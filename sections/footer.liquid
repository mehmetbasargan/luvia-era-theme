{%- style -%}
    {%- liquid
      assign scheme = section.settings.color_scheme.settings
      assign bg_color = scheme.background | default: '#ffffff'
      assign text_color = scheme.text | default: '#000000'
      assign accent_color = scheme.button | default: '#b2ac88'
      assign opacity_val = section.settings.header_opacity | default: 100 | divided_by: 100.0
    -%}

    /* 1. Ana Header ve Değişkenler */
    #main-footer {
      background-color: {{ bg_color | color_modify: 'alpha', opacity_val }} !important;
      color: {{ text_color }} !important;
      --color-primary: {{ text_color }};
      --color-secondary: {{ accent_color }};
      --color-custombg: {{ bg_color }};
      --color-line: {{ text_color | color_modify: 'alpha', 0.1 }};
    }

    /* 2. Mega Menü ve Dropdown Arka Planı */
    #main-footer .absolute.left-0.top-full,
    #main-footer .absolute.min-w-\[200px\],
    #main-footer .mobile-menu-drawer {
      background-color: var(--color-custombg) !important;
    }

    /* 3. Metin ve Link Renkleri */
    #main-footer a, #main-footer button {
      color: var(--color-primary) !important;
      transition: color 0.3s ease;
    }

    #main-footer a:hover, #main-footer button:hover {
      color: var(--color-secondary) !important;
    }

    /* 4. İKON ÇİZGİLERİ (DÜZELTİLDİ) */
    #main-footer svg {
      fill: none !important; /* İkonların içinin dolmasını engeller */
      stroke: currentColor !important; /* Sadece çizgileri renklendirir */
      stroke-width: 1.5; /* Çizgi kalınlığı çok inceyse buradan ayarlayabilirsin */
      transition: stroke 0.3s ease;
    }

    /* Özel Durum: Bazı ikonlar (logo gibi) fill gerektirebilir.
       Eğer logonun içi boşalırsa buraya logo class'ını ekleyebiliriz. */

    /* 5. Sosyal Medya İkonları Hover */
    #main-footer .rounded-full.p-2 {
      border: 1px solid var(--color-line);
      transition: all 0.3s ease;
    }
    #main-footer .rounded-full.p-2:hover {
      background-color: var(--color-secondary);
      border-color: var(--color-secondary);
    }
    #main-footer .rounded-full.p-2:hover svg {
      stroke: #ffffff !important; /* Arka plan renkliyken çizgi beyaz olsun */
    }

    /* 6. Çizgiler ve Borderlar */
    #main-footer .border-b, #main-footer .border-t, #main-footer .border-line {
      border-color: var(--color-line) !important;
    }

    /* Aktif Sayfa Linki (active-link) Kesin Çözüm */
  #main-footer .active-link,
  #main-footer a.active-link,
  #main-footer .mobile-nav-item a.active-link {
    color: var(--color-secondary) !important;
    font-weight: 600 !important; /* Bir tık daha belirgin olması için */
  }

  /* Eğer menü elemanının altındaki bir sayfa aktifse, üst menü de yansın istersen: */
  #main-footer .group:hover > div > a,
  #main-footer .group:hover > div > button {
    color: var(--color-secondary) !important;
  }
{%- endstyle -%}

<footer id="main-footer" class="pt-16 pb-8 px-6 border-t">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
    <div class="flex flex-col space-y-6">
      <div>
        <a href="{{ routes.root_url }}" class="block mb-8">
          {% if section.settings.footer_logo != blank %}
            {%- assign logo_alt = section.settings.footer_logo.alt | default: shop.name -%}
            {{
              section.settings.footer_logo
              | image_url: width: 200
              | image_tag: class: 'h-8 w-auto object-contain', alt: logo_alt, loading: 'eager'
            }}
          {% else %}
            <span class="text-2xl font-light tracking-[0.2em] uppercase">
              {{ 'footer.luvia_era' | t }}
            </span>
          {% endif %}
        </a>

        <p class="mt-4 text-sm leading-relaxed font-light">
          {{ section.settings.footer_description }}
        </p>
      </div>

      <div class="space-y-2 text-sm ">
        <p class="flex items-center gap-2 text-[14px]">
          <span class="">
            {% render 'icon-map' %}
          </span>
          <span class="text-[14px]"> {{ section.settings.footer_address }}</span>
        </p>
        <p class="flex items-center gap-2 text-[14px]">
          <span class="">
            {% render 'icon-envelop' %}
          </span>
          <a href="mailto:{{ section.settings.footer_email }}" class="transition-all duration-200">
            {{- section.settings.footer_email -}}
          </a>
        </p>
      </div>
    </div>

    <div>
      <h4 class="text-sm font-bold uppercase tracking-widest mb-6">
        {{ section.settings.menu_1_title }}
      </h4>
      <ul class="space-y-4 text-md font-light text-primary">
        {% for link in linklists[section.settings.footer_menu_1].links %}
          <li>
            <a href="{{ link.url }}" class=" transition-colors duration-300">
              {{ link.title }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-bold uppercase tracking-widest mb-6">
        {{ section.settings.menu_2_title }}
      </h4>
      <ul class="space-y-4 text-md font-light text-primary">
        {% for link in linklists[section.settings.footer_menu_2].links %}
          <li>
            <a href="{{ link.url }}" class="transition-colors duration-300">
              {{ link.title }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-bold uppercase tracking-widest mb-6">
        {{ 'footer.newsletter' | t }}
      </h4>
      <p class="text-xs text-primary mb-4 font-light italic">
        {{ 'footer.be_first_to_know' | t }}
      </p>

      {% form 'customer', class: 'flex border-b border-gray-400 pb-2' %}
        <input type="hidden" name="contact[tags]" value="newsletter">

        <input
          type="email"
          name="contact[email]"
          value="{{ form.email }}"
          placeholder="{{ 'footer.email_address' | t }}"
          class="bg-transparent border-none text-sm w-full focus:outline-none placeholder:text-primary text-primary"
          aria-required="true"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          required
        >

        <button type="submit" class="uppercase text-xs tracking-widest font-semibold ml-2">
          {{ 'footer.join' | t }}
        </button>

        {%- if form.posted_successfully? -%}
          <p class="text-[14px] text-green-600 absolute mt-8 italic">
            {{ 'newsletter.success' | t | default: 'Thanks for subscribing!' }}
          </p>
        {%- endif -%}

        {%- if form.errors -%}
          <p class="text-[14px] text-red-600 absolute mt-8 italic">
            {{ form.errors.messages.email }}
          </p>
        {%- endif -%}
      {% endform %}
    </div>
  </div>
</footer>

<div class="bg-custombg py-4 text-center border-t border-line">
  <div class="container flex flex-col md:flex-row items-center justify-between">
    <div class="grid__item site-footer__payment-icons">
      <ul class="flex items-center gap-2 mb-5 md:mb-0">
        {% for block in section.blocks %}
          {% if block.settings.payment_icon != blank %}
            <li class="payment-icon">
              {{ block.settings.payment_icon | image_url: width: 50 | image_tag: class: 'w-13 h-8' }}
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>

    <div class="">
      <div class="footer__copyright text-[12px]">
        &copy;
        {{ 'now' | date: '%Y' }}
        {{ shop.name | link_to: routes.root_url }} -
        {{ 'footer.all_rights_reserved' | t }}
      </div>
    </div>
  </div>
</div>

<button
  id="back-to-top"
  class="fixed bottom-8 right-8 z-[120] text-white p-3 rounded-full shadow-2xl transition-all duration-500 transform translate-y-20 opacity-0 hover:scale-110 active:scale-95 cursor-pointer"
  aria-label="Go Up"
>
  {% render 'icon-arrow' %}
</button>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Logo Görseli"
    },
    {
      "type": "text",
      "id": "footer_description",
      "label": "Description",
      "default": "Defining your essence through timeless designs."
    },
    {
      "type": "text",
      "id": "footer_address",
      "label": "Address",
      "default": "Nişantaşı, İstanbul / TR"
    },
    {
      "type": "text",
      "id": "footer_email",
      "label": "Email",
      "default": "info@luviaera.com"
    },
    {
      "type": "text",
      "id": "menu_1_title",
      "label": "1. Menu Title",
      "default": "Collections"
    },
    {
      "type": "link_list",
      "id": "footer_menu_1",
      "label": "1. Menu Selection",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "menu_2_title",
      "label": "2. Menu Title",
      "default": "Customer Care"
    },
    {
      "type": "link_list",
      "id": "footer_menu_2",
      "label": "2. Menu Selection"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "header_opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "label": "Header Opacity Rate",
      "default": 100
    }
  ],
  "blocks": [
    {
      "type": "payment_icons",
      "name": "Payment Icons",
      "settings": [
        {
          "type": "image_picker",
          "id": "payment_icon",
          "label": "Payment Icon",
          "info": "Upload payment method icons (e.g., Visa, Mastercard, PayPal)"
        }
      ]
    }
  ]
}
{% endschema %}
