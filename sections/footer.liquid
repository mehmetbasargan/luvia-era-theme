<footer class="bg-custombg text-primary pt-16 pb-8 px-6 border-t border-line">
  <div class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-12">
    <div class="flex flex-col space-y-6">
      <div>
        <a href="{{ routes.root_url }}" class="block mb-8">
          {% if section.settings.footer_logo != blank %}
            {%- assign logo_alt = section.settings.footer_logo.alt | default: shop.name -%}
            {{
              section.settings.footer_logo
              | image_url: width: 200
              | image_tag: class: 'h-8 w-auto object-contain', alt: logo_alt, loading: 'eager'
            }}
          {% else %}
            <span class="text-2xl font-light tracking-[0.2em] uppercase text-primary">
              {{ 'footer.luvia_era' | t }}
            </span>
          {% endif %}
        </a>

        <p class="mt-4 text-sm text-primary leading-relaxed font-light">
          {{ section.settings.footer_description }}
        </p>
      </div>

      <div class="space-y-2 text-sm text-primary">
        <p class="flex items-center gap-2 text-[14px]">
          <span class="text-primary">
            {% render 'icon-map' %}
          </span>
          <span class="text-[14px]"> {{ section.settings.footer_address }}</span>
        </p>
        <p class="flex items-center gap-2 text-[14px]">
          <span class="text-primary">
            {% render 'icon-envelop' %}
          </span>
          <a href="mailto:{{ section.settings.footer_email }}" class="hover:text-secondary transition-all duration-200">
            {{- section.settings.footer_email -}}
          </a>
        </p>
      </div>
    </div>

    <div>
      <h4 class="text-sm font-bold uppercase tracking-widest mb-6 text-secondary">
        {{ section.settings.menu_1_title }}
      </h4>
      <ul class="space-y-4 text-md font-light text-primary">
        {% for link in linklists[section.settings.footer_menu_1].links %}
          <li>
            <a href="{{ link.url }}" class="hover:text-secondary transition-colors duration-300">
              {{ link.title }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-bold uppercase tracking-widest mb-6 text-secondary">
        {{ section.settings.menu_2_title }}
      </h4>
      <ul class="space-y-4 text-md font-light text-primary">
        {% for link in linklists[section.settings.footer_menu_2].links %}
          <li>
            <a href="{{ link.url }}" class="hover:text-secondary transition-colors duration-300">
              {{ link.title }}
            </a>
          </li>
        {% endfor %}
      </ul>
    </div>

    <div>
      <h4 class="text-sm font-bold uppercase tracking-widest mb-6 text-secondary">
        {{ 'footer.newsletter' | t }}
      </h4>
      <p class="text-xs text-primary mb-4 font-light italic">
        {{ 'footer.be_first_to_know' | t }}
      </p>

      {% form 'customer', class: 'flex border-b border-gray-400 pb-2' %}
        <input type="hidden" name="contact[tags]" value="newsletter">

        <input
          type="email"
          name="contact[email]"
          value="{{ form.email }}"
          placeholder="{{ 'footer.email_address' | t }}"
          class="bg-transparent border-none text-sm w-full focus:outline-none placeholder:text-primary text-primary"
          aria-required="true"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          required
        >

        <button type="submit" class="text-secondary uppercase text-xs tracking-widest font-semibold ml-2">
          {{ 'footer.join' | t }}
        </button>

        {%- if form.posted_successfully? -%}
          <p class="text-[14px] text-green-600 absolute mt-8 italic">
            {{ 'newsletter.success' | t | default: 'Thanks for subscribing!' }}
          </p>
        {%- endif -%}

        {%- if form.errors -%}
          <p class="text-[14px] text-red-600 absolute mt-8 italic">
            {{ form.errors.messages.email }}
          </p>
        {%- endif -%}
      {% endform %}
    </div>
  </div>
</footer>

<div class="bg-custombg py-4 text-center border-t border-line">
  <div class="container flex flex-col md:flex-row items-center justify-between">
    <div class="grid__item site-footer__payment-icons">
      <ul class="flex items-center gap-2 mb-5 md:mb-0">
        <li class="payment-icon">
          {% render 'icon-visa' %}
        </li>
        <li class="payment-icon">
          {% render 'icon-master' %}
        </li>
        <li class="payment-icon">
          {% render '.con-american-express' %}
        </li>
        <li class="payment-icon">
          {% render 'icon-paypal' %}
        </li>
        <li class="payment-icon">
          {% render 'icon-diners-club' %}
        </li>
        <li class="payment-icon">
          {% render 'icon-discover' %}
        </li>
      </ul>
    </div>

    <div class="">
      <div class="footer__copyright text-[12px]">
        &copy;
        {{ 'now' | date: '%Y' }}
        {{ shop.name | link_to: routes.root_url }} -
        {{ 'footer.all_rights_reserved' | t }}
      </div>
      <div class="footer__payment">
        {% if section.settings.show_payment_icons %}
          {% for type in shop.enabled_payment_types %}
            {{ type | payment_type_svg_tag }}
          {% endfor %}
        {% endif %}
      </div>
    </div>
  </div>
</div>

<button
  id="back-to-top"
  class="fixed bottom-8 right-8 z-[120] bg-primary hover:bg-secondary text-white p-3 rounded-full shadow-2xl transition-all duration-500 transform translate-y-20 opacity-0 hover:scale-110 active:scale-95 cursor-pointer"
  aria-label="Go Up"
>
  {% render 'icon-arrow' %}
</button>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "footer_logo",
      "label": "Logo Görseli"
    },
    {
      "type": "text",
      "id": "footer_description",
      "label": "Description",
      "default": "Defining your essence through timeless designs."
    },
    {
      "type": "text",
      "id": "footer_address",
      "label": "Address",
      "default": "Nişantaşı, İstanbul / TR"
    },
    {
      "type": "text",
      "id": "footer_email",
      "label": "Email",
      "default": "info@luviaera.com"
    },
    {
      "type": "text",
      "id": "menu_1_title",
      "label": "1. Menu Title",
      "default": "Collections"
    },
    {
      "type": "link_list",
      "id": "footer_menu_1",
      "label": "1. Menu Selection",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "menu_2_title",
      "label": "2. Menu Title",
      "default": "Customer Care"
    },
    {
      "type": "link_list",
      "id": "footer_menu_2",
      "label": "2. Menu Selection"
    }
  ]
}
{% endschema %}
