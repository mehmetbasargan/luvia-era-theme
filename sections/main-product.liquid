<section class="container py-14">
  <div class="flex flex-col lg:flex-row gap-16 items-start">
    <div class="w-full md:w-full lg:w-2/3 flex flex-row gap-6">
      {% comment %} thumbnails {% endcomment %}
      <div class="hidden md:block w-20 shrink-0">
        <div class="swiper product-thumbs h-full">
          <div class="swiper-wrapper ">
            {% for media in product.media %}
              <div class="swiper-slide cursor-pointer opacity-50 transition-opacity duration-300 [&.swiper-slide-thumb-active]:opacity-100">
                {{
                  media
                  | image_url: width: 200
                  | image_tag: class: ' object-cover w-full h-full', alt: product.title, loading: 'eager'
                }}
              </div>
            {% endfor %}
          </div>
        </div>
      </div>

      {% comment %} main images {% endcomment %}
      <div class="grow h-full overflow-hidden bg-white relative">
        <div class="swiper product-main h-full">
          <div class="swiper-wrapper h-full">
            {% for media in product.media %}
              <div class="swiper-slide h-full">
                {{
                  media
                  | image_url: width: 1500
                  | image_tag: class: 'w-full h-full object-cover object-top', loading: 'eager', alt: product.title
                }}
              </div>
            {% endfor %}
          </div>
          <div class="swiper-button-next text-primary !after:text-lg"></div>
          <div class="swiper-button-prev text-primary !after:text-lg"></div>
        </div>
      </div>
    </div>

    <div class="product-info-column lg:w-2/5 space-y-8 sticky top-28 h-fit">
      <div>
        <h3
          class="font-light tracking-tight uppercase"
          style="color: {{ settings.product_primary_color }}; font-family: {{ settings.product_heading_font.family }}, {{ settings.product_heading_font.fallback_families }};"
        >
          {{ product.title }}
        </h3>
        <div class="mt-4 flex items-center gap-4">
          <span
            id="product-price-display"
            class="text-[20px] font-medium"
            style="color: {{ settings.product_primary_color }};"
          >
            {{- product.selected_or_first_available_variant.price | money -}}
          </span>
          {% if product.compare_at_price > product.price %}
            <span id="product-compare-price" class="text-gray-400 line-through">
              {{- product.compare_at_price | money -}}
            </span>
          {% endif %}
        </div>
      </div>

      <div class="prose prose-sm text-primary leading-relaxed max-w-none">
        {{ product.description }}
      </div>

      {% comment %} Trust Badges (Aynı Tasarım) {% endcomment %}
      <div class="product-trust-badges mt-8 pt-8 border-t border-line">
        <div class="grid grid-cols-1 gap-4 text-primary">
          <div class="flex items-center gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="text-[12px] uppercase tracking-[0.15em]">{{ 'general.ethically_sourced' | t }}</span>
          </div>
          <div class="flex items-center gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <rect x="1" y="3" width="15" height="13"/><polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/><circle cx="5.5" cy="18.5" r="2.5"/><circle cx="18.5" cy="18.5" r="2.5"/>
            </svg>
            <span class="text-[12px] uppercase tracking-[0.15em]">{{ 'general.free_express_shipping' | t }}</span>
          </div>
        </div>
      </div>

      {%- unless product.has_only_default_variant -%}
        <div class="product-variants space-y-6 py-8 border-y border-line my-8">
          {%- for option in product.options_with_values -%}
            <div class="variant-wrapper" data-index="{{ forloop.index }}">
              <label class="text-[13px] uppercase tracking-[0.2em] text-primary mb-4 block">
                {{ option.name }}:
                <span id="option-value-{{ forloop.index }}" class="text-black font-medium">
                  {{- option.selected_value -}}
                </span>
              </label>

              <div class="flex flex-wrap gap-3">
                {%- for value in option.values -%}
                  <label class="cursor-pointer">
                    <input
                      type="radio"
                      name="{{ option.name }}"
                      value="{{ value | escape }}"
                      {% if option.selected_value == value %}
                        checked
                      {% endif %}
                      class="sr-only peer"
                    >
                    {%- if option.name == 'Renk' or option.name == 'Color' -%}
                      <span
                        class="block w-8 h-8 rounded-full border border-line ring-offset-2 ring-black peer-checked:ring-1 transition-all"
                        style="background-color: {{ value | handle }};"
                      ></span>
                    {%- else -%}
                      <span class="min-w-[45px] h-[45px] flex items-center justify-center border border-line text-[14px] uppercase tracking-widest peer-checked:border-black peer-checked:bg-black peer-checked:text-white transition-all px-4">
                        {{ value }}
                      </span>
                    {%- endif -%}
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endunless -%}

      <div class="product-form-container mt-8">
        {%- form 'product', product, id: 'product-form-main' -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          <div class="flex flex-col gap-4">
            <button
              type="submit"
              name="add"
              class="add-to-cart-btn w-full bg-primary text-white py-5 text-[13px] font-medium uppercase tracking-[0.3em] hover:bg-secondary transition-all {% unless product.available %}opacity-50 cursor-not-allowed{% endunless %}"
              {% unless product.available %}
                disabled
              {% endunless %}
            >
              {% if product.available %}
                {{ 'products.product.add_to_cart' | t }}
              {% else %}
                {{ 'products.product.sold_out' | t }}
              {% endif %}
            </button>

            {% comment %} Wishlist Butonu Genelde Buraya Uygulama Tarafından Eklenir {% endcomment %}
            <div class="wishlist-anchor"></div>
          </div>
        {%- endform -%}
      </div>

      <div class="pt-8 border-t border-line space-y-4">
        <details class="group">
          <summary class="flex justify-between items-center cursor-pointer list-none text-[14px] uppercase tracking-widest text-primary font-medium">
            {{ 'products.product.details_title' | t }}
            <span class="group-open:rotate-180 transition-transform">↓</span>
          </summary>
          <div class="pt-4 text-[14px] text-primary leading-6">
            {{ product.metafields.custom.product_details | newline_to_br }}
          </div>
        </details>
      </div>
    </div>
  </div>
</section>

<style>
  .product-thumbs .swiper-slide {
    height: 120px !important;
    width: 100% !important;
    margin-bottom: 10px;
    display: flex;
  }
  .swiper-button-next,
  .swiper-button-prev {
    height: 50px !important;
    width: 50px !important;
    background-color: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(4px);
    border-radius: 50%;
    color: var(--color-primary);
    z-index: 10;
    transition: all 0.3s ease;
  }
  .swiper-button-next:hover,
  .swiper-button-prev:hover {
    background: var(--color-secondary);
    color: white;
  }
  #MainContent,
  .shopify-section {
    overflow: visible !important;
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  // 1. Swiper Init
  if (document.querySelector('.product-thumbs')) {
    const thumbsSwiper = new Swiper('.product-thumbs', { direction: 'vertical', slidesPerView: 'auto', loop: true, spaceBetween: 10, freeMode: true, watchSlidesProgress: true });
    new Swiper('.product-main', { loop: true, zoom: { maxRatio: 2.5 }, navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' }, thumbs: { swiper: thumbsSwiper } });
  }

  // 2. Variant Logic
  const variantData = {{ product.variants | json }};
  const radios = document.querySelectorAll('.variant-wrapper input[type="radio"]');

  radios.forEach(radio => {
    radio.addEventListener('change', () => {
      // Label Güncelle
      const wrapper = radio.closest('.variant-wrapper');
      const labelId = `option-value-${wrapper.getAttribute('data-index')}`;
      const labelSpan = document.getElementById(labelId);
      if(labelSpan) labelSpan.textContent = radio.value;

      // ID ve Fiyat Güncelle
      const selectedOptions = Array.from(document.querySelectorAll('.variant-wrapper input:checked')).map(r => r.value);
      const matched = variantData.find(v => JSON.stringify(v.options) === JSON.stringify(selectedOptions));

      if (matched) {
        const idInput = document.querySelector('input[name="id"]');
        idInput.value = matched.id;
        
        // Fiyat Senkronizasyonu
        const priceDisplay = document.getElementById('product-price-display');
        if (priceDisplay) priceDisplay.innerText = (matched.price / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' });

        // Dış Uygulama (Wishlist) Tetikleyicileri
        idInput.dispatchEvent(new Event('change', { bubbles: true }));
        document.dispatchEvent(new CustomEvent('variant:change', { detail: { variant: matched } }));
        
        // URL Güncelle
        window.history.replaceState({}, '', `?variant=${matched.id}`);
      }
    });
  });

  // 3. Ajax Cart
  const productForm = document.querySelector('#product-form-main');
  if (productForm) {
    productForm.addEventListener('submit', function (e) {
      // Wishlist butonuna basıldıysa sepete ekleme kodunu durdur
      if (e.submitter && (e.submitter.classList.contains('wishlist') || e.submitter.getAttribute('name') !== 'add')) return;

      e.preventDefault();
      fetch('/cart/add.js', { method: 'POST', body: new FormData(productForm) })
      .then(r => r.json())
      .then(() => {
        if (typeof openAndRefreshCart === 'function') openAndRefreshCart();
        else window.location.href = '/cart';
      })
      .catch(err => console.error('Hata:', err));
    });
  }
});
</script>
