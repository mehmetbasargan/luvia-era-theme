<section class="container py-14">
  <div class="flex flex-col lg:flex-row gap-16 items-start">
    <div class="w-full md:w-full lg:w-2/3 flex flex-row gap-6">
      {% comment %} thumbnails {% endcomment %}
      <div class="hidden md:block w-20 shrink-0">
        <div class="swiper product-thumbs h-full">
          <div class="swiper-wrapper ">
            {% for media in product.media %}
              <div class="swiper-slide cursor-pointer opacity-50 transition-opacity duration-300 [&.swiper-slide-thumb-active]:opacity-100">
                {{
                  media
                  | image_url: width: 200
                  | image_tag: class: 'object-cover w-full h-full', alt: product.title, loading: 'eager'
                }}
              </div>
            {% endfor %}
          </div>
        </div>
      </div>

      {% comment %} main images {% endcomment %}
      <div class="grow h-full overflow-hidden bg-white relative">
        <div class="swiper product-main h-full">
          <div class="swiper-wrapper h-full">
            {% for media in product.media %}
              <div class="swiper-slide h-full">
                {{
                  media
                  | image_url: width: 1000, format: 'webp'
                  | image_tag:
                    class: 'w-full h-[700px] md:h-full object-cover object-top',
                    loading: 'eager',
                    alt: product.title
                }}
              </div>
            {% endfor %}
          </div>
          <div class="swiper-button-next hidden md:flex"></div>
          <div class="swiper-button-prev hidden md:flex"></div>
          <div class="swiper-pagination flex md:hidden"></div>
        </div>
      </div>
    </div>

    <div class="product-info-column w-full lg:w-2/5 space-y-8 sticky top-28">
      <div>
        <h3
          class="font-light tracking-tight uppercase"
          style="color: {{ settings.product_primary_color }}; font-family: {{ settings.product_heading_font.family }}, {{ settings.product_heading_font.fallback_families }};"
        >
          {{ product.title }}
        </h3>
        <div class="mt-4 flex items-center gap-4">
          <span
            class="product-price-display text-[20px] font-medium"
            style="color: {{ settings.product_primary_color }};"
          >
            {{- product.selected_or_first_available_variant.price | money -}}
          </span>
          {% if product.compare_at_price > product.price %}
            <span class="product-compare-price text-gray-400 line-through">{{ product.compare_at_price | money }}</span>
          {% endif %}
        </div>
      </div>

      <div class="prose prose-sm text-primary leading-relaxed max-w-none">
        {{ product.description }}
      </div>

      {%- unless product.has_only_default_variant -%}
        <div class="product-variants space-y-6 py-8 border-y border-line my-8">
          {%- for option in product.options_with_values -%}
            <div class="variant-wrapper" data-option-index="{{ forloop.index }}">
              <label class="text-[13px] uppercase tracking-[0.2em] text-primary mb-4 block">
                {{ option.name }}:
                <span id="option-value-{{ forloop.index }}" class="text-black font-medium">
                  {{- option.selected_value -}}
                </span>
              </label>
              <div class="flex flex-wrap gap-3">
                {%- for value in option.values -%}
                  <label class="cursor-pointer">
                    <input
                      type="radio"
                      name="{{ option.name }}"
                      value="{{ value | escape }}"
                      {% if option.selected_value == value %}
                        checked
                      {% endif %}
                      class="sr-only peer"
                    >
                    {%- if option.name == 'Renk' or option.name == 'Color' -%}
                      <span
                        class="block w-8 h-8 rounded-full border border-line ring-offset-2 ring-primary peer-checked:ring-1 transition-all"
                        style="background-color: {{ value | handle }};"
                      ></span>
                    {%- else -%}
                      <span class="min-w-[45px] h-[45px] flex items-center justify-center border border-primary text-[14px] uppercase tracking-widest peer-checked:bg-primary peer-checked:text-white transition-all px-4">
                        {{ value }}
                      </span>
                    {%- endif -%}
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endunless -%}

      <div class="product-form-container mt-8">
        <form action="{{ routes.cart_add_url }}" method="post" id="product-form-{{ section.id }}">
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
          <button
            type="submit"
            name="add"
            class="add-to-cart-btn w-full bg-primary text-white py-5 text-[13px] font-medium uppercase tracking-[0.3em] hover:bg-secondary transition-all {% unless product.available %}opacity-50 cursor-not-allowed{% endunless %}"
            aria-label="{% if product.available %}{{ 'products.product.add_to_cart' | t }} for {{ product.title }}{% else %}{{ 'products.product.sold_out' | t }}{% endif %}"
            {% unless product.available %}
              disabled
            {% endunless %}
          >
            {% if product.available -%}
              {{- 'products.product.add_to_cart' | t -}}
            {%- else -%}
              {{- 'products.product.sold_out' | t -}}
            {%- endif %}
          </button>
        </form>
      </div>

      {% comment %} Accordion Detaylar {% endcomment %}
      <div class="pt-8 border-t border-line space-y-4">
        <details class="group">
          <summary class="flex justify-between items-center cursor-pointer list-none text-[14px] uppercase tracking-widest text-primary">
            {{ 'products.product.details_title' | t }}
            <span class="group-open:rotate-180 transition-transform">↓</span>
          </summary>
          <div class="pt-4 text-[14px] text-primary leading-6">
            {{ product.metafields.custom.product_details | newline_to_br }}
          </div>
        </details>
      </div>
    </div>
  </div>
</section>

<style>
  .product-thumbs .swiper-slide {
    height: 120px !important;
    width: 100% !important;
    margin-bottom: 10px;
  }
  .swiper-button-next,
  .swiper-button-prev {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(4px);
    border-radius: 50%;
    color: var(--color-primary);
  }
  .swiper-button-next .swiper-navigation-icon,
  .swiper-button-prev .swiper-navigation-icon {
    width: 10px !important;
  }
  .swiper-horizontal {
    &.swiper-rtl .swiper-button-next,
    &.swiper-rtl ~ .swiper-button-next,
    & ~ .swiper-button-prev,
    .swiper-button-prev {
      left: 20px;
      right: auto;
    }
  }
  .swiper-horizontal {
    &.swiper-rtl .swiper-button-prev,
    &.swiper-rtl ~ .swiper-button-prev,
    & ~ .swiper-button-next,
    .swiper-button-next {
      left: auto;
      right: 20px;
    }
  }

  .swiper-horizontal > .swiper-pagination-bullets,
  .swiper-pagination-bullets.swiper-pagination-horizontal,
  .swiper-pagination-custom,
  .swiper-pagination-fraction {
    bottom: 20px;
    left: 0;
    top: var(--swiper-pagination-top, auto);
    width: 100%;
    align-items: center;
    justify-content: center;
  }

  .swiper-pagination-bullet {
    background: var(--color-secondary);
    height: 12px !important;
    width: 12px !important;
    opacity: 0.5;
    transition: all 0.3s ease;
  }
  .swiper-pagination-bullet-active {
    background: var(--color-secondary);
    opacity: 1;
    width: 30px !important;
    border-radius: 6px;
  }

  @media screen and (min-width: 1024px) {
    .product-info-column {
      position: sticky;
      top: 100px;
      height: fit-content;
    }
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  // 1. Swiper Kurulumu
  if (document.querySelector('.product-thumbs')) {
    const thumbsSwiper = new Swiper('.product-thumbs', {
      direction: 'vertical', slidesPerView: 'auto', loop: true, spaceBetween: 10, freeMode: true, watchSlidesProgress: true
    });
    new Swiper('.product-main', {
      loop: true, zoom: { maxRatio: 2.5 },
      navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
      thumbs: { swiper: thumbsSwiper },
      pagination: {
        el: ".swiper-pagination",
        clickable: true,
      },
     /*  autoplay: {
        delay: 6000,
        disableOnInteraction: false,
      }, */
    });
  }

  // 2. Variant Change
  const variantData = {{ product.variants | json }};
  const variantRadios = document.querySelectorAll('.variant-wrapper input[type="radio"]');
  
  variantRadios.forEach(radio => {
    radio.addEventListener('change', function() {
      // Label Update
      const optionIndex = this.closest('.variant-wrapper').dataset.optionIndex;
      document.getElementById(`option-value-${optionIndex}`).textContent = this.value;

      // Find selected variant
      const selectedOptions = Array.from(document.querySelectorAll('.variant-wrapper input:checked')).map(input => input.value);
      const matchedVariant = variantData.find(v => JSON.stringify(v.options) === JSON.stringify(selectedOptions));

      if (matchedVariant) {
        // ID Update
        document.querySelector('input[name="id"]').value = matchedVariant.id;
        // Price Update
        document.querySelector('.product-price-display').innerText = (matchedVariant.price / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' });
        // Button Update
        const btn = document.querySelector('.add-to-cart-btn');
        if (matchedVariant.available) {
          btn.disabled = false; btn.classList.remove('opacity-50'); btn.innerText = "{{ 'products.product.add_to_cart' | t }}";
        } else {
          btn.disabled = true; btn.classList.add('opacity-50'); btn.innerText = "{{ 'products.product.sold_out' | t }}";
        }
        // URL Update
        window.history.replaceState({}, '', `?variant=${matchedVariant.id}`);
        // Update wishlist applications
        document.querySelector('input[name="id"]').dispatchEvent(new Event('change', { bubbles: true }));
      }
    });
  });

  // 3. AJAX Add to Cart
  const productForm = document.getElementById('product-form-{{ section.id }}');
  if (productForm) {
    productForm.addEventListener('submit', function (e) {
      e.preventDefault();
      const submitBtn = this.querySelector('.add-to-cart-btn');
      submitBtn.disabled = true;
      submitBtn.innerText = 'Adding...';

      fetch('{{ routes.cart_add_url }}', {
        method: 'POST',
        body: new FormData(this)
      })
      .then(res => res.json())
      .then(data => {
        if (typeof openAndRefreshCart === 'function') {
          openAndRefreshCart();
        } else {
          window.location.href = '/cart';
        }
        submitBtn.disabled = false;
        submitBtn.innerText = "{{ 'products.product.add_to_cart' | t }}";
      })
      .catch(err => {
        console.error('Cart Error:', err);
        submitBtn.disabled = false;
      });
    });
  }
});
</script>
