<section class="container py-14">
  <div class="flex flex-col lg:flex-row gap-16 items-start">
    <div class="w-full md:w-full lg:w-2/3 flex flex-row gap-6">
      {% comment %} thumbnails ddddd {% endcomment %}
      <div class="hidden md:block w-20 shrink-0">
        <div class="swiper product-thumbs h-full">
          <div class="swiper-wrapper ">
            {% for media in product.media %}
              <div class="swiper-slide cursor-pointer opacity-50 transition-opacity duration-300 [&.swiper-slide-thumb-active]:opacity-100">
                {{
                  media
                  | image_url: width: 200
                  | image_tag: class: ' object-cover', alt: product.title, loading: 'eager'
                }}
              </div>
            {% endfor %}
          </div>
        </div>
      </div>

      {% comment %} main images ffff {% endcomment %}
      <div class="grow h-full overflow-hidden bg-white">
        <div class="swiper product-main h-full">
          <div class="swiper-wrapper h-full">
            {% for media in product.media %}
              <div class="swiper-slide h-full">
                {{
                  media
                  | image_url: width: 1500
                  | image_tag: class: 'w-full h-full object-cover object-top', loading: 'eager', alt: product.title
                }}
              </div>
            {% endfor %}
          </div>
          <div class="swiper-button-next text-primary !after:text-lg"></div>
          <div class="swiper-button-prev text-primary !after:text-lg"></div>
        </div>
      </div>
    </div>

    <div class="product-info-column lg:w-2/5 space-y-8">
      <div>
        <h3
          class="font-light tracking-tight uppercase"
          style="color: {{ settings.product_primary_color }}; font-family: {{ settings.product_heading_font.family }}, {{ settings.product_heading_font.fallback_families }};"
        >
          {{ product.title }}
        </h3>
        <div class="mt-4 flex items-center gap-4">
          <span
            class="product-price-display text-[20px] font-medium"
            style="color: {{ settings.product_primary_color }};"
          >
            {{- product.price | money -}}
          </span>
          {% if product.compare_at_price > product.price %}
            <span class="product-compare-price text-gray-400 line-through">{{ product.compare_at_price | money }}</span>
          {% endif %}
        </div>
      </div>

      <div class="prose prose-sm text-primary leading-relaxed max-w-none">
        {{ product.description }}
      </div>

      <div class="product-trust-badges mt-8 pt-8 border-t border-line">
        <div class="grid grid-cols-1 gap-4">
          <div class="flex items-center gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <path d="M5 13l4 4L19 7" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="text-[12px] uppercase tracking-[0.15em] text-primary">
              {{- 'general.ethically_sourced' | t -}}
            </span>
          </div>

          <div class="flex items-center gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <rect x="1" y="3" width="15" height="13" />
              <polygon points="16 8 20 8 23 11 23 16 16 16 16 8" />
              <circle cx="5.5" cy="18.5" r="2.5" />
              <circle cx="18.5" cy="18.5" r="2.5" />
            </svg>
            <span class="text-[12px] uppercase tracking-[0.15em] text-primary">
              {{ 'general.free_express_shipping' | t }}
            </span>
          </div>

          <div class="flex items-center gap-3">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
            </svg>
            <span class="text-[12px] uppercase tracking-[0.15em] text-primary">
              {{ 'general.secure_payment' | t }}
            </span>
          </div>
        </div>
      </div>

      {%- unless product.has_only_default_variant -%}
        <div class="product-variants space-y-6 py-8 border-y border-line my-8">
          {%- for option in product.options_with_values -%}
            <div class="variant-wrapper">
              <label class="text-[13px] uppercase tracking-[0.2em] text-primary mb-4 block">
                {{ option.name }}:
                <span id="option-value-{{ forloop.index }}" class="text-black font-medium">
                  {{- option.selected_value -}}
                </span>
              </label>

              <div class="flex flex-wrap gap-3">
                {%- for value in option.values -%}
                  <label class="cursor-pointer">
                    <input
                      type="radio"
                      name="{{ option.name }}"
                      value="{{ value | escape }}"
                      {% if option.selected_value == value %}
                        checked
                      {% endif %}
                      class="sr-only peer"
                    >

                    {%- if option.name == 'Renk' or option.name == 'Color' -%}
                      <span
                        class="block w-8 h-8 rounded-full border border-line ring-offset-2 ring-primary peer-checked:ring-1 transition-all"
                        style="background-color: {{ value | handle }};"
                      >
                      </span>
                    {%- else -%}
                      <span class="min-w-[45px] h-[45px] flex items-center justify-center border border-primary text-[14px] uppercase tracking-widest peer-checked:border-primary peer-checked:bg-primary peer-checked:text-white transition-all px-4">
                        {{ value }}
                      </span>
                    {%- endif -%}
                  </label>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        </div>
      {%- endunless -%}

      <div class="product-form-container mt-8">
        {%- form 'product', product -%}
          <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

          <div class="flex flex-col gap-4">
            <button
              type="submit"
              name="add"
              class="w-full bg-primary text-white py-5 text-[13px] font-medium uppercase tracking-[0.3em] hover:bg-secondary transition-all {% unless product.available %}opacity-50 cursor-not-allowed{% endunless %}"
              {% unless product.available %}
                disabled
              {% endunless %}
            >
              {% if product.available %}
                {{ 'products.product.add_to_cart' | t }}
              {% else %}
                {{ 'products.product.sold_out' | t }}
              {% endif %}
            </button>

            <!-- Wishlist Button -->
            <button
              type="button"
              id="wishlist-btn-{{ product.id }}"
              onclick="console.log('Wishlist button clicked'); window.LuviaWishlist.toggle('{{ product.id }}')"
              class="w-full border border-primary text-primary py-3 text-[11px] font-medium uppercase tracking-[0.3em] hover:bg-primary hover:text-white transition-all"
            >
              <span id="wishlist-text-{{ product.id }}">Add to Wishlist</span>
            </button>
          </div>
        {%- endform -%}
      </div>

      <div class="pt-8 border-t border-line space-y-4">
        <details class="group">
          <summary class="flex justify-between items-center cursor-pointer list-none text-[14px] uppercase tracking-widest text-primary">
            {{ 'products.product.details_title' | t }}
            <span class="group-open:rotate-180 transition-transform">↓</span>
          </summary>
          <div class="pt-4 text-[14px] text-primary leading-6">
            {{ product.metafields.custom.product_details | newline_to_br }}
          </div>
        </details>
        <details class="group">
          <summary class="flex justify-between items-center cursor-pointer list-none text-[14px] uppercase tracking-widest text-primary">
            {{ 'products.product.shipping_title' | t }}
            <span class="group-open:rotate-180 transition-transform">↓</span>
          </summary>
          <div class="pt-4 text-[14px] text-primary leading-6">
            {{ product.metafields.custom.shipping_returns | newline_to_br }}
          </div>
        </details>
      </div>
    </div>
  </div>
</section>

<style>
  .product-thumbs .swiper-slide {
    height: 120px !important;
    width: 100% !important;
    margin-bottom: 10px;
    display: flex;
  }
  .product-thumbs {
    padding-right: 0px;
  }
  .swiper-button-next,
  .swiper-button-prev {
    height: 50px !important;
    width: 50px !important;
    background-color: color-mix(in srgb, var(--color-white), transparent 60%);
    backdrop-filter: blur(4px);
    border-radius: 50%;
    padding: 15px;
    color: var(--color-primary);
    z-index: 10;
    transition: background-color 0.3s ease;
  }

  .swiper-button-next:hover,
  .swiper-button-prev:hover {
    height: 50px !important;
    width: 50px !important;
    background: var(--color-secondary);
    border-radius: 50%;
    padding: 15px;
    color: var(--color-white);
    z-index: 10;
  }

  .swiper-horizontal {
    &.swiper-rtl .swiper-button-next,
    &.swiper-rtl ~ .swiper-button-next,
    & ~ .swiper-button-prev,
    .swiper-button-prev {
      left: 35px;
      right: auto;
    }
  }

  .swiper-horizontal {
    &.swiper-rtl .swiper-button-next,
    &.swiper-rtl ~ .swiper-button-next,
    & ~ .swiper-button-prev,
    .swiper-button-next {
      right: 35px;
      left: auto;
    }
  }

  #MainContent,
  .shopify-section {
    overflow: visible !important;
  }

  @media screen and (min-width: 1024px) {
    .container > .flex {
      display: flex !important;
      align-items: flex-start !important;
      overflow: visible !important;
    }

    .product-info-column {
      position: -webkit-sticky;
      position: sticky;
      top: 100px;
      height: fit-content !important;
      z-index: 10;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    if (document.querySelector('.product-thumbs')) {
      const thumbsSwiper = new Swiper('.product-thumbs', {
        direction: 'vertical',
        slidesPerView: 'auto',
        loop: true,
        spaceBetween: 10,
        freeMode: true,
        watchSlidesProgress: true,
      });
      const mainSwiper = new Swiper('.product-main', {
        spaceBetween: 0,
        loop: true,
        zoom: {
    maxRatio: 2.5,
  },
        navigation: { nextEl: '.swiper-button-next', prevEl: '.swiper-button-prev' },
        thumbs: { swiper: thumbsSwiper },
      });
    }

    // Add to cart functionality
    document.addEventListener('DOMContentLoaded', function() {
      const productForm = document.querySelector('form[action="/cart/add"]');
      if (productForm) {
        productForm.addEventListener('submit', function (e) {
          e.preventDefault();
          const formData = new FormData(productForm);
          const submitBtn = productForm.querySelector('button[type="submit"]');
          
          // Loading state
          if (submitBtn) {
            submitBtn.disabled = true;
            submitBtn.innerText = 'Adding...';
          }
          
          fetch('/cart/add.js', { 
            method: 'POST', 
            body: formData,
            headers: {
              'X-Requested-With': 'XMLHttpRequest'
            }
          })
          .then((response) => response.json())
          .then((data) => {
          console.log('Product added to cart:', data);
          
          // Dispatch events for other components
          document.dispatchEvent(new CustomEvent('cart:updated', {
            detail: { cart: data }
          }));
          document.dispatchEvent(new CustomEvent('product:added', {
            detail: { product: data }
          }));
          
          openAndRefreshCart();
          showToast('Product added to cart!', 'success');
          
          // Reset button state
          if (submitBtn) {
            submitBtn.disabled = false;
            submitBtn.innerText = "{{ 'products.product.add_to_cart' | t }}";
          }
        })
          .catch((error) => {
            console.error('Sepet Hatası:', error);
            // Show error message and reset button
            if (submitBtn) {
              submitBtn.disabled = false;
              submitBtn.innerText = "{{ 'products.product.add_to_cart' | t }}";
              submitBtn.classList.add('bg-red-500');
              setTimeout(() => {
                submitBtn.classList.remove('bg-red-500');
              }, 2000);
            }
          });
        });
      }
    });

    // Variant change listeners
    document.querySelectorAll('.variant-wrapper').forEach((wrapper, index) => {
  const labelSpan = document.getElementById(`option-value-${index + 1}`);
  const inputs = wrapper.querySelectorAll('input[type="radio"]');

  inputs.forEach(input => {
    input.addEventListener('change', (e) => {
      labelSpan.textContent = e.target.value;
      
      updateVariantID(); 
      e.preventDefault();
      e.stopPropagation();
    });
  });
});

function updateVariantID() {
  const selectedOptions = Array.from(document.querySelectorAll('input[type="radio"]:checked')).map(input => input.value);
  const variantData = {{ product.variants | json }};
  
  const matchedVariant = variantData.find(variant => {
    return variant.options.every((option, index) => option === selectedOptions[index]);
  });

  if (matchedVariant) {
    // 1. Gizli input ID'yi güncelle
    document.querySelector('input[name="id"]').value = matchedVariant.id;

    // 2. Fiyatı güncelle
    const priceDisplay = document.querySelector('.product-price-display');
    if (priceDisplay) {
      priceDisplay.innerText = (matchedVariant.price / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' });
    }

    // 3. Compare at price güncelle
    const compareDisplay = document.querySelector('.product-compare-price');
    if (compareDisplay && matchedVariant.compare_at_price) {
      compareDisplay.innerText = (matchedVariant.compare_at_price / 100).toLocaleString('en-US', { style: 'currency', currency: 'USD' });
      compareDisplay.classList.remove('hidden');
    } else if (compareDisplay) {
      compareDisplay.classList.add('hidden');
    }

    // 4. Buton ve Stok kontrolü
    const btn = document.querySelector('button[type="submit"]');
    if (matchedVariant.available) {
      btn.disabled = false;
      btn.classList.remove('opacity-50', 'cursor-not-allowed');
      btn.innerText = "{{ 'products.product.add_to_cart' | t }}";
    } else {
      btn.disabled = true;
      btn.classList.add('opacity-50', 'cursor-not-allowed');
      btn.innerText = "{{ 'products.product.sold_out' | t }}";
    }

    // 5. URL'i güncelle
    window.history.replaceState({}, '', `?variant=${matchedVariant.id}`);
  }
}

  // Wishlist functionality
    function toggleWishlist(productId) {
      let wishlist = JSON.parse(localStorage.getItem('luvia-wishlist') || '[]');
      const wishlistBtn = document.getElementById(`wishlist-btn-${productId}`);
      const wishlistText = document.getElementById(`wishlist-text-${productId}`);
      
      if (wishlist.includes(productId.toString())) {
        // Remove from wishlist
        wishlist = wishlist.filter(id => id !== productId.toString());
        wishlistText.textContent = 'Add to Wishlist';
        wishlistBtn.classList.remove('bg-primary', 'text-white');
        wishlistBtn.classList.add('border', 'text-primary');
      } else {
        // Add to wishlist
        wishlist.push(productId.toString());
        wishlistText.textContent = 'Remove from Wishlist';
        wishlistBtn.classList.add('bg-primary', 'text-white');
        wishlistBtn.classList.remove('border', 'text-primary');
      }
      
      localStorage.setItem('luvia-wishlist', JSON.stringify(wishlist));
      
      // Dispatch event for other components
      window.dispatchEvent(new CustomEvent('wishlist:updated', {
        detail: { productId, wishlist }
      }));
    }
    
    // Check if product is already in wishlist
    function checkWishlistStatus(productId) {
      const wishlist = JSON.parse(localStorage.getItem('luvia-wishlist') || '[]');
      const wishlistBtn = document.getElementById(`wishlist-btn-${productId}`);
      const wishlistText = document.getElementById(`wishlist-text-${productId}`);
      
      if (wishlist.includes(productId.toString())) {
        wishlistText.textContent = 'Remove from Wishlist';
        wishlistBtn.classList.add('bg-primary', 'text-white');
        wishlistBtn.classList.remove('border', 'text-primary');
      }
    }
    
    // Initialize wishlist status
    checkWishlistStatus('{{ product.id }}');

    // Handle Add to Cart for product cards
    function handleAddToCart(e, variantId) {
      const btn = e.currentTarget;
      const originalText = btn.innerText;
      btn.innerText = 'Adding...';
      btn.disabled = true;

      fetch('/cart/add.js?t=' + Date.now(), {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 }),
      })
        .then((res) => res.json())
        .then((cartData) => {
          btn.innerText = 'ADDED';
          console.log('Product added to cart:', cartData);
          
          // Dispatch events for other components
          document.dispatchEvent(new CustomEvent('cart:updated', {
            detail: { cart: cartData }
          }));
          document.dispatchEvent(new CustomEvent('product:added', {
            detail: { product: cartData }
          }));
          
          // Open cart drawer
          openAndRefreshCart();
          showToast('Product added to cart!', 'success');
          
          // Reset button after delay
          setTimeout(() => {
            btn.innerText = originalText;
            btn.disabled = false;
          }, 2000);
        })
        .catch((error) => {
          console.error('Add to cart error:', error);
          btn.innerText = 'ERROR';
          btn.classList.add('bg-red-500', 'text-white');
          
          // Reset button after delay
          setTimeout(() => {
            btn.innerText = originalText;
            btn.disabled = false;
            btn.classList.remove('bg-red-500', 'text-white');
          }, 2000);
        });
    }

  function openAndRefreshCart() {
    console.log('Opening cart drawer...');
    fetch('/cart.js')
      .then((res) => res.json())
      .then((cart) => {
        console.log('Cart data:', cart);
        const itemsContainer = document.getElementById('cart-drawer-items');
        const totalPriceContainer = document.getElementById('cart-total-price');
        const drawer = document.getElementById('cart-drawer');
        const overlay = document.getElementById('cart-drawer-overlay');
        const content = document.getElementById('cart-drawer-content');
        
        console.log('Cart drawer elements:', {
          drawer: !!drawer,
          overlay: !!overlay,
          content: !!content,
          itemsContainer: !!itemsContainer,
          totalPriceContainer: !!totalPriceContainer,
          drawerElement: drawer,
          overlayElement: overlay,
          contentElement: content
        });
        
        if (!drawer || !overlay || !content) {
          console.error('Cart drawer elements not found');
          return;
        }

        if (cart.items.length > 0) {
          itemsContainer.innerHTML = cart.items
            .map(
              (item, index) => `
                <div class="flex gap-4 border-b border-gray-50 pb-4">
                    <img src="${item.image}" alt="${item.product_title}" class="w-20 h-24 object-cover">
                    <div class="flex-1">
                      <div class="flex justify-between">
                        <h4 class="text-[10px] uppercase tracking-widest text-primary">${item.product_title}</h4>
                        <button onclick="removeCartItem(${
                          index + 1
                        })" class="text-[9px] text-gray-400 hover:text-black uppercase underline" aria-label="Remove item from cart">${ "{{ 'cart.remove' | t }}" }</button>
                      </div>
                      <p class="text-[10px] text-gray-400 mt-1">${item.variant_title || ''}</p>
                      <p class="text-xs mt-2 font-medium">${(item.price / 100).toFixed(2)} {{ cart.currency.symbol }}</p>
                    </div>
                </div>
            `
            )
            .join('');
        } else {
          itemsContainer.innerHTML =
            '<p class="text-[10px] uppercase tracking-widest text-center mt-10 text-gray-400">${ "{{ 'products.product.empty_cart' | t }}" }</p>';
        }

        totalPriceContainer.innerText = (cart.total_price / 100).toFixed(2) + ' ' + cart.currency.symbol;

        const drawer = document.getElementById('cart-drawer');
        const overlay = document.getElementById('cart-drawer-overlay');
        const content = document.getElementById('cart-drawer-content');
        if (drawer && overlay && content) {
          drawer.classList.remove('invisible');
          setTimeout(() => {
            overlay.classList.replace('opacity-0', 'opacity-100');
            content.classList.replace('translate-x-full', 'translate-x-0');
          }, 10);
        } else {
          console.error('Cart drawer elements not found for opening');
        }
      });
  }

  function removeCartItem(line) {
    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ line: line, quantity: 0 }),
    })
      .then((res) => res.json())
      .then(() => {
        openAndRefreshCart(); 
      })
      .catch((err) => console.error('Silme hatası:', err));
  }

  function closeCartDrawer() {
    const drawer = document.getElementById('cart-drawer');
    const overlay = document.getElementById('cart-drawer-overlay');
    const content = document.getElementById('cart-drawer-content');
    overlay.classList.replace('opacity-100', 'opacity-0');
    content.classList.replace('translate-x-0', 'translate-x-full');
    setTimeout(() => {
      drawer.classList.add('invisible');
    }, 500);
  }
</script>

{% schema %}
{
  "name": "Product Page",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "product_primary_color",
      "label": "Primary Color",
      "default": "#3b443c"
    },
    {
      "type": "color",
      "id": "product_secondary_color",
      "label": "Secondary Color",
      "default": "#b2ac88"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "font_picker",
      "id": "product_heading_font",
      "label": "Heading Font",
      "default": "josefin_sans_n4"
    }
  ]
}
{% endschema %}
