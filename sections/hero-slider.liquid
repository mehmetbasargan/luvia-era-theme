<div class="swiper group myHeroSwiper w-full h-[calc(100dvh-var(--header-height,0px))] lg:h-[calc(100vh-var(--header-height,0px))]">
  <div class="swiper-wrapper">
    {% for block in section.blocks %}
      <div class="swiper-slide relative w-full h-full overflow-hidden">
        <div class="bg-[{{ section.settings.overlay_color }}] bg-opacity-[{{ section.settings.overlay_opacity }}]">
          {% if block.settings.image != blank %}
            {{
              block.settings.image
              | image_url: width: 2000
              | image_tag:
                class: 'w-full h-full object-cover object-top hero-image-bg',
                loading: 'eager',
                fetchpriority: 'high',
                alt: block.settings.image.alt,
                preload: true
            }}
          {% else %}
            {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-full object-cover bg-gray-200 hero-image-bg' }}
          {% endif %}
        </div>

        <div class="absolute inset-0 flex items-center justify-center text-center px-4">
          <div class="max-w-3xl">
            <h1 class="hero-title text-white font-light uppercase mb-4">
              {{ block.settings.title }}
            </h1>

            <p class="hero-subtitle text-white font-light mb-8">
              {{ block.settings.sub_title }}
            </p>

            {% if block.settings.button_link != blank %}
              <div class="hero-button">
                <a
                  href="{{ block.settings.button_link }}"
                  class="inline-flex items-center gap-2 bg-secondary text-white px-8 py-3 rounded-sm font-light hover:bg-primary transition-all duration-150"
                >
                  {{ block.settings.button_label }}
                  {% render 'icon-arrow2' %}
                </a>
              </div>
            {% endif %}
          </div>
        </div>
      </div>
    {% endfor %}
  </div>

  <div
    class="
      swiper-button-next !text-primary hover:!text-white !bg-secondary hover:!bg-primary !items-center !justify-center !rounded-full
      !right-[30px] !w-[50px] !h-[50px] inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-[1000ms] ease-out
    "
  >
    <button class="js-prev-btn pointer-events-auto bg-secondary border border-line p-2 rounded-full hover:bg-primary text-white hover:!text-wrap transition-colors">
      {% render 'icon-arrow-bar-right', class: 'w-5 h-5' %}
    </button>
  </div>
  <div
    class="
      swiper-button-prev !text-primary hover:!text-white !bg-secondary hover:!bg-primary !items-center !justify-center !rounded-full
      !left-[30px] !w-[50px] !h-[50px] inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-[1000ms] ease-out
    "
  >
    <button class="js-prev-btn pointer-events-auto bg-secondary border border-line p-2 rounded-full hover:bg-primary text-white hover:!text-wrap transition-colors">
      {% render 'icon-arrow-bar-left', class: 'w-5 h-5' %}
    </button>
  </div>
  <div class="swiper-pagination mb-6"></div>
</div>

<style>
  .swiper-pagination-bullet {
    background: var(--color-secondary);
    height: 12px !important;
    width: 12px !important;
    opacity: 0.5;
    transition: all 0.3s ease;
  }
  .swiper-pagination-bullet-active {
    background: var(--color-secondary);
    opacity: 1;
    width: 30px !important;
    border-radius: 6px;
  }

  .hero-title,
  .hero-subtitle,
  .hero-button {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .is-active .hero-title {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 400ms;
  }
  .is-active .hero-subtitle {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 600ms;
  }
  .is-active .hero-button {
    opacity: 1;
    transform: translateY(0);
    transition-delay: 800ms;
  }

  .is-active img {
    animation: kenburns 8s ease-out forwards;
  }

  @keyframes kenburns {
    0% {
      transform: scale(1);
    }
    100% {
      transform: scale(1.1);
    }
  }

  .hero-overlay::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.3) 0%, transparent 50%);
    z-index: 1;
  }
</style>

<script>
  const initSwiper = () => {
    new Swiper('.myHeroSwiper', {
      loop: true,
      effect: 'fade',
      speed: 1200,
      fadeEffect: {
        crossFade: true,
      },
      autoplay: {
        delay: 6000,
        disableOnInteraction: false,
      },
      on: {
        init: function () {
          const activeSlide = this.slides[this.activeIndex];
          activeSlide.classList.add('is-active');
        },
        slideChangeTransitionStart: function () {
          this.slides.forEach((slide) => {
            slide.classList.remove('is-active');
          });
        },
        slideChangeTransitionEnd: function () {
          const activeSlide = this.slides[this.activeIndex];
          activeSlide.classList.add('is-active');
        },
      },
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
        dynamicBullets: true,
      },
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
    });
  };

  document.addEventListener('DOMContentLoaded', initSwiper);
  document.addEventListener('shopify:section:load', initSwiper);
</script>

{% schema %}
{
  "name": "Hero Slider",
  "settings": [
    {
      "type": "paragraph",
      "content": "ℹ️ **Tip:** For optimal display, use images with a **1920x1080px** resolution. Slide transitions are automatically optimized for performance."
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Slide",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image",
          "info": "The center of the image should be the main focus of the slide."
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "New Season"
        },
        {
          "type": "text",
          "id": "sub_title",
          "label": "Subheading",
          "default": "Discover the latest collection now."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Shop Now",
          "info": "Leave blank to hide the button."
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Hero Slider"
    }
  ]
}
{% endschema %}
