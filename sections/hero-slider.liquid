{%- liquid
  assign slider_height = section.settings.slider_height

  # Yükseklik hesaplama mantığını sağlamlaştıralım
  if slider_height == 'full'
    assign height_style = 'height: calc(100dvh - var(--header-height, 0px)); min-height: 500px;'
  elsif slider_height == 'auto'
    assign height_style = 'height: auto; aspect-ratio: 16/9;'
  else
    assign height_style = 'height: ' | append: slider_height | append: ';'
  endif
-%}

{%- style -%}
  #Slider-{{ section.id }} {
    display: block;
    position: relative;
    background-color: #f0f0f0;
  }
  #Slider-{{ section.id }} .swiper-wrapper {
    height: 100%;
  }
  .swiper-pagination-bullet {
    background: var(--color-secondary, #000);
    height: 10px !important;
    width: 10px !important;
    opacity: 0.5;
    transition: all 0.3s ease;
  }
  .swiper-pagination-bullet-active {
    opacity: 1;
    width: 25px !important;
    border-radius: 5px;
  }
  .hero-title, .hero-subtitle, .hero-button {
    opacity: 0;
    transform: translateY(20px);
    transition: all 0.8s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .is-active .hero-title { opacity: 1; transform: translateY(0); transition-delay: 300ms; }
  .is-active .hero-subtitle { opacity: 1; transform: translateY(0); transition-delay: 500ms; }
  .is-active .hero-button { opacity: 1; transform: translateY(0); transition-delay: 700ms; }

  .is-active .hero-image-bg {
    animation: kenburns 10s ease-out forwards;
  }
  @keyframes kenburns {
    0% { transform: scale(1); }
    100% { transform: scale(1.1); }
  }
{%- endstyle -%}

<div
  id="Slider-{{ section.id }}"
  class="swiper group myHeroSwiper w-full overflow-hidden"
  style="{{ height_style }}"
>
  <div class="swiper-wrapper">
    {% for block in section.blocks %}
      <div
        class="swiper-slide relative w-full h-full overflow-hidden flex items-center justify-center"
        {{ block.shopify_attributes }}
      >
        {% if block.settings.image != blank %}
          {{
            block.settings.image
            | image_url: width: 2000
            | image_tag:
              class: 'absolute inset-0 w-full h-full object-cover object-top hero-image-bg',
              loading: 'eager',
              fetchpriority: 'high',
              alt: block.settings.image.alt
            | default: block.settings.title
          }}
        {% else %}
          {{
            'lifestyle-1'
            | placeholder_svg_tag: 'absolute inset-0 w-full h-full object-cover bg-gray-200 hero-image-bg'
          }}
        {% endif %}

        {%- comment -%} Overlay Düzeltildi {%- endcomment -%}
        <div
          class="hero_overlay absolute inset-0 pointer-events-none"
          style="background-color: {{ section.settings.overlay_color }}; opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }}; z-index: 1;"
        ></div>

        <div class="relative max-w-3xl text-center px-6 z-[2]">
          <h1 class="hero-title text-white text-4xl md:text-6xl font-light uppercase mb-4">
            {{ block.settings.title }}
          </h1>
          <p class="hero-subtitle text-white text-lg md:text-xl font-light mb-8">
            {{ block.settings.sub_title }}
          </p>
          {% if block.settings.button_link != blank %}
            <div class="hero-button">
              <a
                href="{{ block.settings.button_link }}"
                class="inline-flex items-center gap-3 bg-white text-black hover:bg-black hover:text-white px-10 py-4 transition-all duration-300 uppercase tracking-widest text-sm"
              >
                {{ block.settings.button_label }}
                {% render 'icon-arrow2' %}
              </a>
            </div>
          {% endif %}
        </div>
      </div>
    {% endfor %}
  </div>

  {% if section.settings.show_arrows and section.blocks.size > 1 %}
    <div class="swiper-button-next !text-white !right-8 hidden md:flex after:!text-2xl"></div>
    <div class="swiper-button-prev !text-white !left-8 hidden md:flex after:!text-2xl"></div>
  {% endif %}

  {% if section.settings.show_pagination and section.blocks.size > 1 %}
    <div class="swiper-pagination !bottom-10"></div>
  {% endif %}
</div>

<script>
  function initHeroSlider() {
    const swiperEl = document.querySelector('#Slider-{{ section.id }}');
    if (!swiperEl) return;

    // Eğer Swiper kütüphanesi hazır değilse bekle
    if (typeof Swiper === 'undefined') {
      setTimeout(initHeroSlider, 200);
      return;
    }

    // Varsa eski Swiper'ı temizle
    if (swiperEl.swiper) swiperEl.swiper.destroy(true, true);

    new Swiper(swiperEl, {
     loop: {% if section.blocks.size > 1 %}true{% else %}false{% endif %},
      effect: '{{ section.settings.slider_effect }}',
      speed: 1000,
      grabCursor: true,
      watchSlidesProgress: true,
      autoplay: {
        delay: 5000,
        disableOnInteraction: false,
      },
      fadeEffect: { crossFade: true },
      pagination: {
        el: '.swiper-pagination',
        clickable: true
      },
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      on: {
        init: function() {
          this.slides[this.activeIndex].classList.add('is-active');
        },
        slideChangeTransitionStart: function() {
          this.slides.forEach(slide => slide.classList.remove('is-active'));
        },
        slideChangeTransitionEnd: function() {
          this.slides[this.activeIndex].classList.add('is-active');
        }
      }
    });
  }

  document.addEventListener('DOMContentLoaded', initHeroSlider);
  document.addEventListener('shopify:section:load', initHeroSlider);
</script>
