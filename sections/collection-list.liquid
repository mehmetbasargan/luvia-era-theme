{%- style -%}
    #shopify-section-{{ section.id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }

    /* Şema Renklerini Uygula */
    .section-{{ section.id }}-padding {
      background-color: {{ section.settings.color_scheme.settings.background }};
      color: {{ section.settings.color_scheme.settings.text }};
    }

   .section-{{ section.id }}-padding :is(h1, h2, h3, h4, h5, h6) {
    color: {{ section.settings.color_scheme.settings.heading }} !important;
  }

    .section-{{ section.id }}-padding .review-link {
      color: {{ section.settings.color_scheme.settings.text }};
    }

    .section-{{ section.id }}-padding .review-link:hover {
      color: {{ section.settings.color_scheme.settings.button }}; /* Hover'da marka rengine dönsün */
    }

    .section-{{ section.id }}-padding .divider-line {
      background-color: {{ section.settings.color_scheme.settings.button }};
    }
{%- endstyle -%}

<section
  id="shopify-section-{{ section.id }}"
  class="section-{{ section.id }}-padding color-{{ section.settings.color_scheme }}"
>
  <div class="container">
    <div class="text-center mb-16">
      <h4 class="uppercase font-light tracking-[0.2em]">
        {{ section.settings.collection_list_title | default: 'Our Collections' }}
      </h4>
      <div class="h-[1px] w-20 mx-auto mt-4 divider-line"></div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-4 gap-4 md:gap-6">
      {% for block in section.blocks %}
        {%- assign collection = collections[block.settings.collection] -%}
        <div class="group relative flex flex-col items-center">
          <a
            href="{{ collection.url | default: '#' }}"
            class="w-full h-[250px] lg:h-[200px] overflow-hidden bg-white relative"
          >
            {% if collection.featured_image != blank %}
              <img
                src="{{ collection.featured_image | image_url: width: 600 }}"
                alt="{{ collection.title | escape }}"
                width="600"
                height="400"
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
              >
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full bg-[#E5E5E5]' }}
            {% endif %}
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/5 transition-colors duration-500"></div>
          </a>
          <div class="mt-6 text-center">
            <h6 class="tracking-widest uppercase mb-2">
              {{ collection.title | default: 'Collection Title' }}
            </h6>
            <a
              href="{{ collection.url }}"
              class="review-link text-[11px] md:text-[13px] uppercase tracking-widest transition-all flex items-center justify-center gap-2"
            >
              {{ 'collections.review' | t | default: 'Review' }}
              {% render 'icon-arrow-right' %}
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection List",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "text",
      "id": "collection_list_title",
      "label": "Title",
      "default": "Our Collections"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection Select"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List",
      "blocks": [{ "type": "collection" }, { "type": "collection" }, { "type": "collection" }, { "type": "collection" }]
    }
  ]
}
{% endschema %}
