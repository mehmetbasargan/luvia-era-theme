<section
  style="
    background-color: {{ section.settings.section_bg_color | default: settings.background_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="container">
    {% if section.settings.section_title != blank %}
      <div class="text-center mb-16">
        <h3 class="uppercase font-light tracking-[0.2em]" style="color: {{ section.settings.section_text_color }};">
          {{ section.settings.section_title }}
        </h3>
        <div class="h-[1px] w-20 bg-secondary mx-auto mt-4"></div>
      </div>
    {% endif %}

    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-4 gap-4 md:gap-6">
      {% for block in section.blocks %}
        {%- assign collection = collections[block.settings.collection] -%}
        <div class="group relative flex flex-col items-center">
          <a
            href="{{ collection.url | default: '#' }}"
            class="w-full h-[250px] lg:h-[200px] overflow-hidden bg-white relative"
          >
            {% if collection.featured_image != blank %}
              <img
                src="{{ collection.featured_image | image_url: width: 600 }}"
                alt="{{ collection.title | escape }}"
                width="600"
                height="400"
                loading="eager"
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
              >
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full bg-[#E5E5E5]' }}
            {% endif %}

            <div
              class="absolute inset-0 bg-[var(--color-primary)]/0 group-hover:bg-[var(--color-primary)]/10 transition-colors duration-500"
            ></div>
          </a>
          <div class="mt-6 text-center">
            <h6 class=" tracking-widest uppercase mb-2" style="color: {{ section.settings.section_text_color }};">
              {% if collection.title != blank %}
                {{ collection.title }}
              {% else %}
                {{ 'collections.select_collection_placeholder' | t }}
              {% endif %}
            </h6>
            <a
              href="{{ collection.url }}"
              class="text-[12px] md:text-[13px] border-b border-primary pb-1 uppercase tracking-widest hover:text-secondary hover:border-primary transition-all"
              style="color: {{ section.settings.section_text_color }};"
            >
              {{ 'collections.review' | t }}
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection Cards",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "section_title",
      "label": "Section Title",
      "default": "Explore Categories"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "section_text_color",
      "label": "Section Text Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection Select"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Cards",
      "blocks": [{ "type": "collection" }, { "type": "collection" }, { "type": "collection" }, { "type": "collection" }]
    }
  ]
}
{% endschema %}
