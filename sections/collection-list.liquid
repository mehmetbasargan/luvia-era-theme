{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  /* color and background settings */
  #LuviaSection-{{ section.id }} {
    {% if section.settings.remove_bg %}
      background-color: transparent !important;
      background-image: none !important;
    {% elsif section.settings.use_custom_bg %}
      background-color: {{ section.settings.section_bg_color }} !important;
      background-image: none !important;
    {% endif %}
  }
{%- endstyle -%}

<section
  id="LuviaSection-{{ section.id }}"
  class="
    transition-colors duration-300 section-{{ section.id }}-padding
    {% unless section.settings.remove_bg or section.settings.use_custom_bg %}bg-white color-{{ section.settings.color_scheme }} gradient{% endunless %}
  "
>
  <div class="container">
    {% if section.settings.collection_list_title != blank %}
      <div class="text-center mb-16">
        <h4 class="uppercase font-light tracking-[0.2em]">
          {{ section.settings.collection_list_title }}
        </h4>
        <div class="h-[1px] w-20 mx-auto mt-4 border-b border-secondary"></div>
      </div>
    {% endif %}

    {% comment %}
      Blok sayısına göre grid yapısını dinamik yapıyoruz:
      1 blok varsa tam genişlik, 2 varsa yarı yarıya, 3 veya daha fazla varsa uygun grid.
    {% endcomment %}
    <div class="grid grid-cols-1 sm:grid-cols-2 {% if section.blocks.size == 3 %}md:grid-cols-3{% else %}md:grid-cols-4{% endif %} gap-8">
      {% for block in section.blocks %}
        {%- assign collection = collections[block.settings.collection] -%}
        <div class="group relative flex flex-col items-center" {{ block.shopify_attributes }}>
          <a
            href="{{ collection.url | default: '#' }}"
            class="w-full aspect-[4/5] overflow-hidden bg-white relative block shadow-sm transition-all duration-500 border border-transparent group-hover:border-line"
          >
            {% if collection.featured_image != blank %}
              <img
                src="{{ collection.featured_image | image_url: width: 800 }}"
                alt="{{ collection.title | escape }}"
                width="800"
                height="1000"
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
              >
            {% else %}
              <div class="w-full h-full bg-custombg flex items-center justify-center border border-line">
                {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'w-1/2 h-1/2 opacity-10' }}
              </div>
            {% endif %}

            <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/5 transition-colors duration-500"></div>
          </a>

          <div class="mt-6 text-center">
            <h6 class="tracking-widest uppercase mb-2 font-light">
              {{ collection.title | default: 'Collection Title' }}
            </h6>
            <a
              href="{{ collection.url | default: '#' }}"
              class="text-primary text-[11px] uppercase tracking-[0.2em] hover:text-secondary transition-all flex items-center justify-center gap-2"
            >
              {{ 'collections.review' | t | default: 'Explore' }}
              <span class="transition-transform group-hover:translate-x-1">
                {% render 'icon-arrow-right' %}
              </span>
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection List",
  "settings": [
    {
      "id": "collection_list_title",
      "type": "text",
      "label": "Title",
      "default": "Our Collections"
    },
    {
      "type": "header",
      "content": "Section Spacing Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    },
    {
      "type": "header",
      "content": "Arka Plan Tasarımı"
    },
    {
      "type": "checkbox",
      "id": "use_custom_bg",
      "label": "Özel Arka Plan Rengi Kullan",
      "default": false
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Arka Plan Rengi",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "remove_bg",
      "label": "Arka Planı Tamamen Kaldır (Transparent)",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection Select"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List",
      "blocks": [{ "type": "collection" }, { "type": "collection" }, { "type": "collection" }]
    }
  ]
}
{% endschema %}
