{%- style -%}
  #shopify-section-{{ section.id }} {
    background-color: {{ section.settings.bg_color_new }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{%- endstyle -%}

<style>
    /* Seçilen şemaya göre renkleri otomatik dağıtır */
  .color-{{ section.settings.color_scheme }} {
    background-color: {{ section.settings.color_scheme.settings.background }};
    color: {{ section.settings.color_scheme.settings.text }};
  }

  .color-{{ section.settings.color_scheme }} h2,
  .color-{{ section.settings.color_scheme }} h3 {
    color: {{ section.settings.color_scheme.settings.heading }};
  }

  .color-{{ section.settings.color_scheme }} .button {
    background-color: {{ section.settings.color_scheme.settings.button }};
    color: {{ section.settings.color_scheme.settings.button_label }};
  }

  .color-{{ section.settings.color_scheme }} .button:hover {
    background-color: {{ section.settings.color_scheme.settings.button_hover }};
  }
</style>

<section id="shopify-section-{{ section.id }}" class="color-{{ section.settings.color_scheme }}">
  <div class="container">
    <div class="text-center mb-16">
      {%- liquid
        # Önce rengi değişkene atayalım ki yönetmesi kolay olsun dddd
        assign title_color = section.settings.title_color
        if title_color == blank or title_color == 'rgba(0,0,0,0)'
          assign title_color = 'var(--color-secondary)'
        endif
        assign line_color = section.settings.line_color
        if line_color == blank or line_color == 'rgba(0,0,0,0)'
          assign line_color = 'var(--color-secondary)'
        endif
      -%}

      <h4
        class="uppercase font-light tracking-[0.2em]"
        style="color:{{ title_color }};"
      >
        {{ section.settings.collection_list_title | default: 'Our Collections' }}
      </h4>
      <div class="h-[1px] w-20 mx-auto mt-4" style="background-color: {{ line_color }};"></div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-4 gap-4 md:gap-6">
      {% for block in section.blocks %}
        {%- assign collection = collections[block.settings.collection] -%}
        <div class="group relative flex flex-col items-center">
          <a
            href="{{ collection.url | default: '#' }}"
            class="w-full h-[250px] lg:h-[200px] overflow-hidden bg-white relative"
          >
            {% if collection.featured_image != blank %}
              <img
                src="{{ collection.featured_image | image_url: width: 600 }}"
                alt="{{ collection.title | escape }}"
                width="600"
                height="400"
                loading="eager"
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-110"
              >
            {% else %}
              {{ 'collection-1' | placeholder_svg_tag: 'w-full h-full bg-[#E5E5E5]' }}
            {% endif %}

            <div
              class="absolute inset-0 bg-[var(--color-primary)]/0 group-hover:bg-[var(--color-primary)]/10 transition-colors duration-500"
            ></div>
          </a>
          <div class="mt-6 text-center">
            <h6 class="text-primary tracking-widest uppercase mb-2">
              {% if collection.title != blank %}
                {{ collection.title }}
              {% else %}
                {{ 'collections.select_collection_placeholder' | t }}
              {% endif %}
            </h6>
            <a
              href="{{ collection.url }}"
              class="text-[11px] md:text-[13px] text-primary uppercase tracking-widest hover:text-secondary transition-all flex items-center justify-center gap-2"
            >
              {{ 'collections.review' | t }}
              {% render 'icon-arrow-right' %}
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection List",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Content Settings"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Top",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Margin Bottom",
      "default": 0
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection Select"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List",
      "blocks": [{ "type": "collection" }, { "type": "collection" }, { "type": "collection" }, { "type": "collection" }]
    }
  ]
}
{% endschema %}
