<section
  id="shopify-section-{{ section.id }}"
  class="bg-custombg transition-colors duration-300"
>
  <div class="container py-24 md:py-32">
    <div class="text-center mb-16">
      <h4 class="text-primary uppercase font-light tracking-[0.2em]">
        {{ section.settings.collection_list_title | default: 'Our Collections' }}
      </h4>
      {% comment %} Dinamik divider line {% endcomment %}
      <div class="h-[1px] w-20 mx-auto mt-4 border-b border-line"></div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {% for block in section.blocks %}
        {%- assign collection = collections[block.settings.collection] -%}
        <div class="group relative flex flex-col items-center" {{ block.shopify_attributes }}>
          <a
            href="{{ collection.url | default: '#' }}"
            class="w-full aspect-[4/5] overflow-hidden bg-white relative block shadow-sm border border-transparent group-hover:border-line transition-all duration-500"
          >
            {% if collection.featured_image != blank %}
              <img
                src="{{ collection.featured_image | image_url: width: 600 }}"
                alt="{{ collection.title | escape }}"
                width="600"
                height="800"
                loading="lazy"
                class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
              >
            {% else %}
              {% comment %} İŞTE BURASI: Sabit renk yerine bg-custombg ve border-line kullanıyoruz {% endcomment %}
              <div class="w-full h-full bg-custombg flex items-center justify-center border border-line">
                {{ 'collection-1' | placeholder_svg_tag: 'w-1/2 h-1/2 opacity-10' }}
              </div>
            {% endif %}

            <div class="absolute inset-0 bg-primary/0 group-hover:bg-primary/5 transition-colors duration-500"></div>
          </a>

          <div class="mt-6 text-center">
            <h6 class="text-primary tracking-widest uppercase mb-2 font-light">
              {{ collection.title | default: 'Collection Title' }}
            </h6>
            <a
              href="{{ collection.url | default: '#' }}"
              class="text-primary text-[11px] uppercase tracking-[0.2em] hover:text-secondary transition-all flex items-center justify-center gap-2"
            >
              {{ 'collections.review' | t | default: 'Explore' }}
              <span class="transition-transform group-hover:translate-x-1">
                {% render 'icon-arrow-right' %}
              </span>
            </a>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Collection List",
  "max_blocks": 4,
  "settings": [
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "id": "collection_list_title",
      "type": "text",
      "label": "Title",
      "default": "Our Collections"
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection Select"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection List",
      "blocks": [{ "type": "collection" }, { "type": "collection" }, { "type": "collection" }, { "type": "collection" }]
    }
  ]
}
{% endschema %}
