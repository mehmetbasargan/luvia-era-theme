<div class="address-section py-[{{ section.settings.padding_y }}px]">
  <div class="container mx-auto px-6">
    <div class="text-center mb-16">
      <h1 class="text-3xl font-light uppercase tracking-[0.3em] text-primary">{{ 'customer.addresses.title' | t }}</h1>
      <button
        type="button"
        class="mt-6 text-[11px] uppercase tracking-[0.2em] border-b border-primary pb-1 font-bold hover:text-secondary hover:border-secondary transition-all"
        onclick="toggleNewAddress()"
      >
        {{ 'customer.addresses.add_new' | t }}
      </button>
    </div>

    {% comment %} Yeni Adres Formu (Başlangıçta Gizli) {% endcomment %}
    <div id="AddAddress" class="hidden max-w-xl mx-auto mb-20 p-8 border border-gray-100 bg-gray-50 transition-all">
      {% form 'customer_address', customer.new_address %}
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <input
            type="text"
            name="address[first_name]"
            placeholder="Ad"
            class="border-b bg-transparent py-2 outline-none focus:border-primary text-sm font-light"
          >
          <input
            type="text"
            name="address[last_name]"
            placeholder="Soyad"
            class="border-b bg-transparent py-2 outline-none focus:border-primary text-sm font-light"
          >
        </div>
        <input
          type="text"
          name="address[address1]"
          placeholder="Adres"
          class="w-full border-b bg-transparent py-2 outline-none focus:border-primary text-sm font-light mt-6"
        >
        <input
          type="text"
          name="address[city]"
          placeholder="Şehir"
          class="w-full border-b bg-transparent py-2 outline-none focus:border-primary text-sm font-light mt-6"
        >

        <div class="mt-8 flex gap-4">
          <button
            type="submit"
            class="bg-primary text-white px-8 py-3 text-[10px] uppercase tracking-widest hover:bg-secondary"
          >
            {{ 'customer.addresses.add' | t }}
          </button>
          <button
            type="button"
            class="text-[10px] uppercase tracking-widest text-gray-400"
            onclick="toggleNewAddress()"
          >
            İptal
          </button>
        </div>
      {% endform %}
    </div>

    {% comment %} Adres Listesi {% endcomment %}
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {% for address in customer.addresses %}
        <div class="p-6 border border-gray-100 relative group transition-all hover:shadow-md">
          {% if address == customer.default_address %}
            <span class="absolute top-4 right-4 text-[8px] uppercase tracking-widest bg-secondary text-white px-2 py-0.5"
              >Varsayılan</span
            >
          {% endif %}

          <div class="text-xs leading-relaxed font-light text-gray-600">
            <p class="font-bold text-primary mb-2 uppercase">
              {{ address.first_name }}
              {{ address.last_name }}
            </p>
            {{ address | format_address }}
          </div>

          <div class="mt-6 pt-4 border-t border-gray-50 flex gap-4">
            <button class="text-[10px] uppercase tracking-widest text-gray-400 hover:text-primary">Düzenle</button>
            <form method="post" action="/account/addresses/{{ address.id }}">
              <input type="hidden" name="_method" value="delete">
              <button class="text-[10px] uppercase tracking-widest text-red-300 hover:text-red-500">Sil</button>
            </form>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  function toggleNewAddress() {
    const el = document.getElementById('AddAddress');
    el.classList.toggle('hidden');
    el.scrollIntoView({ behavior: 'smooth' });
  }
</script>

{% schema %}
{
  "name": "Adres Yönetimi",
  "settings": [
    {
      "type": "range",
      "id": "padding_y",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Dikey Boşluk",
      "default": 60
    }
  ]
}
{% endschema %}
