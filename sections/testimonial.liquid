<div class="container py-[300px]">
  <!-- Swiper -->
  <div class="swiper myTestimonialSwiper">
    <div class="swiper-wrapper">
      {% for item in section.blocks %}
        <div class="swiper-slide flex flex-col items-center text-center w-full bg-custombg p-8 rounded-lg min-h-[250px]">
          <span class="bg-red-500">{% render 'icon-quote' %}</span>
          {{ item.settings.testimonial }}
          <span class="mt-8">- {{ item.settings.name }}</span>
        </div>
      {% endfor %}
    </div>
    <div class="swiper-pagination"></div>
  </div>
</div>

<script>
  const initTestimonialSwiper = () => {
    // Mevcut bir swiper örneği varsa önce onu yok et (Shopify Editör çakışmalarını önler)
    const existingSwiper = document.querySelector('.myTestimonialSwiper')?.swiper;
    if (existingSwiper) existingSwiper.destroy(true, true);

    new Swiper('.myTestimonialSwiper', {
      slidesPerView: {{ section.settings.slides_per_view }},
      spaceBetween: 30,
      freeMode: true,
      loop:true,
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
    });
  };

  // Sayfa yüklenince ve Shopify Editör her güncellendiğinde çalıştır
  document.addEventListener('DOMContentLoaded', initTestimonialSwiper);
  document.addEventListener('shopify:section:load', initTestimonialSwiper);
</script>

{% schema %}
{
  "name": "Testimonial",
  "settings": [
    {
      "type": "number",
      "id": "slides_per_view",
      "label": "Slides per view",
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "testimonial",
          "label": "Testimonial"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial"
    }
  ]
}
{% endschema %}
