<div class="container py-[100px]">
  {% if section.settings.testimonial_title %}
    <div class="container mb-10 flex justify-center items-end w-full">
      <div>
        <h2 class="font-light uppercase tracking-widest">{{ section.settings.testimonial_title }}</h2>
        <div class="h-[1px] w-20 bg-secondary mx-auto mt-4"></div>
      </div>
    </div>
  {% endif %}

  <!-- Swiper -->
  <div class="swiper myTestimonialSwiper">
    <div class="swiper-wrapper">
      {% for item in section.blocks %}
        <div
          class="swiper-slide flex flex-col items-center text-center w-full bg-custombg p-4 rounded-lg "
          itemscope
          itemtype="https://schema.org/Review"
        >
          <span class="w-[25px] mb-5 text-secondary">{% render 'icon-quote' %}</span>
          <div class="h-[90px] text-[14px]" itemprop="reviewBody">
            {{ item.settings.testimonial | strip_html | truncate: 150, '...' }}
          </div>
          <span class="mt-8 italic text-[13px]" itemprop="author">- {{ item.settings.name }}</span>
          <meta itemprop="datePublished" content="{{ 'now' | date: '%Y-%m-%d' }}">
        </div>
      {% endfor %}
    </div>
    <div class="swiper-pagination" role="tablist" aria-label="Testimonial slide navigation"></div>
  </div>
</div>

<!-- JSON-LD Structured Data for SEO -->
<script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "AggregateRating",
    "itemReviewed": {
      "@type": "Thing",
      "name": "{{ section.settings.testimonial_title | default: 'Testimonials' }}"
    },
    "reviewCount": {{ section.blocks.size }},
    "ratingValue": "5.0",
    "bestRating": "5.0",
    "worstRating": "1.0"
  }
</script>

<style>
  .myTestimonialSwiper .swiper-pagination {
    position: initial;
    text-align: center;
    transform: translateZ(0);
    transition: opacity 0.3s;
    z-index: 10;
  }

  .myTestimonialSwiper .swiper-horizontal > .swiper-pagination-bullets,
  .myTestimonialSwiper .swiper-pagination-bullets.swiper-pagination-horizontal,
  .myTestimonialSwiper .swiper-pagination-custom,
  .myTestimonialSwiper .swiper-pagination-fraction {
    margin-top: 20px;
  }
</style>

<script>
  const initTestimonialSwiper = () => {
    // Mevcut bir swiper örneği varsa önce onu yok et (Shopify Editör çakışmalarını önler)
    const existingSwiper = document.querySelector('.myTestimonialSwiper')?.swiper;
    if (existingSwiper) existingSwiper.destroy(true, true);

    new Swiper('.myTestimonialSwiper', {
      spaceBetween: 30,
      freeMode: true,
      loop:true,
      autoplay: {
        delay: 3000,
        disableOnInteraction: false,
      },
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
      },
       breakpoints: {
        640: {
          slidesPerView: 2,
        },
        768: {
          slidesPerView: 2,
        },
        1024: {
          slidesPerView: {{ section.settings.slides_per_view }},
        },
      },
    });
  };

  // Sayfa yüklenince ve Shopify Editör her güncellendiğinde çalıştır
  document.addEventListener('DOMContentLoaded', initTestimonialSwiper);
  document.addEventListener('shopify:section:load', initTestimonialSwiper);
</script>

{% schema %}
{
  "name": "Testimonial",
  "settings": [
    {
      "type": "number",
      "id": "slides_per_view",
      "label": "Slides per view",
      "default": 3
    },
    {
      "type": "text",
      "id": "testimonial_title",
      "label": "Testimonial Title",
      "default": "Testimonials"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "testimonial",
          "label": "Testimonial",
          "info": "Recommended: Max 150 characters for the best layout.",
          "placeholder": "Write the customer feedback here..."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial"
    }
  ]
}
{% endschema %}
