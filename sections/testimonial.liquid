{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  #LuviaSection-{{ section.id }} {
    {% if section.settings.remove_bg %}
      background-color: transparent !important;
    {% elsif section.settings.use_custom_bg %}
      background-color: {{ section.settings.section_bg_color }} !important;
    {% endif %}
  }

  /* Slider Görünürlük Ayarları */
  .swiper-{{ section.id }} {
    width: 100%;
    height: auto;
    overflow: hidden;
  }

  .swiper-{{ section.id }} .swiper-pagination {
    position: relative;
    margin-top: 20px;
    text-align: center;
  }
{%- endstyle -%}

<section id="LuviaSection-{{ section.id }}" class="section-{{ section.id }}-padding transition-colors duration-300">
  <div class="container py-[100px]">
    {% if section.settings.testimonial_title %}
      <div class="mb-10 flex justify-center items-end w-full">
        <div class="text-center">
          <h2>{{ section.settings.testimonial_title }}</h2>
          <div class="h-[1px] w-20 bg-secondary mx-auto mt-4"></div>
        </div>
      </div>
    {% endif %}

    <div class="swiper swiper-{{ section.id }}">
      <div class="swiper-wrapper">
        {% for item in section.blocks %}
          <div
            class="swiper-slide flex flex-col items-center justify-center text-center bg-custombg p-6 rounded-lg"
            itemscope
            itemtype="https://schema.org/Review"
          >
            <div class="w-full h-[70px] flex items-center justify-center mb-4">
              <span class="text-secondary" aria-hidden="true">{% render 'icon-quote' %}</span>
            </div>
            <div class="min-h-[90px] text-[14px]" itemprop="reviewBody">
              {{ item.settings.testimonial | strip_html | truncate: 150 }}
            </div>
            <span class="mt-8 italic text-[13px]" itemprop="author">- {{ item.settings.name }}</span>
            <meta itemprop="datePublished" content="{{ 'now' | date: '%Y-%m-%d' }}">
          </div>
        {% endfor %}
      </div>
      <div
        class="swiper-pagination pagination-{{ section.id }}"
        role="tablist"
        aria-label="Testimonial navigation"
      ></div>
    </div>
  </div>
</section>

<script>
  // IIFE (Sarmalayıcı) kullanarak global değişken çakışmalarını %100 engelliyoruz
  (function() {
    function initSlider() {
      const container = document.querySelector('.swiper-{{ section.id }}');
      if (!container) return;

      // Eğer zaten başlatılmışsa yok et (Shopify Editor için)
      if (container.swiper) container.swiper.destroy(true, true);

      const blockCount = {{ section.blocks.size }};
      const desktopView = {{ section.settings.slides_per_view | default: 3 }};

      new Swiper('.swiper-{{ section.id }}', {
        spaceBetween: 30,
        grabCursor: true,
        // Lighthouse Hatası Fix: Sadece yeterli slide varsa loop aç
        loop: blockCount > desktopView,
        pagination: {
          el: '.pagination-{{ section.id }}',
          clickable: true,
        },
        breakpoints: {
          320: { slidesPerView: 1, loop: blockCount > 1 },
          640: { slidesPerView: 2, loop: blockCount > 2 },
          1024: { slidesPerView: desktopView, loop: blockCount > desktopView }
        }
      });
    }

    // İlk yükleme
    document.addEventListener('DOMContentLoaded', initSlider);
    // Shopify Tema Editörü etkileşimi
    document.addEventListener('shopify:section:load', initSlider);
    // Mobil/Resize kontrolü için yedek
    window.addEventListener('resize', function() {
        if(!document.querySelector('.swiper-{{ section.id }}')?.swiper) initSlider();
    });
  })();
</script>

{% schema %}
{
  "name": "Testimonial",
  "settings": [
    {
      "type": "number",
      "id": "slides_per_view",
      "label": "Slides per view",
      "default": 3
    },
    {
      "type": "text",
      "id": "testimonial_title",
      "label": "Testimonial Title",
      "default": "Testimonials"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    },
    {
      "type": "checkbox",
      "id": "use_custom_bg",
      "label": "Use Custom Background Color",
      "default": false
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "remove_bg",
      "label": "Remove Background (Transparent)",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "testimonial",
          "label": "Testimonial",
          "default": "This is a great product!"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "John Doe"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial"
    }
  ]
}
{% endschema %}
