<div class="container py-[300px]">
  <!-- Swiper -->
  <div class="swiper myTestimonialSwiper">
    <div class="swiper-wrapper">
      {% for item in section.blocks %}
        <div class="swiper-slide">
          {{ item.settings.testimonial }}
        </div>
      {% endfor %}
    </div>
    <div class="swiper-pagination"></div>
  </div>
</div>

<script>
  const initTestimonialSwiper = () => {
    // Mevcut bir swiper örneği varsa önce onu yok et (Shopify Editör çakışmalarını önler)
    const existingSwiper = document.querySelector('.myTestimonialSwiper')?.swiper;
    if (existingSwiper) existingSwiper.destroy(true, true);

    new Swiper('.myTestimonialSwiper', {
      loop: true,
      effect: 'fade',
      slidesPerView: 1, // Fade efekti için mutlaka 1 olmalı
      speed: 1200,
      allowTouchMove: true,
      fadeEffect: {
        crossFade: true, // Slaytların birbirinin içinden geçmesi için
      },
      autoplay: {
        delay: 6000,
        disableOnInteraction: false,
      },
      pagination: {
        el: '.swiper-pagination',
        clickable: true,
        dynamicBullets: true,
      },
      navigation: {
        nextEl: '.swiper-button-next',
        prevEl: '.swiper-button-prev',
      },
      on: {
        init: function () {
          // İlk slaytı aktif et
          this.slides[this.activeIndex].classList.add('is-active');
        },
        slideChange: function () {
          // Tüm slaytlardan sınıfı kaldır ve yeni aktif olana ekle
          this.slides.forEach((slide) => slide.classList.remove('is-active'));
          this.slides[this.activeIndex].classList.add('is-active');
        },
      },
    });
  };

  // Sayfa yüklenince ve Shopify Editör her güncellendiğinde çalıştır
  document.addEventListener('DOMContentLoaded', initTestimonialSwiper);
  document.addEventListener('shopify:section:load', initTestimonialSwiper);
</script>

{% schema %}
{
  "name": "Testimonial",
  "settings": [
    {
      "type": "number",
      "id": "slides_per_view",
      "label": "Slides per view",
      "default": 3
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "testimonial",
          "label": "Testimonial"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial"
    }
  ]
}
{% endschema %}
