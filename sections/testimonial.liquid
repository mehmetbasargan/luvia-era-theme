{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  #LuviaSection-{{ section.id }} {
    {% if section.settings.remove_bg %}
      background-color: transparent !important;
    {% elsif section.settings.use_custom_bg %}
      background-color: {{ section.settings.section_bg_color }} !important;
    {% endif %}
  }

  .swiper-{{ section.id }} {
    width: 100%;
    height: auto;
    overflow: hidden;
    padding-bottom: 60px !important;
  }

  .pagination-{{ section.id }} .swiper-pagination-bullet-active {
    background: #000 !important; /* Tailwind değişkenin yoksa şimdilik siyah */
    width: 20px;
    border-radius: 4px;
    transition: all 0.3s;
  }
{%- endstyle -%}

<section id="LuviaSection-{{ section.id }}" class="section-{{ section.id }}-padding transition-colors duration-300">
  <div class="container mx-auto px-4">
    {% comment %} Başlık Kontrolü {% endcomment %}
    <div class="mb-16 flex justify-center items-end w-full">
      <div class="text-center">
        <h2 class="text-2xl md:text-3xl font-light uppercase tracking-widest">
          {{ section.settings.testimonial_title | default: 'Client Experiences' }}
        </h2>
        <div class="h-[1px] w-20 bg-secondary mx-auto mt-6"></div>
      </div>
    </div>

    <div class="swiper swiper-{{ section.id }}">
      <div class="swiper-wrapper">
        {%- assign valid_blocks_count = 0 -%}

        {%- for item in section.blocks -%}
          {%- if item.settings.testimonial != blank or item.settings.name != blank -%}
            {%- assign valid_blocks_count = valid_blocks_count | plus: 1 -%}
            <div
              class="swiper-slide flex flex-col items-center justify-center text-center bg-gray-50 p-8 md:p-12 rounded-sm border border-gray-100 h-auto"
              {{ item.shopify_attributes }}
              itemscope
              itemtype="https://schema.org/Review"
            >
              <div class="w-full h-[40px] flex items-center justify-center mb-6">
                <span class="text-secondary opacity-40 scale-150" aria-hidden="true">{% render 'icon-quote' %}</span>
              </div>

              <div class="min-h-[100px] text-[15px] leading-relaxed italic text-primary" itemprop="reviewBody">
                "
                {{-
                  item.settings.testimonial
                  | default: 'The quality and design exceeded my expectations. A truly timeless piece.'
                -}}
                "
              </div>

              <span class="mt-8 font-medium uppercase tracking-widest text-[12px]" itemprop="author">
                — {{ item.settings.name | default: 'Valued Customer' }}
              </span>
              <meta itemprop="datePublished" content="{{ 'now' | date: '%Y-%m-%d' }}">
            </div>
          {%- endif -%}
        {%- endfor -%}

        {%- if valid_blocks_count == 0 -%}
          {%- for i in (1..3) -%}
            <div class="swiper-slide bg-gray-50 p-12 text-center opacity-50">
              <div class="min-h-[100px] italic">No testimonials yet. Add one in the theme editor!</div>
              <span class="mt-8 block">— Example Name</span>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <div class="swiper-pagination pagination-{{ section.id }}"></div>
    </div>
  </div>
</section>

<script>
  (function() {
    const initSlider = () => {
      const container = document.querySelector('.swiper-{{ section.id }}');
      if (!container) return;

      if (container.swiper) container.swiper.destroy(true, true);

      // Gerçekten dolu olan slide sayısını bul
      const realSlidesCount = container.querySelectorAll('.swiper-slide').length;
      const desktopView = {{ section.settings.slides_per_view | default: 3 }};

      new Swiper('.swiper-{{ section.id }}', {
        slidesPerView: 1.2,
        spaceBetween: 20,
        grabCursor: true,
        centeredSlides: realSlidesCount < 2,
        loop: realSlidesCount > desktopView,
        pagination: {
          el: '.pagination-{{ section.id }}',
          clickable: true,
        },
        breakpoints: {
          640: { slidesPerView: 2, spaceBetween: 30 },
          1024: { slidesPerView: desktopView, spaceBetween: 40 }
        }
      });
    }

    document.addEventListener('DOMContentLoaded', initSlider);
    document.addEventListener('shopify:section:load', initSlider);
  })();
</script>

{% schema %}
{
  "name": "Testimonial",
  "settings": [
    {
      "type": "range",
      "id": "slides_per_view",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Slides per view (Desktop)",
      "default": 3
    },
    {
      "type": "text",
      "id": "testimonial_title",
      "label": "Testimonial Title",
      "default": "Client Experiences"
    },
    { "type": "header", "content": "Style Settings" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    { "type": "checkbox", "id": "use_custom_bg", "label": "Use Custom Background Color", "default": false },
    { "type": "color", "id": "section_bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "checkbox", "id": "remove_bg", "label": "Remove Background", "default": false }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "testimonial",
          "label": "Testimonial",
          "default": "The quality and design exceeded my expectations. A truly timeless piece that I will cherish forever."
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "John Doe"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonial",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
