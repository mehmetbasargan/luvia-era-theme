{% paginate blog.articles by 10 %}
  <div class="main-blog-section py-12 px-4 container">
    <header class="text-center mb-16">
      <span class="uppercase text-xl font-bold tracking-wider">
        {{- section.settings.blog_title | default: blog.title -}}
      </span>
      <p class="text-primary mt-2">
        {{ section.settings.blog_subtitle }}
      </p>
    </header>

    <div class="flex justify-center gap-4 mb-10 overflow-x-auto pb-4">
      <a
        href="{{ blog.url }}"
        class="px-4 py-2 rounded-md border border-primary hover:bg-secondary hover:text-white transition {% if current_tags == blank %}bg-primary text-white{% endif %}"
      >
        {{ 'blog.all_posts' | t }}
      </a>
      {% for tag in blog.all_tags %}
        <a
          href="{{ blog.url }}/tagged/{{ tag | handle }}"
          class="px-4 py-2 rounded-md border border-primary hover:bg-primary hover:text-white transition {% if current_tags contains tag %}bg-primary text-white{% endif %}"
        >
          {{ tag }}
        </a>
      {% endfor %}
    </div>

    {% if blog.articles.size > 0 %}
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {% for article in blog.articles %}
          <article class="blog-post-card group">
            {% comment %} GÖRSEL ALANI: Görsel varsa onu, yoksa yer tutucuyu basar {% endcomment %}
            <a
              href="{{ article.url }}"
              class="block overflow-hidden mb-4 aspect-[16/10] bg-custombg border border-line/10"
              aria-label="Read {{ article.title | escape }}"
            >
              {% if article.image %}
                <img
                  src="{{ article.image | image_url: width: 800 }}"
                  alt="{{ article.title | escape }}"
                  height="450"
                  width="800"
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                  loading="lazy"
                >
              {% else %}
                {% comment %} Görsel eklenmediğinde görünecek yer tutucu {% endcomment %}
                <div class="w-full h-full bg-gray-100 flex items-center justify-center opacity-40 group-hover:scale-105 transition-transform duration-700">
                  {{ 'lifestyle-1' | placeholder_svg_tag: 'w-20 h-20' }}
                </div>
              {% endif %}
            </a>

            <div class="content space-y-3 flex flex-col">
              <span class="text-sm text-primary -tracking-tight uppercase">
                {{- article.published_at | date: '%B %d, %Y' -}}
              </span>
              <span class="hover:text-primary transition-colors max-w-[300px] min-h-[1rem] leading-[24px] font-bold uppercase">
                <a href="{{ article.url }}" aria-label="Read article: {{ article.title | escape }}">
                  {{- article.title -}}
                </a>
              </span>
              <p class="text-primary line-clamp-3">{{ article.excerpt_or_content | strip_html | truncate: 150 }}</p>
              <a
                href="{{ article.url }}"
                class="inline-block pt-2 font-medium text-sm hover:underline text-primary transition-all"
                aria-label="Continue reading: {{ article.title | escape }}"
              >
                <div class="flex items-center gap-3">
                  {{ 'blog.read_more' | t }}
                  {% render 'icon-arrow-right' %}
                </div>
              </a>
            </div>
          </article>
        {% endfor %}
      </div>

      {% if paginate.pages > 1 %}
        <nav class="mt-16 flex justify-center items-center space-x-6 border-t border-gray-100 pt-10" role="navigation">
          {% if paginate.previous %}
            <a
              href="{{ paginate.previous.url }}"
              class="flex items-center font-medium text-sm text-primary hover:text-secondary transition-colors uppercase tracking-widest"
            >
              <span class="mr-2">←</span> {{ section.settings.pagination_prev }}
            </a>
          {% endif %}

          <div class="flex items-center space-x-4">
            {% for part in paginate.parts %}
              {% if part.is_link %}
                <a
                  href="{{ part.url }}"
                  class="text-sm font-medium text-primary hover:text-secondary transition-colors border-b-2 border-transparent pb-1"
                >
                  {{ part.title }}
                </a>
              {% else %}
                {% if part.title == paginate.current_page %}
                  <span class="text-md font-bold text-primary border-b-2 border-primary pb-1">
                    {{ part.title }}
                  </span>
                {% else %}
                  <span class="text-gray-300 ">
                    {{ part.title }}
                  </span>
                {% endif %}
              {% endif %}
            {% endfor %}
          </div>

          {% if paginate.next %}
            <a
              href="{{ paginate.next.url }}"
              class="flex items-center font-medium text-sm text-primary hover:text-secondary transition-colors uppercase tracking-widest"
            >
              {{ section.settings.pagination_next }}
              <span class="ml-2">→</span>
            </a>
          {% endif %}
        </nav>
      {% endif %}

    {% else %}
      <div class="text-center py-20 bg-gray-50 rounded-lg">
        <p class="text-xl text-primary italic">No posts found in "{{ blog.title }}"</p>
        <a
          href="/admin/articles/new"
          class="mt-4 inline-block bg-primary text-white px-6 py-2 rounded"
          aria-label="Create new blog post"
        >
          Create a Post
        </a>
      </div>
    {% endif %}
  </div>
{% endpaginate %}

{% schema %}
{
  "name": "Main Blog Page",
  "settings": [
    {
      "type": "header",
      "content": "Blog Header Settings"
    },
    {
      "type": "text",
      "id": "blog_title",
      "label": "Blog Page Title",
      "info": "Leave empty to use the default blog name.",
      "default": "Latest Stories"
    },
    {
      "type": "textarea",
      "id": "blog_subtitle",
      "label": "Blog Subtitle",
      "default": "Explore our latest stories and updates."
    },
    {
      "type": "header",
      "content": "Pagination Settings"
    },
    {
      "type": "text",
      "id": "pagination_prev",
      "label": "Previous Button Label",
      "default": "Previous"
    },
    {
      "type": "text",
      "id": "pagination_next",
      "label": "Next Button Label",
      "default": "Next"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "range",
      "id": "header_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Header Opacity Rate",
      "default": 100,
      "info": "Adjust the transparency level of the header section."
    }
  ],
  "presets": [
    {
      "name": "Main Blog Page"
    }
  ]
}
{% endschema %}
