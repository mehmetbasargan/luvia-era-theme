<section class="login-section py-24 min-h-[70vh] flex items-center justify-center">
  <div class="container max-w-[420px] px-6">
    <div class="header-group text-center mb-10">
      <h1 class="text-3xl font-light uppercase tracking-[0.3em] text-primary">Oturum Aç</h1>
      <div class="w-10 h-[1px] bg-secondary mx-auto mt-4"></div>
    </div>

    {%- form 'customer_login' -%}
      {%- if form.errors -%}
        <div class="bg-red-50 text-red-600 p-4 mb-6 text-[11px] uppercase tracking-widest leading-relaxed border-l-2 border-red-600">
          {{ form.errors | default_errors }}
        </div>
      {%- endif -%}

      <div class="input-group flex flex-col gap-8">
        {% comment %} Email {% endcomment %}
        <div class="field relative">
          <input
            type="email"
            name="customer[email]"
            id="CustomerEmail"
            class="w-full border-b border-gray-200 py-2 outline-none focus:border-primary transition-all bg-transparent font-light text-sm placeholder:text-gray-300"
            placeholder="E-posta"
            required
          >
        </div>

        {% comment %} Password {% endcomment %}
        <div class="field relative">
          <input
            type="password"
            name="customer[password]"
            id="CustomerPassword"
            class="w-full border-b border-gray-200 py-2 outline-none focus:border-primary transition-all bg-transparent font-light text-sm placeholder:text-gray-300"
            placeholder="Şifre"
            required
          >
          <a
            href="#recover"
            class="absolute right-0 bottom-2 text-[9px] uppercase tracking-widest text-gray-400 hover:text-secondary"
            >Şifremi Unuttum</a
          >
        </div>

        {% comment %} Buttons {% endcomment %}
        <div class="actions mt-6 flex flex-col gap-6">
          <button
            type="submit"
            class="w-full bg-primary text-white py-4 text-[11px] uppercase tracking-[0.3em] font-medium hover:bg-secondary transition-all duration-500"
          >
            Giriş Yap
          </button>

          <div class="text-center pt-4">
            <p class="text-[10px] uppercase tracking-[0.2em] text-gray-400 mb-2">Henüz hesabınız yok mu?</p>
            <a
              href="{{ routes.account_register_url }}"
              class="text-[11px] uppercase tracking-[0.3em] font-semibold text-primary border-b border-primary/20 hover:border-primary transition-all"
            >
              Kayıt Olun
            </a>
          </div>
        </div>
      </div>
    {%- endform -%}
  </div>
</section>

{% schema %}
{
  "name": "Main Login",
  "settings": [],
  "presets": [
    {
      "name": "Main Login"
    }
  ]
}
{% endschema %}
