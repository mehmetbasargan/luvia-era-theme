<section class="relative w-full h-[450px] md:h-[550px] overflow-hidden flex items-center justify-center">
  {% comment %} Background Image {% endcomment %}
  <div class="absolute inset-0 z-0">
    {% if section.settings.bg_image != blank %}
      <img
        src="{{ section.settings.bg_image | image_url: width: 1200 }}"
        alt="Newsletter Background"
        class="w-full h-full object-cover"
        loading="lazy"
        width="1200"
        height="600"
      >
    {% else %}
      <div class="w-full h-full bg-primary/20"></div>
    {% endif %}

    {% comment %} Dynamic Overlay {% endcomment %}
    <div
      class="absolute inset-0 z-[1]"
      style="background-color: rgba(0,0,0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});"
    ></div>
  </div>

  {% comment %} Content Area {% endcomment %}
  <div class="relative z-10 container mx-auto px-6 text-center text-white">
    <div class="max-w-2xl mx-auto space-y-8">
      <div class="space-y-4">
        <h2 class="text-white">
          {{ section.settings.title | default: 'Join the World of Luvia' }}
        </h2>
        <p class="text-white tracking-wide">
          {{ section.settings.subtext | default: 'Subscribe to receive updates, access to exclusive deals, and more.' }}
        </p>
      </div>

      {% comment %} Newsletter Form {% endcomment %}
      {% form 'customer', class: 'mt-10' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="flex flex-col md:flex-row items-center gap-4 max-w-xl mx-auto">
          <label class="sr-only" for="NewsletterEmail--{{ section.id }}">E-posta</label>
          <input
            id="NewsletterEmail--{{ section.id }}"
            type="email"
            name="contact[email]"
            class="w-full bg-transparent border-b border-white text-white placeholder:text-white py-3 px-2 focus:outline-none focus:border-white transition-colors font-light"
            placeholder="Your email address"
            required
          >
          <button
            type="submit"
            class="w-full md:w-auto px-10 py-3 bg-white text-primary text-[13px] uppercase tracking-[0.2em] hover:bg-secondary hover:text-white transition-all duration-500 whitespace-nowrap"
            aria-label="Subscribe to newsletter"
          >
            Subscribe
          </button>
        </div>

        {% if form.posted_successfully? %}
          <p class="mt-4 text-secondary font-medium uppercase tracking-widest text-sm">Thanks for subscribing!</p>
        {% endif %}
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 10,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 40
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Luvia Privileges"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Be the first to know about new collections and exclusive events."
    }
  ],
  "presets": [
    {
      "name": "Newsletter Banner"
    }
  ]
}
{% endschema %}
