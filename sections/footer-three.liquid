<footer class="bg-custombg text-primary border-t border-line">
  <div class="container">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 border-b border-line pt-10 pb-10">
      <div class="w-1/2">
        <h5 class="font-bold mb-3 text-secondary">
          {{ section.settings.menu_2_title }}
        </h5>
        <ul class="space-y-4 text-sm text-primary flex flex-col">
          {% for link in linklists[section.settings.footer_menu_2].links %}
            <li>
              <a href="{{ link.url }}" class="hover:text-secondary transition-colors duration-300">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="w-1/2">
        <h5 class="font-bold mb-3 text-secondary">
          {{ section.settings.menu_1_title }}
        </h5>
        <ul class="text-sm text-primary flex flex-col gap-3">
          {% for link in linklists[section.settings.footer_menu_1].links %}
            <li>
              <a href="{{ link.url }}" class="hover:text-secondary transition-colors duration-300">
                {{ link.title }}
              </a>
            </li>
          {% endfor %}
        </ul>
      </div>

      <div class="w-full lg:w-100%">
        <h5 class="font-bold mb-6 text-secondary">
          {{ section.settings.gallery_title }}
        </h5>
        <div class="grid grid-cols-4 md:grid-cols-4 lg:grid-cols-4 gap-2">
          {% for block in section.blocks %}
            {% if block.type == 'gallery_image' %}
              <div class="aspect-square overflow-hidden bg-custombg group">
                {% if block.settings.image != blank %}
                  {{
                    block.settings.image
                    | image_url: width: 400
                    | image_tag:
                      class: 'w-full h-full object-cover object-top transition-transform duration-500 group-hover:scale-110'
                  }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag: 'w-full h-full bg-custombg' }}
                {% endif %}
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>

    <div class="md:w-[60%] mx-auto text-center py-9">
      <h5 class="font-bold mb-1 text-secondary">
        {{ 'footer.newsletter' | t }}
      </h5>
      <p class="text-sm text-primary mb-4 font-medium ">
        {{ 'footer.be_first_to_know' | t }}
      </p>

      {% form 'customer', class: 'flex border-b border-secondary pb-2' %}
        <input type="hidden" name="contact[tags]" value="newsletter">

        <input
          type="email"
          name="contact[email]"
          id="NewsletterForm--{{ section.id }}"
          value="{{ form.email }}"
          placeholder="{{ 'footer.email_address' | t }}"
          class="bg-transparent border-none text-sm w-full focus:outline-none placeholder:text-primary text-primary"
          aria-required="true"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          required
        >

        <button type="submit" class="text-secondary uppercase text-sm tracking-widest font-bold ml-2">
          {{ 'footer.join' | t }}
        </button>

        {%- if form.posted_successfully? -%}
          <div class="absolute mt-10 w-full text-center">
            <p class="text-[13px] text-green-600 font-bold italic">
              {{ 'newsletter.success' | t | default: 'Success! You are on the list.' }}
            </p>
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <div class="absolute mt-10 w-full text-center">
            <p class="text-[13px] text-red-600 font-bold italic">
              {{ form.errors.messages.email }}
            </p>
          </div>
        {%- endif -%}
      {% endform %}
    </div>
  </div>
</footer>

<div class="bg-custombg py-4 text-center border-t border-line">
  <div class="container">
    <div class="footer__copyright text-[12px]">
      &copy;
      {{ 'now' | date: '%Y' }}
      {{ shop.name | link_to: routes.root_url }} - {{ 'footer.all_rights_reserved' | t }}
    </div>
    <div class="footer__payment">
      {% if section.settings.show_payment_icons %}
        {% for type in shop.enabled_payment_types %}
          {{ type | payment_type_svg_tag }}
        {% endfor %}
      {% endif %}
    </div>
  </div>
</div>

<button
  id="back-to-top"
  class="fixed bottom-8 right-8 z-[120] bg-primary hover:bg-secondary text-white p-3 rounded-full shadow-2xl transition-all duration-500 transform translate-y-20 opacity-0 hover:scale-110 active:scale-95 cursor-pointer"
  aria-label="Go Up"
>
  {% render 'icon-arrow' %}
</button>

{% schema %}
{
  "name": "Footer Three",
  "settings": [
    {
      "type": "text",
      "id": "menu_1_title",
      "label": "1. Menu Title",
      "default": "Collections"
    },
    {
      "type": "link_list",
      "id": "footer_menu_1",
      "label": "1. Menu Selection",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "menu_2_title",
      "label": "2. Menu Title",
      "default": "Customer Care"
    },
    {
      "type": "link_list",
      "id": "footer_menu_2",
      "label": "2. Menu Selection"
    },
    {
      "type": "text",
      "id": "gallery_title",
      "label": "Gallery Title",
      "default": "Follow Us @LuviaEra"
    }
  ],
  "blocks": [
    {
      "type": "gallery_image",
      "name": "Gallery Image",
      "limit": 8,
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ]
}
{% endschema %}
