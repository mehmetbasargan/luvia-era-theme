<div class="container px-4 md:px-20 py-20 lg:py-32">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div class="space-y-8 animate-fadeIn">
      <p class="text-primary text-lg">
        {{ section.settings.since }}
      </p>
      <h2 class="text-secondary text-xl md:text-2xl">
        {{ section.settings.heading | default: 'Crafting Timeless Elegance' }}
      </h2>
      <div class="text-primary !leading-relaxed flex flex-col gap-4">
        {{
          section.settings.text
          | default: 'Luvia Era was born from a desire to blend modern minimalism with artisan craftsmanship.'
        }}
      </div>
    </div>

    <div class="relative group overflow-hidden bg-custombg">
      {% if section.settings.image %}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          height="600"
          width="1200"
          alt="{{ section.settings.heading | escape }}"
          loading="eager"
          class="w-full h-[400px] md:h-[600px] object-cover grayscale hover:grayscale-0 transition-all duration-1000"
        >
      {% else %}
        {% comment %}
          Profesyonel Placeholder: Görsel eklenmediğinde 'lifestyle-2' (yaşam tarzı)
          temalı şık bir demo görseli basar.
        {% endcomment %}
        <div class="w-full h-[400px] md:h-[600px] bg-[#F5F5F5] flex items-center justify-center border border-line/5 transition-all duration-1000 group-hover:scale-105">
          <div class="w-full h-full opacity-30 p-20">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'w-full h-full object-cover' }}
          </div>
          <div class="absolute inset-0 flex items-center justify-center">
            <span class="text-primary/40 uppercase tracking-[0.5em] text-xs font-light">
              {{ section.settings.heading | default: 'Brand Story Image' }}
            </span>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Philosophy"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Focusing on the essence of style.</p>"
    },
    {
      "type": "text",
      "id": "since",
      "label": "Since",
      "default": "2026"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Story Image"
    }
  ]
}
{% endschema %}
