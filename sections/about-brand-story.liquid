<div class="container px-4 md:px-20 py-20 lg:py-32">
  <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
    <div class="space-y-8 animate-fadeIn">
      <p class="text-primary text-lg">
        {{ section.settings.since }}
      </p>
      <h3 class="text-secondary">
        {{ section.settings.heading | default: 'Crafting Timeless Elegance' }}
      </h3>
      <div class="text-primary !leading-relaxed flex flex-col gap-4">
        {{
          section.settings.text
          | default: 'Luvia Era was born from a desire to blend modern minimalism with artisan craftsmanship.'
        }}
      </div>
    </div>

    <div class="relative group overflow-hidden bg-custombg">
      {% if section.settings.image %}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          height="600"
          width="1200"
          alt="{{ section.settings.heading }}"
          loading="eager"
          class="w-full h-[600px] object-cover grayscale hover:grayscale-0 transition-all duration-1000"
        >
      {% else %}
        <div class="w-full h-[600px] bg-[#E5E5E5] flex items-center justify-center">
          <svg
            height="600"
            width="1200"
            viewBox="0 0 1200 600"
            fill="none"
            xmlns="http://www.w3.org/2000/svg"
            class="w-full h-full"
            preserveAspectRatio="xMidYMid slice"
          >
            <rect width="1200" height="600" fill="#E5E5E5"/>
            <text x="600" y="300" text-anchor="middle" fill="#currentColor" font-size="24" font-family="sans-serif">{{ section.settings.heading }}</text>
          </svg>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "About Brand Story",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Philosophy"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Focusing on the essence of style.</p>"
    },
    {
      "type": "text",
      "id": "since",
      "label": "Since",
      "default": "2026"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Story Image"
    }
  ]
}
{% endschema %}
