{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }
{%- endstyle -%}

<div
  id="StatementBanner-{{ section.id }}"
  class="statement-banner-wrapper section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient"
>
  <section class="relative w-full min-h-[400px] md:min-h-[500px] overflow-hidden flex items-center justify-center">
    {% comment %} Background Image {% endcomment %}
    <div class="absolute inset-0 z-0">
      {% if section.settings.bg_image != blank %}
        {{
          section.settings.bg_image
          | image_url: width: 1920
          | image_tag:
            class: 'w-full h-full object-cover block',
            loading: 'eager',
            widths: '375, 550, 750, 1100, 1500, 1780, 2000',
            alt: section.settings.title
        }}
      {% else %}
        <div class="w-full h-full bg-gray-200">
          {{ 'lifestyle-2' | placeholder_svg_tag: 'w-full h-full object-cover opacity-30 grayscale' }}
        </div>
      {% endif %}

      {% comment %} Dynamic Overlay Layer {% endcomment %}
      <div
        class="absolute inset-0 z-[1]"
        style="background-color: rgba(0,0,0, {{ section.settings.overlay_opacity | divided_by: 100.0 }});"
      ></div>
    </div>

    {% comment %} Content Area {% endcomment %}
    <div class="relative z-10 container mx-auto px-6 text-center text-white">
      <div class="max-w-3xl mx-auto space-y-6">
        {% comment %} Title: Silinse bile yedek başlık gelir {% endcomment %}
        <h2 class="text-white">
          {{ section.settings.title | default: 'THE ART OF ELEGANCE' }}
        </h2>

        {% comment %} Text: Silinse bile yedek paragraf gelir {% endcomment %}
        <div class="text-white tracking-wide">
          {{ section.settings.text | default: '<p>Discover our curated collection of timeless pieces.</p>' }}
        </div>

        {% comment %} Button: Sadece etiket tamamen silinirse kaybolur, bu normaldir {% endcomment %}
        {% if section.settings.button_label != blank %}
          <a
            href="{{ section.settings.button_link | default: '#' }}"
            class="statement-btn inline-block mt-8 px-12 py-4 border border-white text-white font-medium text-[13px] uppercase tracking-[0.2em] transition-all duration-500 hover:bg-primary hover:border-primary"
          >
            {{ section.settings.button_label }}
          </a>
        {% endif %}
      </div>
    </div>
  </section>
</div>

{% schema %}
{
  "name": "Statement Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background Image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 90,
      "step": 10,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 40
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "THE ART OF ELEGANCE"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Statement Text",
      "default": "<p>Discover our curated collection of timeless pieces.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop The Collection"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Section Spacing Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Statement Banner"
    }
  ]
}
{% endschema %}
