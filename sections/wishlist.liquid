<div class="container mx-auto px-4 py-12">
  <h2 class="text-primary uppercase mb-8 text-center tracking-widest border-b border-line pb-4 text-xl md:text-3xl">
    {{ 'wishlist.title' | t }}
  </h2>

  <div id="wishlist-container" class="grid grid-cols-2 md:grid-cols-4 gap-6 min-h-[200px] transition-all duration-500">
    {% comment %} Ürünler JS ile buraya gelecek {% endcomment %}
  </div>

  <div id="wishlist-empty" class="hidden text-center py-20">
    <p class="text-primary text-lg">{{ 'wishlist.empty' | t }}</p>
    <a
      href="{{ routes.all_products_collection_url }}"
      class="inline-block mt-4 px-6 py-3 bg-primary text-white text-sm uppercase tracking-[0.2em] hover:bg-secondary transition-colors"
    >
      {{ 'wishlist.continue_shopping' | t }}
    </a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('wishlist-container');
    const emptyMsg = document.getElementById('wishlist-empty');

    // 1. Veriyi her türlü anahtardan (Prefix dahil) çekme
    const getWishlistRaw = () => {
      for (let i = 0; i < localStorage.length; i++) {
        const key = localStorage.key(i);
        if (key && key.includes('luvia-wishlist')) {
          try {
            return JSON.parse(localStorage.getItem(key));
          } catch (e) {
            console.warn('Wishlist parse error for key:', key);
            return [];
          }
        }
      }
      return [];
    };

    // 2. Fallback mekanizması ile ürün çekme
    const fetchProductWithFallback = async (id) => {
      // Önce /products/ID.js dene
      try {
        const response = await fetch('/products/' + id + '.js');
        if (response.ok) {
          return await response.json();
        }
      } catch (e) {
        console.warn('Direct fetch failed for ID:', id);
      }

      // Fallback 1: /search/suggest.json?q=id:ID
      try {
        const searchResponse = await fetch('/search/suggest.json?q=id:' + id);
        if (searchResponse.ok) {
          const searchData = await searchResponse.json();
          const product = searchData.resources.results.products.find((p) => p.id == id);
          if (product) {
            // Ürünü tam formatına çevir
            return {
              id: product.id,
              title: product.title,
              handle: product.handle,
              url: '/products/' + product.handle,
              price: product.price,
              featured_image: product.featured_image?.url || '',
              images: product.images?.map((img) => img.url) || [],
              variants: [
                {
                  id: product.variants?.[0]?.id || product.id,
                  price: product.variants?.[0]?.price || product.price,
                },
              ],
            };
          }
        }
      } catch (e) {
        console.warn('Search fallback failed for ID:', id);
      }

      // Fallback 2: Handle ile dene (ID handle olabilir)
      try {
        const handleResponse = await fetch('/products/' + id + '.js');
        if (handleResponse.ok) {
          return await handleResponse.json();
        }
      } catch (e) {
        console.warn('Handle fetch failed for:', id);
      }

      return null;
    };

    const buildWishlist = async () => {
      const ids = getWishlistRaw();

      // Boşsa direkt mesajı göster
      if (!ids || ids.length === 0) {
        container.classList.add('hidden');
        emptyMsg.classList.remove('hidden');
        return;
      }

      // Tasarımın bozulmaması için container'ı aç, loading göster
      container.classList.remove('hidden');
      emptyMsg.classList.add('hidden');
      container.innerHTML =
        '<div class="col-span-full text-center py-20 text-xl uppercase tracking-widest opacity-50">{{ 'wishlist.loading' | t }}</div>';

      try {
        // Ürünleri fallback mekanizması ile çek
        const productPromises = ids.map((id) => fetchProductWithFallback(id));
        const products = await Promise.all(productPromises);
        const validProducts = products.filter((p) => p !== null);

        // Debug için konsola bilgi
        console.log('Wishlist IDs:', ids);
        console.log('Valid products:', validProducts.length, 'of', ids.length);

        if (validProducts.length === 0) {
          container.classList.add('hidden');
          emptyMsg.classList.remove('hidden');
          return;
        }

        // 3. Mevcut HTML yapını koruyarak ürünleri render et
        container.innerHTML = validProducts
          .map((product) => {
            const img = product.featured_image || (product.images && product.images[0]) || '';
            const price =
              window.Shopify?.currency?.active === 'USD'
                ? '$' + (product.price / 100).toFixed(2)
                : (product.price / 100).toFixed(2) + ' ' + (window.Shopify?.currency?.active || 'TL');

            return `
            <div class="wishlist-item group animate-fadeIn" id="wish-item-${product.id}">
                <div class="relative aspect-[3/4] overflow-hidden bg-gray-50 border border-line/10">
                    <button type="button" onclick="window.LuviaWishlist.toggle('${product.id}')" 
                        class="absolute top-2 right-2 z-30 w-8 h-8 bg-white rounded-full flex items-center justify-center shadow-sm hover:bg-black hover:text-white transition-all cursor-pointer border-none">
                        <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="2" stroke-linecap="round"/></svg>
                    </button>
                    
                    <a href="${product.url}" class="block h-full">
                        ${
                          img
                            ? `<img src="${img}" alt="${product.title.replace(
                                /"/g,
                                '&quot;'
                              )}" class="w-full h-full object-cover">`
                            : `<div class="w-full h-full bg-gray-100 flex items-center justify-center">
                                <svg class="w-12 h-12 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                                </svg>
                            </div>`
                        }
                    </a>

                    <a href="${product.url}" 
                      class="absolute bottom-0 w-full bg-primary text-white py-4 translate-y-full group-hover:translate-y-0 transition-all text-[14px] tracking-widest uppercase border-none cursor-pointer flex items-center justify-center text-center">
                        {{ 'products.product.view_product' | t }}
                    </a>
                </div>
                <div class="p-4 text-center">
                    <h3 class="text-[12px] uppercase tracking-wider line-clamp-1 font-normal">
                        <a href="${product.url}">${product.title.replace(/"/g, '&quot;')}</a>
                    </h3>
                    <p class="text-[14px] font-medium mt-1">${price}</p>
                </div>
            </div>
            `;
          })
          .join('');

        // İkonları (kalpleri) güncelle
        if (window.LuviaWishlist && window.LuviaWishlist.initIcons) {
          setTimeout(() => {
            window.LuviaWishlist.initIcons();
          }, 100);
        }
      } catch (error) {
        console.error('Wishlist Build Error:', error);
        container.classList.add('hidden');
        emptyMsg.classList.remove('hidden');
      }
    };

    // İlk yükleme
    buildWishlist();

    // Dinamik silme dinleyicisi
    window.addEventListener('wishlist:updated', (event) => {
      const { productId, isAdding } = event.detail || {};

      // Sadece ekleme işlemi varsa tam rebuild yap
      if (isAdding) {
        setTimeout(buildWishlist, 100);
        return;
      }

      // Silme işlemi için empty state kontrolü
      const checkEmptyState = () => {
        const remainingItems = container.querySelectorAll('.wishlist-item');
        if (remainingItems.length === 0) {
          container.classList.add('hidden');
          emptyMsg.classList.remove('hidden');
        }
      };

      // Silme işlemi zaten LuviaWishlist.toggle tarafından yapılıyor, sadece empty state kontrolü
      setTimeout(checkEmptyState, 400);
    });
  });
</script>

<style>
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
  .animate-fadeIn {
    animation: fadeIn 0.4s ease forwards;
  }
</style>
