<div class="container mx-auto px-4 py-12">
  <h4 class="text-primary uppercase mb-8 text-center font-light tracking-widest border-b border-line pb-2">
    {{ 'wishlist.title' | t }}
  </h4>

  <div id="wishlist-container" class="grid grid-cols-2 md:grid-cols-4 gap-6 min-h-[200px] transition-all duration-500">
    {% comment %} Ürünler JS ile buraya gelecek {% endcomment %}
  </div>

  <div id="wishlist-empty" class="hidden text-center py-20">
    <p class="text-primary text-lg">{{ 'wishlist.empty' | t }}</p>
    <a
      href="{{ routes.all_products_collection_url }}"
      class="inline-block mt-4 px-6 py-3 bg-primary text-white text-sm uppercase tracking-[0.2em] hover:bg-secondary transition-colors"
    >
      {{ 'wishlist.continue_shopping' | t }}
    </a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('wishlist-container');
    const emptyMessage = document.getElementById('wishlist-empty');

    const updateUI = () => {
      const ids = window.LuviaWishlist.get();
      if (!ids || ids.length === 0) {
        container?.classList.add('hidden');
        emptyMessage?.classList.remove('hidden');
      } else {
        container?.classList.remove('hidden');
        emptyMessage?.classList.add('hidden');
      }
    };

    // Silme işlemini anlık yap
    const originalToggle = window.LuviaWishlist.toggle;
    window.LuviaWishlist.toggle = function (id) {
      originalToggle.call(this, id);
      document.getElementById(`wish-item-${id}`)?.remove();
      updateUI();
    };

    updateUI();
    const wishlistIds = window.LuviaWishlist.get();
    if (wishlistIds.length === 0) return;

    // 🛡️ EN SAĞLAM YÖNTEM: Predictive Search (Garantili JSON döner)
    fetch(
      `${window.Shopify.routes.root}search/suggest.json?q=${wishlistIds.join(
        ','
      )}&resources[type]=product&resources[limit]=10`
    )
      .then((res) => res.json())
      .then((data) => {
        const products = data.resources.results.products;

        if (!products || products.length === 0) {
          updateUI();
          return;
        }

        container.innerHTML = products
          .map((product) => {
            // Fiyatı formatla
            const price = Shopify.formatMoney
              ? Shopify.formatMoney(product.price * 100, '{{ shop.money_format }}')
              : product.price + ' {{ cart.currency.symbol }}';

            return `
          <div class="group flex flex-col h-full bg-white border border-line/20 relative" id="wish-item-${product.id}">
            <div class="relative aspect-[3/4] overflow-hidden bg-custombg">
              <button type="button" onclick="LuviaWishlist.toggle('${product.id}')" class="absolute top-2 right-2 z-30 w-8 h-8 bg-white/90 rounded-full flex items-center justify-center shadow-sm hover:bg-red-500 hover:text-white transition-all cursor-pointer border-none">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="2" stroke-linecap="round"/></svg>
              </button>
              <a href="${product.url}" class="block h-full w-full">
                <img src="${product.image}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
              </a>
              <button onclick="handleWishlistAddToCart(event, '${product.variants[0].id}')" class="absolute inset-x-0 bottom-0 bg-primary text-white py-3 text-[10px] uppercase tracking-[0.2em] opacity-0 group-hover:opacity-100 transition-all cursor-pointer border-none">
                {{ 'products.product.add_to_cart' | t }}
              </button>
            </div>
            <div class="p-4 text-center">
              <h3 class="text-[12px] uppercase tracking-wider text-primary line-clamp-1">${product.title}</h3>
              <p class="mt-1 text-secondary font-medium text-[13px]">${price}</p>
            </div>
          </div>
        `;
          })
          .join('');
      })
      .catch((err) => console.error('Wishlist Loading Error:', err));
  });

  // Sepete Ekleme Fonksiyonu
  window.handleWishlistAddToCart = function (e, variantId) {
    const btn = e.currentTarget;
    btn.innerText = '...';
    fetch('/cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ id: variantId, quantity: 1 }),
    })
      .then((res) => res.json())
      .then(() => {
        btn.innerText = 'ADDED';
        if (window.showToast) window.showToast("{{ 'products.product.add_to_cart' | t }}", 'success');
        if (typeof openAndRefreshCart === 'function') openAndRefreshCart();
        setTimeout(() => {
          btn.innerText = "{{ 'products.product.add_to_cart' | t }}";
        }, 2000);
      });
  };
</script>
