<div class="container mx-auto px-4 py-12">
  <h4 class="text-primary uppercase mb-8 text-center font-light tracking-widest border-b border-line pb-2">
    {{ 'wishlist.title' | t }}
  </h4>

  <div id="wishlist-container" class="grid grid-cols-2 md:grid-cols-4 gap-6 min-h-[200px] transition-all duration-500">
    {% comment %} Ürünler JS ile buraya gelecek {% endcomment %}
  </div>

  <div id="wishlist-empty" class="hidden text-center py-20">
    <p class="text-primary text-lg">{{ 'wishlist.empty' | t }}</p>
    <a
      href="{{ routes.all_products_collection_url }}"
      class="inline-block mt-4 px-6 py-3 bg-primary text-white text-sm uppercase tracking-[0.2em] hover:bg-secondary transition-colors"
    >
      {{ 'wishlist.continue_shopping' | t }}
    </a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('wishlist-container');
    const emptyMessage = document.getElementById('wishlist-empty');

    const updateWishlistUI = () => {
      const wishlistIds = window.LuviaWishlist.get();
      if (!wishlistIds || wishlistIds.length === 0) {
        if (container) container.classList.add('hidden');
        if (emptyMessage) emptyMessage.classList.remove('hidden');
      } else {
        if (container) container.classList.remove('hidden');
        if (emptyMessage) emptyMessage.classList.add('hidden');
      }
    };

    // Toggle fonksiyonunu sayfa için özelleştir
    const originalToggle = window.LuviaWishlist.toggle;
    window.LuviaWishlist.toggle = function (id) {
      originalToggle.call(this, id);
      const itemElement = document.getElementById(`wish-item-${id}`);
      if (itemElement) {
        itemElement.remove();
        updateWishlistUI();
      }
    };

    updateWishlistUI();

    const wishlistIds = window.LuviaWishlist.get();
    if (wishlistIds.length === 0) return;

    // 1. Arama sorgusu oluştur (id:123 OR id:456 ...)
    const searchQuery = wishlistIds.map((id) => `id:${id}`).join(' OR ');

    // 2. Search API ile ürünleri getir
    fetch(`${window.Shopify.routes.root}search?q=${encodeURIComponent(searchQuery)}&view=json&type=product`)
      .then((res) => res.json())
      .then((products) => {
        if (!products || products.length === 0) {
          updateWishlistUI();
          return;
        }

        container.innerHTML = products
          .map((product) => {
            const isOnSale = product.compare_at_price > product.price;
            // Fiyat formatlama (Basit ama etkili)
            const price = Shopify.formatMoney(product.price, '{{ shop.money_format }}');
            const comparePrice = product.compare_at_price
              ? Shopify.formatMoney(product.compare_at_price, '{{ shop.money_format }}')
              : '';

            return `
            <div class="group flex flex-col h-full bg-white relative" id="wish-item-${product.id}">
              <div class="relative aspect-[3/4] overflow-hidden bg-custombg">
                <button type="button" 
                        onclick="LuviaWishlist.toggle('${product.id}')"
                        class="absolute top-3 right-3 z-20 flex items-center justify-center w-8 h-8 bg-white rounded-full shadow-sm hover:bg-red-500 hover:text-white transition-all cursor-pointer border-none">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
                </button>
                <a href="${product.url}" class="block h-full w-full">
                  <img src="${
                    product.featured_image
                  }" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105">
                </a>
                <button type="button" onclick="handleWishlistAddToCart(event, '${
                  product.variants[0].id
                }')" class="absolute inset-x-0 bottom-0 bg-primary text-white py-4 text-[11px] uppercase tracking-widest opacity-0 group-hover:opacity-100 transition-all cursor-pointer border-none">
                  {{ 'products.product.add_to_cart' | t }}
                </button>
              </div>
              <div class="pt-4 text-center">
                <a href="${product.url}" class="text-primary text-[13px] uppercase tracking-wider line-clamp-1 px-2">${
              product.title
            }</a>
                <div class="mt-1 flex justify-center gap-2 text-[13px]">
                  ${isOnSale ? `<span class="text-gray-400 line-through">${comparePrice}</span>` : ''}
                  <span class="text-primary font-medium">${price}</span>
                </div>
              </div>
            </div>`;
          })
          .join('');
      })
      .catch((err) => {
        console.error('Wishlist Error:', err);
        updateWishlistUI();
      });

    // Sepete Ekleme
    window.handleWishlistAddToCart = function (e, variantId) {
      const btn = e.currentTarget;
      btn.innerText = '...';
      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 }),
      })
        .then((res) => res.json())
        .then((data) => {
          btn.innerText = 'ADDED';
          if (window.showToast) window.showToast('Added to cart', 'success');
          if (typeof openAndRefreshCart === 'function') openAndRefreshCart();
          setTimeout(() => {
            btn.innerText = 'ADD TO CART';
          }, 2000);
        });
    };
  });
</script>
