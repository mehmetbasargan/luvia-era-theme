<div class="container mx-auto px-4 py-12">
  <h2 class="text-primary uppercase mb-8 text-center tracking-widest border-b border-line pb-4 text-xl md:text-3xl">
    {{ 'wishlist.title' | t }}
  </h2>

  <div id="wishlist-container" class="grid grid-cols-2 md:grid-cols-4 gap-6 min-h-[200px] transition-all duration-500">
    {% comment %} Ürünler JS ile buraya gelecek {% endcomment %}
  </div>

  <div id="wishlist-empty" class="hidden text-center py-20">
    <p class="text-primary text-lg">{{ 'wishlist.empty' | t }}</p>
    <a
      href="{{ routes.all_products_collection_url }}"
      class="inline-block mt-4 px-6 py-3 bg-primary text-white text-sm uppercase tracking-[0.2em] hover:bg-secondary transition-colors"
    >
      {{ 'wishlist.continue_shopping' | t }}
    </a>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const container = document.getElementById('wishlist-container');
    const emptyMessage = document.getElementById('wishlist-empty');

    const updateUI = () => {
      const ids = window.LuviaWishlist.get();
      if (!ids || ids.length === 0) {
        if (container) container.classList.add('hidden');
        if (emptyMessage) emptyMessage.classList.remove('hidden');
      } else {
        if (container) container.classList.remove('hidden');
        if (emptyMessage) emptyMessage.classList.add('hidden');
      }
    };

    // Wishlist'ten silme işlemini global fonksiyona bağla
    const originalToggle = window.LuviaWishlist.toggle;
    window.LuviaWishlist.toggle = function (id, handle) {
      // Hem ID hem Handle desteği için kontrol
      const targetId = id.toString();
      originalToggle.call(this, null, targetId);
      document.getElementById(`wish-item-${targetId}`)?.remove();
      updateUI();
    };

    updateUI();
    const wishlistIds = window.LuviaWishlist.get();
    if (!wishlistIds || wishlistIds.length === 0) return;

    // ARAMA SORGU GÜNCELLEMESİ: ID'leri Shopify Search API'ye gönderiyoruz
    const searchQuery = wishlistIds.map((id) => `id:${id.trim()}`).join(' OR ');
    const apiUrl = `${window.Shopify.routes.root}search?q=${encodeURIComponent(
      searchQuery
    )}&type=product&view=wishlist-json`;

    fetch(apiUrl)
      .then((res) => res.json())
      .then((products) => {
        if (!products || products.length === 0) {
          updateUI();
          return;
        }

        container.innerHTML = products
          .map((product) => {
            // Fiyat Formatlama
            let formattedPrice = (product.price / 100).toFixed(2);
            if (window.Shopify && window.Shopify.formatMoney) {
              formattedPrice = Shopify.formatMoney(product.price, '{{ shop.money_format }}');
            }

            return `
            <div class="group flex flex-col h-full bg-white border border-line/20 relative" id="wish-item-${product.id}">
              <div class="relative aspect-[3/4] overflow-hidden bg-custombg">
                <button type="button" 
                  onclick="LuviaWishlist.toggle('${product.id}')" 
                  class="absolute top-2 right-2 z-30 w-8 h-8 bg-white rounded-full flex items-center justify-center shadow-sm hover:bg-red-500 hover:text-white transition-all cursor-pointer border-none" >
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="2" stroke-linecap="round"/></svg>
                </button>

                <a href="${product.url}" class="block h-full w-full">
                  <img src="${product.image}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy">
                </a>

                <button type="button" 
                  onclick="handleWishlistAddToCart(event, '${product.variant_id}')" 
                  class="absolute inset-x-0 bottom-0 bg-primary text-white py-4 text-[11px] uppercase tracking-[0.2em] opacity-0 group-hover:opacity-100 transition-all cursor-pointer border-none z-40">
                  {{ 'products.product.add_to_cart' | t }}
                </button>
              </div>

              <div class="p-4 text-center">
                <h3 class="text-[12px] uppercase tracking-wider text-primary line-clamp-1 font-normal">${product.title}</h3>
                <p class="mt-1 text-secondary font-medium text-[13px]">${formattedPrice}</p>
              </div>
            </div>
            `;
          })
          .join('');
      })
      .catch((err) => {
        console.error('Wishlist error:', err);
        updateUI();
      });
  });

  // 🛒 SEPETE EKLEME (WISHLIST ÖZEL)
  window.handleWishlistAddToCart = function (event, variantId) {
    event.preventDefault();
    const btn = event.currentTarget;
    const originalText = btn.innerText;
    if (btn.disabled) return;

    btn.disabled = true;
    btn.innerText = '...';

    fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ items: [{ id: variantId, quantity: 1 }] }),
    })
      .then((res) => res.json())
      .then((data) => {
        btn.innerText = 'ADDED';
        // Çekmeceyi açan fonksiyonun
        if (typeof openAndRefreshCart === 'function') openAndRefreshCart();
        else if (window.openCartDrawer) window.openCartDrawer();

        document.dispatchEvent(new CustomEvent('cart:updated', { detail: { cart: data } }));
        setTimeout(() => {
          btn.innerText = originalText;
          btn.disabled = false;
        }, 2000);
      })
      .catch(() => {
        btn.innerText = 'ERROR';
        btn.disabled = false;
      });
  };
</script>
