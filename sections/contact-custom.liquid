{% comment %} Luvia Era - Custom Contact Section {% endcomment %}
<section class="max-w-[1440px] mx-auto px-6 py-24 md:py-32 bg-white">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-20">
    <div class="flex flex-col space-y-12 animate-fade-in">
      <h1 class="font-josefin font-light uppercase tracking-[0.4em] text-2xl md:text-3xl text-black">
        {{ section.settings.heading }}
      </h1>
      <div class="space-y-10 font-josefin font-light uppercase tracking-[0.2em] text-xs md:text-sm text-black">
        <p class="opacity-60 leading-loose max-w-md">{{ section.settings.subtext }}</p>

        <div class="space-y-8 pt-4">
          <div class="group">
            <p class="opacity-30 mb-2 text-[10px]">Paris Studio</p>
            <p class="tracking-[0.3em]">22 Rue de Rivoli, 75004 Paris</p>
          </div>
          <div class="group">
            <p class="opacity-30 mb-2 text-[10px]">Inquiries</p>
            <p class="tracking-[0.3em]">studio@luvialera.com</p>
          </div>
        </div>
      </div>
    </div>

    <div class="animate-fade-in-delayed">
      {% form 'contact' %}
        {% if form.posted_successfully? %}
          <p class="font-josefin text-xs tracking-[0.3em] mb-10 text-black italic">
            MESSAGE SENT SUCCESSFULLY. WE WILL CONTACT YOU SHORTLY.
          </p>
        {% endif %}

        <div class="space-y-12">
          <input
            type="text"
            name="contact[name]"
            placeholder="FULL NAME"
            required
            class="w-full bg-transparent border-b border-gray-200 py-4 font-josefin text-xs uppercase tracking-[0.2em] focus:outline-none focus:border-black transition-colors duration-[1500ms] placeholder:opacity-30"
          >

          <input
            type="email"
            name="contact[email]"
            placeholder="EMAIL ADDRESS"
            required
            class="w-full bg-transparent border-b border-gray-200 py-4 font-josefin text-xs uppercase tracking-[0.2em] focus:outline-none focus:border-black transition-colors duration-[1500ms] placeholder:opacity-30"
          >

          <textarea
            name="contact[body]"
            rows="4"
            placeholder="YOUR MESSAGE"
            required
            class="w-full bg-transparent border-b border-gray-200 py-4 font-josefin text-xs uppercase tracking-[0.2em] focus:outline-none focus:border-black transition-colors duration-[1500ms] resize-none placeholder:opacity-30"
          ></textarea>

          <button
            type="submit"
            class="w-full md:w-auto px-16 py-5 bg-black text-white font-josefin text-[10px] uppercase tracking-[0.4em] hover:bg-gray-800 transition-all duration-500"
          >
            Send Message
          </button>
        </div>
      {% endform %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Contact Custom",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "CONTACT THE ERA" },
    {
      "type": "textarea",
      "id": "subtext",
      "label": "Subtext",
      "default": "FOR INQUIRIES REGARDING OUR COLLECTIONS, PRIVATE APPOINTMENTS OR PARTNERSHIPS."
    }
  ],
  "presets": [
    {
      "name": "Contact Custom"
    }
  ]
}
{% endschema %}
