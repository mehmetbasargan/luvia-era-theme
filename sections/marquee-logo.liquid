{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  #LuviaSection-{{ section.id }} {
    {% if section.settings.remove_bg %}
      background-color: transparent !important;
    {% elsif section.settings.use_custom_bg %}
      background-color: {{ section.settings.section_bg_color }} !important;
    {% endif %}
  }

  @keyframes marquee-{{ section.id }} {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .animate-marquee-{{ section.id }} {
    animation: marquee-{{ section.id }} 20s linear infinite;
    display: flex;
    width: max-content;
  }

  .group:hover .animate-marquee-{{ section.id }} {
    animation-play-state: paused;
  }
{%- endstyle -%}

<section id="LuviaSection-{{ section.id }}" class="section-{{ section.id }}-padding transition-colors duration-300">
  {% if section.settings.title != blank %}
    <div class="text-center mb-12">
      <h2 class="text-xl md:text-2xl font-light uppercase tracking-[0.3em] text-primary">
        {{ section.settings.title }}
      </h2>
      <div class="h-[1px] w-12 bg-secondary mx-auto mt-6 opacity-30"></div>
    </div>
  {% endif %}

  <div class="relative flex overflow-hidden group py-4">
    {%- capture marquee_content -%}
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          <div class="mx-10 md:mx-20 w-24 md:w-40 flex-shrink-0 opacity-50 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-700 ease-in-out cursor-pointer flex items-center justify-center" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 400 | image_tag: class: 'w-full h-auto object-contain', loading: 'lazy' }}
            {% else %}
               {% comment %} Individual Logo Placeholder {% endcomment %}
               <div class="text-[10px] font-bold tracking-tighter text-gray-400 uppercase border border-gray-200 px-4 py-2 italic">Your Logo</div>
            {% endif %}
          </div>
        {% endfor %}
      {% else %}
        {% comment %} 
           ELEGANT PLACEHOLDER MODE: 
           Shows 6 stylish dummy logos if no blocks are added.
        {% endcomment %}
        {%- assign dummy_logos = "Logo, Logo, Logo, Logo, Logo, Logo" | split: ", " -%}
        {% for logo_name in dummy_logos %}
          <div class="mx-10 md:mx-20 w-24 md:w-40 flex-shrink-0 opacity-20 grayscale flex items-center justify-center">
            <span class="text-lg md:text-2xl font-black font-josefin italic uppercase tracking-tighter">{{ logo_name }}</span>
          </div>
        {% endfor %}
      {% endif %}
    {%- endcapture -%}

    {% comment %} Double the content for seamless infinite loop {% endcomment %}
    <div class="animate-marquee-{{ section.id }} flex items-center whitespace-nowrap">
      {{ marquee_content }}
      {{ marquee_content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Marquee Logos",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "AS FEATURED IN" },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    },
    { "type": "header", "content": "Design" },
    { "type": "checkbox", "id": "use_custom_bg", "label": "Use Custom Background", "default": false },
    { "type": "color", "id": "section_bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "checkbox", "id": "remove_bg", "label": "Transparent Background", "default": false }
  ],
  "blocks": [
    {
      "type": "logo_image",
      "name": "Logo",
      "settings": [{ "type": "image_picker", "id": "image", "label": "Logo Image" }]
    }
  ],
  "presets": [
    {
      "name": "Dynamic Marquee Logos",
      "blocks": []
    }
  ]
}
{% endschema %}
