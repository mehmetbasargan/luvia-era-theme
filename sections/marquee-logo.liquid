<section class="py-16 bg-white overflow-hidden border-y border-line">
  {% if section.settings.title != blank %}
    <div class="text-center mb-10">
      <h4 class="font-light uppercase tracking-[0.2em] text-secondary">
        {{ section.settings.title }}
      </h4>
      <div class="h-[1px] w-20 bg-secondary mx-auto mt-4"></div>
    </div>
  {% endif %}

  <div class="relative flex overflow-x-hidden group">
    {%- capture marquee_content -%}
      {% for block in section.blocks %}
        <div class="mx-8 md:mx-16 w-24 md:w-36 flex-shrink-0 opacity-40 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-[1500ms] ease-out cursor-pointer luvia-gallery-item" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 400 | image_tag: 
              class: 'w-full h-auto object-contain',
              loading: 'lazy'
            }}
          {% else %}
            {{ 'logo' | placeholder_svg_tag: 'w-full h-auto opacity-20' }}
          {% endif %}
        </div>
      {% endfor %}
    {%- endcapture -%}

    <div class="animate-marquee flex items-center whitespace-nowrap">
      {{ marquee_content }}
      {{ marquee_content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Dinamik Marquee Logos",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "AS FEATURED IN"
    }
  ],
  "blocks": [
    {
      "type": "logo_image",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dinamik Marquee Logos",
      "blocks": [{ "type": "logo_image" }, { "type": "logo_image" }, { "type": "logo_image" }]
    }
  ]
}
{% endschema %}

<style>
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  .animate-marquee {
    animation: marquee 40s linear infinite;
    display: flex;
    width: max-content;
  }
  .group:hover .animate-marquee {
    animation-play-state: paused;
  }
</style>
