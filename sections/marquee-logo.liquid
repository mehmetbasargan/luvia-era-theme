{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  /* color and background settings */
  #LuviaSection-{{ section.id }} {
    {% if section.settings.remove_bg %}
      background-color: transparent !important;
      background-image: none !important;
    {% elsif section.settings.use_custom_bg %}
      background-color: {{ section.settings.section_bg_color }} !important;
      background-image: none !important;
    {% endif %}
  }
{%- endstyle -%}

<section
  id="LuviaSection-{{ section.id }}"
  class="
    transition-colors duration-300 section-{{ section.id }}-padding
    {% unless section.settings.remove_bg or section.settings.use_custom_bg %}bg-white color-{{ section.settings.color_scheme }} gradient{% endunless %}
  "
>
  {% if section.settings.title != blank %}
    <div class="text-center mb-10">
      <h2 class="text-secondary">
        {{ section.settings.title }}
      </h2>
      <div class="h-[1px] w-20 bg-secondary mx-auto mt-4"></div>
    </div>
  {% endif %}

  <div class="relative flex overflow-x-hidden group">
    {%- capture marquee_content -%}
      {% for block in section.blocks %}
        <div class="mx-8 md:mx-16 w-24 md:w-36 flex-shrink-0 opacity-40 grayscale hover:grayscale-0 hover:opacity-100 transition-all duration-500 ease-out cursor-pointer luvia-gallery-item" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 200 | image_tag: 
              class: 'w-full h-auto object-contain',
              loading: 'eager',
              width: '200',
              height: '100'
            }}
          {% else %}
            {{ 'logo' | placeholder_svg_tag: 'w-full h-auto opacity-20' }}
          {% endif %}
        </div>
      {% endfor %}
    {%- endcapture -%}

    <div class="animate-marquee flex items-center whitespace-nowrap">
      {{ marquee_content }}
      {{ marquee_content }}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Marquee Logos",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "AS FEATURED IN"
    },
    {
      "type": "header",
      "content": "Section Spacing Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    },
    {
      "type": "header",
      "content": "Background Design"
    },
    {
      "type": "checkbox",
      "id": "use_custom_bg",
      "label": "Use Custom Background Color",
      "default": false
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "remove_bg",
      "label": "Remove Background (Transparent)",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "logo_image",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dinamik Marquee Logos",
      "blocks": [{ "type": "logo_image" }, { "type": "logo_image" }, { "type": "logo_image" }]
    }
  ]
}
{% endschema %}

<style>
  @keyframes marquee {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  .animate-marquee {
    animation: marquee 15s linear infinite;
    display: flex;
    width: max-content;
    will-change: transform;
  }
  .group:hover .animate-marquee {
    animation-play-state: paused;
  }

  /* Performance optimization */
  .animate-marquee img {
    will-change: transform;
    backface-visibility: hidden;
    transform: translateZ(0);
  }
</style>
