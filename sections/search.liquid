<script>
  // 1. Gerekli Değişkenler ve Çeviriler
  const translations = {
    journal: {{ 'general.search.journal' | t | json }} || "Journal",
    article: {{ 'general.search.article' | t | json }} || "Article",
    readMore: {{ 'blog.read_more' | t | json }} || "Read Article",
    viewProduct: {{ 'general.view_product' | t | json }} || "View Product",
    sale: {{ 'products.product.on_sale' | t | json }} || "SALE"
  };

  const searchInput = document.querySelector('#search-input');
  const resultsContainer = document.querySelector('#search-results');
  const searchHeaderWrapper = document.querySelector('#search-header-wrapper');
  const dynamicTitle = document.querySelector('#dynamic-search-title');
  const emptyMessage = document.querySelector('#search-empty-message');

  const formatMoney = (cents) => {
    if (!cents) return '';
    return (cents / 100).toLocaleString('{{ shop.locale }}', {
      style: 'currency',
      currency: '{{ cart.currency.iso_code }}',
    });
  };

  const rawSearchLabel = "{{ 'general.search.search_results' | t }}";
  const searchLabel = rawSearchLabel.includes('search_results') ? 'Search Results' : rawSearchLabel;

  // 2. Arama Girişi Dinleyicisi (Input Listener)
  if (searchInput) {
    searchInput.addEventListener('input', function (e) {
      const searchTerm = e.target.value.trim();
      
      if (searchTerm.length <= 2) {
        if (!window.location.search.includes('q=')) {
          if (searchHeaderWrapper) searchHeaderWrapper.classList.add('hidden');
          if (resultsContainer) resultsContainer.innerHTML = '';
        }
        return;
      }

      // Shopify Suggest API'den veriyi çek
      fetch(`${window.Shopify.routes.root}search/suggest.json?q=${encodeURIComponent(searchTerm)}&resources[type]=product,article&resources[limit]=12`)
        .then(response => response.json())
        .then(data => {
          const products = data.resources?.results?.products || [];
          const articles = data.resources?.results?.articles || [];
          const allResults = [...products, ...articles];
          
          if (searchHeaderWrapper) searchHeaderWrapper.classList.remove('hidden');
          if (dynamicTitle) dynamicTitle.innerText = `${searchLabel}: "${searchTerm}" (${allResults.length})`;

          if (allResults.length > 0) {
            if (emptyMessage) emptyMessage.classList.add('hidden');
            if (resultsContainer) resultsContainer.classList.remove('hidden');
            renderResults(allResults); // Kartları oluştur
          } else {
            if (resultsContainer) resultsContainer.innerHTML = '';
            if (emptyMessage) emptyMessage.classList.remove('hidden');
          }
        })
        .catch(err => console.error("Search Fetch Error:", err));
    });
  }

  // 3. Kartları Ekrana Basan Fonksiyon
  function renderResults(results) {
    if (!resultsContainer) return;

    resultsContainer.innerHTML = results.map((item) => {
        const isArticle = item.url.includes('/blogs/') || item.type === 'article';
        const mainImage = item.featured_image ? item.featured_image.url : (item.image || '');
        
        let badgeHtml = '', priceHtml = '', actionButton = '', wishlistBtn = '';

        if (!isArticle) {
          // Ürün Ayarları
          const currentPrice = Number(item.price);
          const comparePriceRaw = Number(item.compare_at_price || item.compare_at_price_max || 0);
          const isOnSale = comparePriceRaw > currentPrice && comparePriceRaw > 0;
          const variantId = item.variants && item.variants[0] ? item.variants[0].id : '';

          if (isOnSale) {
            badgeHtml = `<span class="absolute top-3 left-3 z-30 bg-secondary text-white text-[10px] px-2 py-1 uppercase tracking-widest font-medium">${translations.sale}</span>`;
          }

          priceHtml = `<div class="mt-2 flex items-center gap-2">
            ${isOnSale ? `<span class="text-gray-400 line-through text-[12px]">${formatMoney(comparePriceRaw)}</span>` : ''}
            <span class="text-primary text-[14px] font-medium">${formatMoney(item.price)}</span>
          </div>`;

          // Global Wishlist Butonu
          wishlistBtn = `
          <div class="absolute top-3 right-3 z-40">
            <button type="button" 
                    class="custom-wishlist-btn flex items-center justify-center w-9 h-9 bg-white/90 backdrop-blur-sm rounded-full shadow-sm hover:scale-110 transition-transform duration-300 pointer-events-auto" 
                    data-product-id="${item.id}"
                    onclick="window.LuviaWishlist.toggle('${item.id}')">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"></path>
              </svg>
            </button>
          </div>`;

          // Global Add to Cart Butonu
          actionButton = `
          <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 hidden md:block z-30">
            <button type="button" 
                    onclick="window.handleGlobalAddToCart(event, '${variantId}')" 
                    class="w-full bg-primary text-white py-4 text-[11px] uppercase tracking-[0.2em] block text-center hover:bg-secondary transition-colors border-none cursor-pointer font-heading">
              ADD TO CART
            </button>
          </div>`;
        } else {
          // Blog Yazısı Ayarları
          badgeHtml = `<span class="absolute top-3 left-3 z-30 bg-black text-white text-[10px] px-2 py-1 tracking-widest uppercase italic shadow-sm">${translations.journal}</span>`;
          actionButton = `
          <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 hidden md:block z-20">
            <a href="${item.url}" class="w-full bg-black text-white py-4 text-[11px] uppercase tracking-[0.2em] block text-center hover:bg-secondary transition-colors font-heading">
              ${translations.readMore}
            </a>
          </div>`;
        }

        return `
        <div class="group flex flex-col h-full bg-white overflow-hidden relative animate-fadeIn transition-all" id="search-item-${item.id}">
          <div class="relative aspect-[3/4] overflow-hidden bg-custombg">
            ${badgeHtml}
            ${wishlistBtn}
            
            <a href="${item.url}" class="block h-full w-full">
              <img src="${mainImage}" alt="${item.title}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy">
            </a>

            ${actionButton}
          </div>

          <div class="pt-4 pb-2 flex flex-col items-center px-3 text-center">
            <a href="${item.url}" class="text-primary font-light text-[14px] hover:text-secondary transition-colors uppercase line-clamp-2 min-h-[40px] tracking-wider font-body">
              ${item.title}
            </a>
            ${priceHtml}
          </div>
        </div>`;
      }).join('');

    // Kartlar basıldıktan sonra favori ikonlarını (kalpleri) boya
    if (window.LuviaWishlist && typeof window.LuviaWishlist.initIcons === 'function') {
      window.LuviaWishlist.initIcons();
    }
  }
</script>

<style>
  .animate-fadeIn {
    animation: fadeIn 0.4s ease-out forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
