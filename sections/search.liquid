<div class="container py-20 mx-auto px-4">
  <form
    action="{{ routes.search_url }}"
    method="get"
    role="search"
    class="flex items-center gap-2 max-w-3xl mx-auto mb-10"
  >
    <input type="hidden" name="type" value="product,article">
    <div class="relative w-full">
      <label class="sr-only" for="search-input">{{ 'general.search.placeholder' | t }}</label>
      <input
        id="search-input"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'general.search.placeholder' | t }}"
        class="border border-line rounded px-4 py-2 h-16 w-full focus:outline-none focus:ring-1 focus:ring-secondary font-inter bg-white"
        autocomplete="off"
      >
    </div>
    <button
      type="submit"
      class="h-[64px] w-[64px] bg-secondary text-white rounded flex items-center justify-center hover:bg-primary transition-colors shrink-0"
      aria-label="{{ 'general.search.submit' | t | default: 'Submit search' }}"
    >
      {% render 'icon-search', class: 'w-6 h-6' %}
    </button>
  </form>

  <div
    id="search-header-wrapper"
    class="mb-8 border-b border-line pb-4 {% unless search.performed %}hidden{% endunless %}"
  >
    <span
      id="dynamic-search-title"
      class="text-primary leading-relaxed text-center text-lg flex items-start justify-center"
    >
      {% if search.performed %}
        {{ 'general.search.results_with_count' | t: terms: search.terms, count: search.results_count }}
      {% endif %}
    </span>
  </div>

  <div id="search-results-container">
    <div id="search-results" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 w-full">
      {% if search.performed %}
        {% for result in search.results %}
          {% if result.object_type == 'product' %}
            {% render 'product-card', product: result %}
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
    <div id="search-empty-message" class="hidden text-center py-20 text-lg text-primary">
      {{ 'general.search.no_results' | t }}
    </div>
  </div>
</div>

<script>
  const translations = {
    journal: {{ 'general.search.journal' | t | json }} || "Journal",
    article: {{ 'general.search.article' | t | json }} || "Article",
    readMore: {{ 'blog.read_more' | t | json }} || "Read Article",
    viewProduct: {{ 'general.view_product' | t | json }} || "VIEW PRODUCT",
    sale: {{ 'products.product.on_sale' | t | json }} || "SALE"
  };

  const searchInput = document.querySelector('#search-input');
  const resultsContainer = document.querySelector('#search-results');
  const searchHeaderWrapper = document.querySelector('#search-header-wrapper');
  const dynamicTitle = document.querySelector('#dynamic-search-title');
  const emptyMessage = document.querySelector('#search-empty-message');

  const formatMoney = (cents) => {
    if (!cents) return '';
    return (cents / 100).toLocaleString('{{ shop.locale }}', {
      style: 'currency',
      currency: '{{ cart.currency.iso_code }}',
    });
  };

  const rawSearchLabel = "{{ 'general.search.search_results' | t }}";
  const searchLabel = rawSearchLabel.includes('search_results') ? 'Search Results' : rawSearchLabel;

  if (searchInput) {
    searchInput.addEventListener('input', function (e) {
      const searchTerm = e.target.value.trim();
      if (searchTerm.length <= 2) {
        if (!window.location.search.includes('q=')) {
          if (searchHeaderWrapper) searchHeaderWrapper.classList.add('hidden');
          if (resultsContainer) resultsContainer.innerHTML = '';
        }
        return;
      }

      fetch(`${window.Shopify.routes.root}search/suggest.json?q=${encodeURIComponent(searchTerm)}&resources[type]=product,article&resources[limit]=12`)
        .then(response => response.json())
        .then(data => {
          const products = data.resources?.results?.products || [];
          const articles = data.resources?.results?.articles || [];
          const allResults = [...products, ...articles];

          if (searchHeaderWrapper) searchHeaderWrapper.classList.remove('hidden');
          if (dynamicTitle) dynamicTitle.innerText = `${searchLabel}: "${searchTerm}" (${allResults.length})`;

          if (allResults.length > 0) {
            if (emptyMessage) emptyMessage.classList.add('hidden');
            if (resultsContainer) resultsContainer.classList.remove('hidden');
            renderResults(allResults);
          } else {
            if (resultsContainer) resultsContainer.innerHTML = '';
            if (emptyMessage) emptyMessage.classList.remove('hidden');
          }
        })
        .catch(err => console.error("Search fetch error:", err));
    });
  }

  function renderResults(results) {
    if (!resultsContainer) return;

    resultsContainer.innerHTML = results.map(item => {
      const isArticle = item.url.includes('/blogs/') || item.type === 'article';
      const mainImage = item.featured_image ? item.featured_image.url : (item.image || '');
      let badgeHtml = '', priceHtml = '', actionButton = '', wishlistBtn = '';

      if (!isArticle) {
        const currentPrice = Number(item.price);
        const comparePriceRaw = Number(item.compare_at_price || item.compare_at_price_max || 0);
        const isOnSale = comparePriceRaw > currentPrice && comparePriceRaw > 0;

        if (isOnSale) {
          badgeHtml = `<span class="absolute top-3 left-3 z-30 bg-secondary text-white text-[10px] px-2 py-1 uppercase tracking-widest font-medium">${translations.sale}</span>`;
        }

        priceHtml = `<div class="mt-2 flex items-center gap-2">
            ${isOnSale ? `<span class="text-gray-600 line-through text-[13px]">${formatMoney(comparePriceRaw)}</span>` : ''}
            <span class="text-primary text-[14px] font-medium">${formatMoney(item.price)}</span>
          </div>`;

        wishlistBtn = `
          <div class="absolute top-3 right-3 z-50">
            <button type="button" class="custom-wishlist-btn flex items-center justify-center w-9 h-9 bg-white rounded-full shadow-sm hover:scale-110 transition-transform duration-300" data-product-id="${item.id}" onclick="window.LuviaWishlist.toggle('${item.id}')">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"></path>
              </svg>
            </button>
          </div>`;

        // DETAIL BUTTON FOR ALL PRODUCTS
        actionButton = `
          <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 hidden md:block z-20">
            <a href="${item.url}" class="w-full bg-primary text-white py-4 text-[11px] uppercase tracking-[0.2em] block text-center hover:bg-secondary transition-colors font-heading no-underline" aria-label="View ${translations.viewProduct} details">
              ${translations.viewProduct}
            </a>
          </div>`;
      } else {
        badgeHtml = `<span class="absolute top-3 left-3 z-30 bg-black text-white text-[10px] px-2 py-1 tracking-widest uppercase italic shadow-sm">${translations.journal}</span>`;
        actionButton = `
          <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 hidden md:block z-20">
            <a href="${item.url}" class="w-full bg-black text-white py-4 text-[11px] uppercase tracking-[0.2em] block text-center hover:bg-secondary transition-colors font-heading no-underline" aria-label="Read ${translations.readMore}">
              ${translations.readMore}
            </a>
          </div>`;
      }

      return `
        <div class="group flex flex-col h-full bg-white overflow-hidden relative animate-fadeIn transition-all">
          <div class="relative aspect-[3/4] overflow-hidden bg-custombg">
            ${badgeHtml}
            ${wishlistBtn}
            <a href="${item.url}" class="block h-full w-full" aria-label="View ${item.title} details">
              <img src="${mainImage}" alt="${item.title}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110" loading="lazy" width="400" height="400">
            </a>
            ${actionButton}
          </div>
          <div class="pt-4 pb-2 flex flex-col items-center px-3 text-center">
            <a href="${item.url}" class="text-primary font-light text-[14px] hover:text-secondary transition-colors uppercase line-clamp-2 min-h-[40px] tracking-wider font-body no-underline" aria-label="View ${item.title} details">
              ${item.title}
            </a>
            ${priceHtml}
          </div>
        </div>`;
    }).join('');

    if (window.LuviaWishlist && typeof window.LuviaWishlist.initIcons === 'function') {
      window.LuviaWishlist.initIcons();
    }
  }
</script>
