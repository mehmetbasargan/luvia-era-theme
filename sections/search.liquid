<div class="container py-20">
  {% comment %} Search Formu {% endcomment %}
  <form
    action="{{ routes.search_url }}"
    method="get"
    role="search"
    class="flex items-center gap-2 max-w-3xl mx-auto mb-10"
  >
    <input type="hidden" name="type" value="product,article">
    <div class="relative w-full">
      <input
        id="search-input"
        type="search"
        name="q"
        value="{{ search.terms | escape }}"
        placeholder="{{ 'general.search.placeholder' | t }}"
        class="border border-line rounded px-4 py-2 h-16 w-full focus:outline-none focus:ring-1 focus:ring-secondary font-inter"
        autocomplete="off"
      >
    </div>
    <button
      type="submit"
      class="h-[64px] w-[64px] bg-secondary text-white rounded flex items-center justify-center hover:bg-primary transition-colors shrink-0"
    >
      {% render 'icon-search', class: 'w-6 h-6' %}
    </button>
  </form>

  {% comment %} Search Header {% endcomment %}
  <div
    id="search-header-wrapper"
    class="mb-8 border-b border-line pb-4 {% unless search.performed %}hidden{% endunless %}"
  >
    <h5 id="dynamic-search-title" class=" font-light text-primary uppercase tracking-widest leading-relaxed">
      {% if search.performed %}
        {{ 'general.search.results_with_count' | t: terms: search.terms, count: search.results_count }}
      {% endif %}
    </h5>
  </div>

  {% comment %} Search Results {% endcomment %}
  <div id="search-results-container">
    <div id="search-results" class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-6 w-full">
      {% if search.performed %}
        {% for result in search.results %}
          {% if result.object_type == 'product' %}
            {% render 'product-card', product: result %}
          {% endif %}
        {% endfor %}
      {% endif %}
    </div>
    <div id="search-empty-message" class="hidden text-center py-20 text-lg text-primary">
      {{ 'general.search.no_results' | t }}
    </div>
  </div>
</div>

<script>
  // ... (translations ve formatMoney kısımları aynı kalsın) ...

  function renderResults(results) {
    if (!resultsContainer) return;

    resultsContainer.innerHTML = results
      .map((item) => {
        const isArticle = item.url.includes('/blogs/') || item.type === 'article';
        const mainImage = item.featured_image ? item.featured_image.url : item.image || '';
        const hoverImage = !isArticle ? `/products/${item.handle}.js` : null;

        let badgeHtml = '',
          priceHtml = '',
          actionButton = '',
          wishlistBtn = '';

        if (!isArticle) {
          // Ürün Ayarları
          const currentPrice = Number(item.price);
          const comparePriceRaw = Number(item.compare_at_price || item.compare_at_price_max || 0);
          const isOnSale = comparePriceRaw > currentPrice && comparePriceRaw > 0;
          const variantId = item.variants && item.variants[0] ? item.variants[0].id : '';

          if (isOnSale) {
            badgeHtml = `<span class="absolute top-3 left-3 z-30 bg-secondary text-white text-[10px] px-2 py-1 uppercase tracking-widest font-medium">${translations.sale}</span>`;
          }

          priceHtml = `<div class="mt-2 flex items-center gap-2">
            ${
              isOnSale
                ? `<span class="text-gray-400 line-through text-[12px]">${formatMoney(comparePriceRaw)}</span>`
                : ''
            }
            <span class="text-primary text-[14px] font-medium">${formatMoney(item.price)}</span>
          </div>`;

          // Wishlist Butonu (Global Sistem)
          wishlistBtn = `
          <div class="absolute top-3 right-3 z-40">
            <button type="button" 
                    class="custom-wishlist-btn flex items-center justify-center w-9 h-9 bg-white/90 backdrop-blur-sm rounded-full shadow-sm hover:scale-110 transition-transform duration-300" 
                    data-product-id="${item.id}"
                    onclick="window.LuviaWishlist.toggle('${item.id}')">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"></path>
              </svg>
            </button>
          </div>`;

          // Add to Cart Butonu (Global Sistem)
          actionButton = `
          <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 hidden md:block z-30">
            <button type="button" 
                    onclick="window.handleGlobalAddToCart(event, '${variantId}')" 
                    class="w-full bg-primary text-white py-4 text-[11px] uppercase tracking-[0.2em] block text-center hover:bg-secondary transition-colors border-none cursor-pointer font-heading">
              ADD TO CART
            </button>
          </div>`;
        } else {
          // Makale Ayarları (Wishlist ve Add to Cart olmaz)
          badgeHtml = `<span class="absolute top-3 left-3 z-30 bg-black text-white text-[10px] px-2 py-1 tracking-widest uppercase italic shadow-sm">${translations.journal}</span>`;
          actionButton = `
          <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 hidden md:block z-20">
            <a href="${item.url}" class="w-full bg-black text-white py-4 text-[11px] uppercase tracking-[0.2em] block text-center hover:bg-secondary transition-colors font-heading">
              ${translations.readMore}
            </a>
          </div>`;
        }

        return `
        <div class="group flex flex-col h-full bg-white overflow-hidden relative animate-fadeIn transition-all" id="search-item-${item.id}">
          <div class="relative aspect-[3/4] overflow-hidden bg-custombg">
            ${badgeHtml}
            ${wishlistBtn}
            
            <a href="${item.url}" class="block h-full w-full">
              <img src="${mainImage}" alt="${item.title}" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy">
            </a>

            ${actionButton}
          </div>

          <div class="pt-4 pb-2 flex flex-col items-center px-3">
            <a href="${item.url}" class="text-primary font-light text-[14px] hover:text-secondary transition-colors uppercase text-center line-clamp-2 min-h-[40px] tracking-wider">
              ${item.title}
            </a>
            ${priceHtml}
          </div>
        </div>`;
      })
      .join('');

    // Sonuçlar render edildikten sonra Wishlist kalplerini doldur
    if (window.LuviaWishlist && typeof window.LuviaWishlist.initIcons === 'function') {
      window.LuviaWishlist.initIcons();
    }
  }
</script>

<style>
  .animate-fadeIn {
    animation: fadeIn 0.4s ease-out forwards;
  }
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .ssw-faveit i.ssw-icon-heart-o::before {
    content: '\e80a';
    font-family: 'sswfont' !important;
    font-style: normal;
    font-weight: normal;
    display: inline-block;
    text-decoration: inherit;
    width: 1em;
    margin-right: 0.2em;
    text-align: center;
    font-variant: normal;
    text-transform: none;
    line-height: 1em;
    margin-left: 0.2em;
    -webkit-font-smoothing: antialiased;
    color: var(--color-primary);
    font-size: 20px;
  }

  .ssw-faveit:hover i.ssw-icon-heart-o::before {
    content: '\e80b';
    color: var(--color-secondary);
  }
</style>
