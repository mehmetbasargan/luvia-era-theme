{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  /* color and background settings */
  #LuviaSection-{{ section.id }} {
    {% if section.settings.remove_bg %}
      background-color: transparent !important;
      background-image: none !important;
    {% elsif section.settings.use_custom_bg %}
      background-color: {{ section.settings.section_bg_color }} !important;
      background-image: none !important;
    {% endif %}
  }
{%- endstyle -%}

<section
  id="LuviaSection-{{ section.id }}"
  class="
    transition-colors duration-300 section-{{ section.id }}-padding
    {% unless section.settings.remove_bg or section.settings.use_custom_bg %}bg-custombg color-{{ section.settings.color_scheme }} gradient{% endunless %}
  "
>
  <div class="container mx-auto">
    {% for block in section.blocks %}
      <div
        class="flex flex-col {% if block.settings.image_placement == 'right' %}md:flex-row-reverse{% else %}md:flex-row{% endif %} items-center gap-12 md:gap-24 py-16 md:py-24"
        {{ block.shopify_attributes }}
      >
        {% comment %} Visual Area {% endcomment %}
        <div class="w-full md:w-1/2">
          <div class="relative aspect-[4/5] overflow-hidden bg-white shadow-sm border border-line">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 1000 }}"
                alt="{{ block.settings.image.alt | escape }}"
                loading="lazy"
                height="500"
                width="500"
                class="w-full h-full object-cover transition-transform duration-1000 hover:scale-105"
              >
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'w-full h-full opacity-10 bg-white' }}
            {% endif %}
          </div>
        </div>

        {% comment %} Text Area {% endcomment %}
        <div class="w-full md:w-1/2 text-left space-y-6 px-4 md:px-0">
          {% if block.settings.subheading != blank %}
            <span class="text-secondary uppercase tracking-[0.1em] text-[14px] block">
              {{ block.settings.subheading }}
            </span>
          {% endif %}

          <h2 class="text-secondary">
            {{ block.settings.title }}
          </h2>

          <div class="text-primary leading-relaxed">
            {{ block.settings.text }}
          </div>

          {% if block.settings.button_label != blank %}
            <a
              href="{{ block.settings.button_link | default: '#' }}"
              class="inline-block mt-4 px-10 py-4 bg-primary text-white text-[15px] uppercase tracking-[0.2em] hover:bg-secondary transition-colors duration-300"
              aria-label="{{ block.settings.button_label | default: 'Discover More' | escape }} - {{ block.settings.title | escape }}"
            >
              {{ block.settings.button_label }}
            </a>
          {% endif %}
        </div>
      </div>

      {% comment %} Bloklar arasına ince bir çizgi (Opsiyonel) {% endcomment %}
      {% unless forloop.last %}
        <div class="container mx-auto border-b border-line"></div>
      {% endunless %}
    {% endfor %}
  </div>
</section>

{% schema %}
{
  "name": "Image with Text Multi",
  "settings": [
    {
      "type": "header",
      "content": "Section Spacing Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    },
    {
      "type": "header",
      "content": "Background Design"
    },
    {
      "type": "checkbox",
      "id": "use_custom_bg",
      "label": "Use Custom Background Color",
      "default": false
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "remove_bg",
      "label": "Remove Background (Transparent)",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "image_block",
      "name": "Image & Text Row",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "select",
          "id": "image_placement",
          "label": "Image Placement",
          "options": [
            { "value": "left", "label": "Left" },
            { "value": "right", "label": "Right" }
          ],
          "default": "left"
        },
        {
          "type": "text",
          "id": "subheading",
          "label": "Sub-heading",
          "default": "Luvia Story"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Crafted with passion"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description",
          "default": "<p>Our jewelry is more than just an accessory. It is a reflection of your unique journey and timeless elegance.</p>"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button Label",
          "default": "Discover More"
        },
        {
          "type": "url",
          "id": "button_link",
          "label": "Button Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image with Text Multi",
      "blocks": [
        { "type": "image_block", "settings": { "image_placement": "left" } },
        { "type": "image_block", "settings": { "image_placement": "right" } },
        { "type": "image_block", "settings": { "image_placement": "left" } }
      ]
    }
  ]
}
{% endschema %}
