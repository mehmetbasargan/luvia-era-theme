{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  /* color and background settings */
  #LuviaSection-{{ section.id }} {
    {% if section.settings.remove_bg %}
      background-color: transparent !important;
      background-image: none !important;
    {% elsif section.settings.use_custom_bg %}
      background-color: {{ section.settings.section_bg_color }} !important;
      background-image: none !important;
    {% endif %}
  }
{%- endstyle -%}

<section
  id="LuviaSection-{{ section.id }}"
  class="
     transition-colors duration-300 section-{{ section.id }}-padding
    {% unless section.settings.remove_bg or section.settings.use_custom_bg %}bg-white color-{{ section.settings.color_scheme }} gradient{% endunless %}
  "
>
  <div class="container">
    <div class="mb-10 flex flex-col md:flex-row justify-between items-start">
      <div>
        <h3 class="uppercase tracking-widest">{{ section.settings.title }}</h3>
        <p class="text-primary mt-2">{{ section.settings.subtitle }}</p>
      </div>
      <div class="flex space-x-4 mt-5 md:mt-0">
        <div class="swiper-button-prev-custom cursor-pointer border border-primary p-2 hover:bg-primary hover:text-white transition">
          {% render 'icon-chevron-left' %}
        </div>
        <div class="swiper-button-next-custom cursor-pointer border border-primary p-2 hover:bg-primary hover:text-white transition">
          {% render 'icon-chevron-right' %}
        </div>
      </div>
    </div>

    <div class="swiper featuredSwiper px-4">
      <div class="swiper-wrapper">
        {% assign blog = blogs[section.settings.blog] %}
        {% for article in blog.articles limit: section.settings.post_limit %}
          <div class="swiper-slide">
            <div class="cursor-pointer">
              {% if article.image %}
                <div class="overflow-hidden aspect-[16/9] mb-6 rounded-sm">
                  <a href="{{ article.url }}" aria-label="Read article: {{ article.title | escape }}">
                    <img
                      src="{{ article.image | image_url: width: 600 }}"
                      height="400"
                      width="600"
                      class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                      alt="{{ article.title | escape }}"
                      loading="eager"
                    >
                  </a>
                </div>
              {% endif %}

              <div class="space-y-2">
                <span class="text-[13px] font-medium text-primary uppercase">
                  {{- article.published_at | date: '%b %d, %Y' -}}
                </span>

                <h5 class="uppercase hover:text-primary transition-colors max-w-[300px] min-h-[1rem] leading-[20px] text-lg">
                  {{ article.title }}
                </h5>

                <a
                  href="{{ article.url }}"
                  class="text-[12px] uppercase font-semibold tracking-widest hover:text-secondary transition-all flex items-center gap-1"
                >
                  {{ 'blog.read_article' | t }}
                  {% render 'icon-arrow-right' %}
                </a>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.featuredSwiper', {
      slidesPerView: 1.2,
      spaceBetween: 20,
      loop: true,
      autoplay: {
        delay: 5000,
      },
      navigation: {
        nextEl: '.swiper-button-next-custom',
        prevEl: '.swiper-button-prev-custom',
      },
      breakpoints: {
        640: { slidesPerView: 2.2 },
        1024: { slidesPerView: 3.2 },
      },
    });
  });
</script>

{% schema %}
{
  "name": "Featured Blog Carousel",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The Journal"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sub-heading",
      "default": "Discover the world of Luvia Era"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Select Blog"
    },
    {
      "type": "range",
      "id": "post_limit",
      "min": 3,
      "max": 9,
      "step": 1,
      "label": "Posts to show",
      "default": 6
    },
    {
      "type": "header",
      "content": "Section Spacing Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    },
    {
      "type": "header",
      "content": "Background Design"
    },
    {
      "type": "checkbox",
      "id": "use_custom_bg",
      "label": "Use Custom Background Color",
      "default": false
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "remove_bg",
      "label": "Remove Background (Transparent)",
      "default": false
    }
  ],
  "presets": [
    {
      "name": "Featured Blog Carousel",
      "settings": {
        "blog": "news"
      }
    }
  ]
}
{% endschema %}
