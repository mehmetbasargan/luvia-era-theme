{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  #LuviaSection-{{ section.id }} {
    {% if section.settings.remove_bg %}
      background-color: transparent !important;
    {% elsif section.settings.use_custom_bg %}
      background-color: {{ section.settings.section_bg_color }} !important;
    {% endif %}
  }

  .blog-swiper-{{ section.id }} {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .blog-swiper-{{ section.id }} .swiper-slide {
    height: auto;
  }

  .swiper-button-disabled {
    opacity: 0.3 !important;
    cursor: not-allowed !important;
  }
{%- endstyle -%}

<section id="LuviaSection-{{ section.id }}" class="transition-colors duration-300 section-{{ section.id }}-padding">
  <div class="container mx-auto px-4">
    {% comment %} Header Area {% endcomment %}
    <div class="mb-10 flex flex-col md:flex-row justify-between items-start">
      <div>
        <h2 class="text-2xl md:text-3xl font-bold">
          {{ section.settings.title | default: 'The Journal' }}
        </h2>
        <p class="text-primary mt-2 opacity-80">
          {{ section.settings.subtitle | default: 'Discover the world of Luvia Era' }}
        </p>
      </div>

      {% comment %} Navigation Buttons {% endcomment %}
      <div class="flex space-x-4 mt-5 md:mt-0">
        <button
          type="button"
          class="blog-prev-{{ section.id }} cursor-pointer border border-primary p-2 hover:bg-primary hover:text-white transition-all focus:outline-none"
          aria-label="Previous posts"
        >
          {% render 'icon-chevron-left' %}
        </button>
        <button
          type="button"
          class="blog-next-{{ section.id }} cursor-pointer border border-primary p-2 hover:bg-primary hover:text-white transition-all focus:outline-none"
          aria-label="Next posts"
        >
          {% render 'icon-chevron-right' %}
        </button>
      </div>
    </div>

    <div class="swiper blog-swiper-{{ section.id }}">
      <div class="swiper-wrapper">
        {%- assign blog = blogs[section.settings.blog] -%}

        {%- if blog != blank and blog.articles_count > 0 -%}
          {%- for article in blog.articles limit: section.settings.post_limit -%}
            <div class="swiper-slide h-full">
              <div class="group h-full flex flex-col">
                <div class="overflow-hidden aspect-[16/9] mb-6 rounded-sm bg-gray-100">
                  <a
                    href="{{ article.url }}"
                    class="block w-full h-full"
                    aria-label="{{ 'blog.read_article' | t | default: 'Read More' | escape }} - {{ article.title | escape }}"
                  >
                    {%- if article.image -%}
                      {{
                        article.image
                        | image_url: width: 800
                        | image_tag:
                          class: 'w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105',
                          loading: 'lazy',
                          widths: '400, 600, 800',
                          alt: article.title
                      }}
                    {%- else -%}
                      {{ 'image' | placeholder_svg_tag: 'w-full h-full opacity-20 grayscale' }}
                    {%- endif -%}
                  </a>
                </div>

                <div class="flex flex-col flex-grow space-y-3">
                  <span class="text-[12px] font-medium text-primary opacity-70 uppercase tracking-widest">
                    {{ article.published_at | date: '%b %d, %Y' }}
                  </span>

                  <h3 class="text-lg font-medium leading-tight group-hover:text-primary transition-colors">
                    <a href="{{ article.url }}">{{ article.title }}</a>
                  </h3>

                  <a
                    href="{{ article.url }}"
                    class="text-[12px] uppercase font-bold tracking-tighter hover:text-secondary transition-all flex items-center gap-2 mt-auto pt-4 border-t border-gray-100"
                  >
                    {{ 'blog.read_article' | t | default: 'Read More' }}
                    <span class="w-4">{% render 'icon-arrow-right' %}</span>
                  </a>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- else -%}
          {% comment %} Placeholder Content when no blog is selected {% endcomment %}
          {%- for i in (1..3) -%}
            <div class="swiper-slide h-full">
              <div class="group h-full flex flex-col opacity-60">
                <div class="aspect-[16/9] bg-gray-200 mb-6 rounded-sm">
                  {{
                    'lifestyle-'
                    | append: i
                    | placeholder_svg_tag: 'w-full h-full object-cover grayscale opacity-30'
                  }}
                </div>
                <div class="space-y-4">
                  <div class="h-3 w-24 bg-gray-200"></div>
                  <div class="h-6 w-full bg-gray-200"></div>
                  <div class="h-4 w-2/3 bg-gray-200"></div>
                </div>
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const initBlogSlider = () => {
      const selector = '.blog-swiper-{{ section.id }}';
      const container = document.querySelector(selector);
      if (!container) return;

      if (container.swiper) container.swiper.destroy(true, true);

      const articleCount = container.querySelectorAll('.swiper-slide').length;

      new Swiper(selector, {
        slidesPerView: 1.2,
        spaceBetween: 20,
        grabCursor: true,
        watchOverflow: true,
        loop: articleCount > 3,
        autoplay: {
          delay: 5000,
          disableOnInteraction: true,
          pauseOnMouseEnter: true,
        },
        navigation: {
          nextEl: '.blog-next-{{ section.id }}',
          prevEl: '.blog-prev-{{ section.id }}',
        },
        breakpoints: {
          640: {
            slidesPerView: 2.2,
            loop: articleCount > 2,
          },
          1024: {
            slidesPerView: 3,
            spaceBetween: 30,
            loop: articleCount > 3,
          },
        },
      });
    };

    document.addEventListener('DOMContentLoaded', initBlogSlider);
    document.addEventListener('shopify:section:load', initBlogSlider);
  })();
</script>

{% schema %}
{
  "name": "Featured Blog Carousel",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "The Journal" },
    { "type": "text", "id": "subtitle", "label": "Sub-heading", "default": "Discover the world of Luvia Era" },
    { "type": "blog", "id": "blog", "label": "Select Blog" },
    { "type": "range", "id": "post_limit", "min": 3, "max": 9, "step": 1, "label": "Posts to show", "default": 6 },
    { "type": "header", "content": "Section Spacing Settings" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    },
    { "type": "header", "content": "Background Design" },
    { "type": "checkbox", "id": "use_custom_bg", "label": "Use Custom Background Color", "default": false },
    { "type": "color", "id": "section_bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "checkbox", "id": "remove_bg", "label": "Remove Background", "default": false }
  ],
  "presets": [
    {
      "name": "Featured Blog Carousel",
      "settings": { "blog": "news" }
    }
  ]
}
{% endschema %}
