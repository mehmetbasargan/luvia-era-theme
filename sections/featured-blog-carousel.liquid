{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }
  

  #LuviaSection-{{ section.id }} {
    {% if section.settings.remove_bg %}
      background-color: transparent !important;
    {% elsif section.settings.use_custom_bg %}
      background-color: {{ section.settings.section_bg_color }} !important;
    {% endif %}
  }

  /* Slider Stabilite Ayarları */
  .blog-swiper-{{ section.id }} {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .blog-swiper-{{ section.id }} .swiper-slide {
    height: auto; /* Kartların aynı boyda olması için */
  }

  .swiper-button-disabled {
    opacity: 0.3 !important;
    cursor: not-allowed !important;
  }
{%- endstyle -%}

<section id="LuviaSection-{{ section.id }}" class="transition-colors duration-300 section-{{ section.id }}-padding">
  <div class="container mx-auto px-4">
    <div class="mb-10 flex flex-col md:flex-row justify-between items-start">
      <div>
        <h2 class="text-2xl md:text-3xl font-bold">{{ section.settings.title }}</h2>
        <p class="text-primary mt-2 opacity-80">{{ section.settings.subtitle }}</p>
      </div>
      <div class="flex space-x-4 mt-5 md:mt-0">
        <button
          type="button"
          class="blog-prev-{{ section.id }} cursor-pointer border border-primary p-2 hover:bg-primary hover:text-white transition-all"
          aria-label="Önceki yazılar"
        >
          {% render 'icon-chevron-left' %}
        </button>
        <button
          type="button"
          class="blog-next-{{ section.id }} cursor-pointer border border-primary p-2 hover:bg-primary hover:text-white transition-all"
          aria-label="Sonraki yazılar"
        >
          {% render 'icon-chevron-right' %}
        </button>
      </div>
    </div>


    <div class="swiper blog-swiper-{{ section.id }}">
      <div class="swiper-wrapper">
        {% assign blog = blogs[section.settings.blog] %}
        {% for article in blog.articles limit: section.settings.post_limit %}
          <div class="swiper-slide h-full">
            <div class="group h-full flex flex-col">
              {% if article.image %}
                <div class="overflow-hidden aspect-[16/9] mb-6 rounded-sm bg-gray-100">
                  <a
                    href="{{ article.url }}"
                    class="block w-full h-full"
                    aria-label="{{ article.title | escape }} - Makaleyi oku"
                  >
                    <img
                      src="{{ article.image | image_url: width: 800 }}"
                      height="450"
                      width="800"
                      class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                      alt="Makale görseli"
                      loading="lazy"
                    >
                  </a>
                </div>
              {% endif %}

              <div class="flex flex-col flex-grow space-y-3">
                <span class="text-[12px] font-medium text-primary opacity-70 uppercase tracking-widest">
                  {{ article.published_at | date: '%b %d, %Y' }}
                </span>

                <h3 class="text-lg font-medium leading-tight group-hover:text-primary transition-colors">
                  <a href="{{ article.url }}">{{ article.title }}</a>
                </h3>

                <a
                  href="{{ article.url }}"
                  class="text-[12px] uppercase font-bold tracking-tighter hover:text-secondary transition-all flex items-center gap-2 mt-auto pt-4"
                  aria-label="{{ article.title | escape }} - Makaleyi oku"
                >
                  {{ 'blog.read_article' | t }}
                  <span class="w-4">{% render 'icon-arrow-right' %}</span>
                </a>
              </div>
            </div>
          </div>
        {% else %}
          {% comment %} Blog seçilmediyse veya boşsa dummy içerik (Editör için) {% endcomment %}
          {% for i in (1..3) %}
            <div class="swiper-slide">
              <div class="aspect-[16/9] bg-gray-200 mb-4"></div>
              <div class="h-4 w-1/3 bg-gray-200 mb-2"></div>
              <div class="h-6 w-full bg-gray-200"></div>
            </div>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const initBlogSlider = () => {
      const selector = '.blog-swiper-{{ section.id }}';
      const container = document.querySelector(selector);
      if (!container) return;

      if (container.swiper) container.swiper.destroy(true, true);

      const articleCount = container.querySelectorAll('.swiper-slide').length;

      new Swiper(selector, {
        slidesPerView: 1.2,
        spaceBetween: 20,
        grabCursor: true,
        watchOverflow: true,
        // KRİTİK: Loop'u sadece yeterli içerik varsa ve mobilde değilken aktif et (Lighthouse dostu)
        loop: articleCount > 3,
        autoplay: {
          delay: 5000,
          disableOnInteraction: true,
          pauseOnMouseEnter: true,
        },
        navigation: {
          nextEl: '.blog-next-{{ section.id }}',
          prevEl: '.blog-prev-{{ section.id }}',
        },
        breakpoints: {
          640: {
            slidesPerView: 2.2,
            loop: articleCount > 2,
          },
          1024: {
            slidesPerView: 3,
            spaceBetween: 30,
            loop: articleCount > 3,
          },
        },
      });
    };

    document.addEventListener('DOMContentLoaded', initBlogSlider);
    document.addEventListener('shopify:section:load', initBlogSlider);
  })();
</script>

{% schema %}
{
  "name": "Featured Blog Carousel",
  "settings": [
    { "type": "text", "id": "title", "label": "Heading", "default": "The Journal" },
    { "type": "text", "id": "subtitle", "label": "Sub-heading", "default": "Discover the world of Luvia Era" },
    { "type": "blog", "id": "blog", "label": "Select Blog" },
    { "type": "range", "id": "post_limit", "min": 3, "max": 9, "step": 1, "label": "Posts to show", "default": 6 },
    { "type": "header", "content": "Section Spacing Settings" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    },
    { "type": "header", "content": "Background Design" },
    { "type": "checkbox", "id": "use_custom_bg", "label": "Use Custom Background Color", "default": false },
    { "type": "color", "id": "section_bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "checkbox", "id": "remove_bg", "label": "Remove Background", "default": false }
  ],
  "presets": [
    {
      "name": "Featured Blog Carousel",
      "settings": { "blog": "news" }
    }
  ]
}
{% endschema %}
