<section class="container featured-blog-slider py-32 overflow-hidden">
  <div class="container mb-10 flex flex-col md:flex-row justify-between items-start">
    <div>
      <h2 class="font-light uppercase tracking-widest">{{ section.settings.title }}</h2>
      <p class="text-primary mt-2">{{ section.settings.subtitle }}</p>
    </div>
    <div class="flex space-x-4 mt-5 md:mt-0">
      <div class="swiper-button-prev-custom cursor-pointer border border-primary p-2 hover:bg-primary hover:text-white transition">
        {% render 'icon-chevron-left' %}
      </div>
      <div class="swiper-button-next-custom cursor-pointer border border-primary p-2 hover:bg-primary hover:text-white transition">
        {% render 'icon-chevron-right' %}
      </div>
    </div>
  </div>

  <div class="container swiper featuredSwiper px-4">
    <div class="swiper-wrapper">
      {% assign blog = blogs[section.settings.blog] %}
      {% for article in blog.articles limit: section.settings.post_limit %}
        <div class="swiper-slide">
          <div class="cursor-pointer">
            {% if article.image %}
              <div class="overflow-hidden aspect-[16/9] mb-6 rounded-sm">
                <a href="{{ article.url }}">
                  <img
                    src="{{ article.image | image_url: width: 600 }}"
                    height="400"
                    width="600"
                    class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
                    alt="{{ article.title | escape }}"
                    loading="eager"
                  >
                </a>
              </div>
            {% endif %}

            <div class="space-y-2">
              <span class="text-[13px] font-medium text-primary uppercase">
                {{- article.published_at | date: '%b %d, %Y' -}}
              </span>

              <h6 class="font-medium uppercase hover:text-primary transition-colors max-w-[300px] min-h-[1rem] leading-[24px]">
                {{ article.title }}
              </h6>

              <a
                href="{{ article.url }}"
                class="text-[12px] uppercase font-semibold tracking-widest hover:text-secondary transition-all flex items-center gap-1"
              >
                {{ 'blog.read_article' | t }}
                {% render 'icon-arrow-right' %}
              </a>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.featuredSwiper', {
      slidesPerView: 1.2,
      spaceBetween: 20,
      loop: true,
      autoplay: {
        delay: 5000,
      },
      navigation: {
        nextEl: '.swiper-button-next-custom',
        prevEl: '.swiper-button-prev-custom',
      },
      breakpoints: {
        640: { slidesPerView: 2.2 },
        1024: { slidesPerView: 3.2 },
      },
    });
  });
</script>

{% schema %}
{
  "name": "Featured Blog Carousel",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "The Journal"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Sub-heading",
      "default": "Discover the world of Luvia Era"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Select Blog"
    },
    {
      "type": "range",
      "id": "post_limit",
      "min": 3,
      "max": 9,
      "step": 1,
      "label": "Posts to show",
      "default": 6
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "range",
      "id": "header_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Header Opacity Rate",
      "default": 100,
      "info": "Adjust the transparency level of the header section if applicable."
    }
  ],
  "presets": [
    {
      "name": "Featured Blog Carousel",
      "settings": {
        "blog": "news"
      }
    }
  ]
}
{% endschema %}
