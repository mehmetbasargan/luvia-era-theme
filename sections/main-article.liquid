<article class="max-w-[900px] mx-auto px-4 py-16">
  <header class="text-center mb-12">
    <span class="text-md uppercase tracking-widest text-primary">{{ blog.title }}</span>
    <h2 class="mt-4 mb-6 text-xl md:text-2xl">{{ article.title }}</h2>
    <div class="flex justify-center items-center space-x-4 text-primary">
      <span>{{ article.author }}</span>
      <span class="text-primary">•</span>
      <span>{{ article.published_at | date: '%d %b %Y' }}</span>
    </div>
  </header>

  {% if article.image %}
    {% comment %}
      Detay sayfasında görselin kesilmemesi için 'object-contain' ve soft bir arka plan ekledik.
      Böylece görsel içindeki tüm detaylar (yazılar, küçük objeler) tam boy görünür.
    {% endcomment %}
    <div class="aspect-video overflow-hidden mb-12 bg-[#fbfbfb] border border-line/5 flex items-center justify-center">
      <img
        src="{{ article.image | image_url: width: 1200 }}"
        {% comment %} Netlik için genişliği artırdık {% endcomment %}
        alt="{{ article.title | escape }}"
        loading="eager"
        width="100%"
        height="auto"
        class="w-full h-full object-contain"
        {% comment %} Kesilmeyi engelleyen asıl komut {% endcomment %}
      >
    </div>
  {% else %}
    {% comment %} Eğer detay sayfasında da görsel yoksa boş kalmasın diye yer tutucu (isteğe bağlı) {% endcomment %}
    <div class="aspect-video overflow-hidden mb-12 bg-gray-50 flex items-center justify-center opacity-20 border border-gray-500">
      {{ 'lifestyle-2' | placeholder_svg_tag: 'w-[70%] h-[70%]' }}
    </div>
  {% endif %}

  <div class="prose prose-lg max-w-none prose-headings:font-light prose-a:text-secondary flex flex-col gap-6">
    {{ article.content }}
  </div>

  <div class="mt-16 pt-8 border-t border-line flex flex-col md:flex-row md:justify-between justify-center items-center">
    <a
      href="{{ blog.url }}"
      class="text-sm font-medium hover:text-secondary mb-8 md:mb-0"
      aria-label="Back to {{ blog.title }}"
    >
      ← {{ 'blog.back_to_blog' | t }}
    </a>
    {%- render 'icon-sharing', share_title: article.title, share_permalink: article.url, share_image: article.image -%}
  </div>
</article>
