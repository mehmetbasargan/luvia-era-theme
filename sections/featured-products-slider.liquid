{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  #LuviaSection-{{ section.id }} {
    {% if section.settings.remove_bg %}
      background-color: transparent !important;
    {% elsif section.settings.use_custom_bg %}
      background-color: {{ section.settings.section_bg_color }} !important;
    {% endif %}
  }

  .featured-swiper-{{ section.id }} {
    width: 100%;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .featured-swiper-{{ section.id }}.swiper-initialized {
    opacity: 1;
  }
{%- endstyle -%}

<section id="LuviaSection-{{ section.id }}" class="section-{{ section.id }}-padding transition-colors duration-300">
  <div class="container mx-auto">
    {% comment %} Navigation & Header {% endcomment %}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 px-4 md:px-0">
      <div>
        <h2 class="text-secondary text-2xl md:text-3xl font-bold uppercase tracking-tight">
          {{ section.settings.section_title }}
        </h2>
        <p class="text-primary mt-2 opacity-70 italic">
          {{ section.settings.section_subtitle }}
        </p>
      </div>

      <div class="flex items-center gap-6 mt-6 md:mt-0">
        <div class="flex gap-2">
          <button class="swiper-prev-{{ section.id }} border border-primary p-2 hover:bg-primary hover:text-white transition-all cursor-pointer">
            {% render 'icon-chevron-left' %}
          </button>
          <button class="swiper-next-{{ section.id }} border border-primary p-2 hover:bg-primary hover:text-white transition-all cursor-pointer">
            {% render 'icon-chevron-right' %}
          </button>
        </div>
        {% if section.settings.button_url %}
          <a
            href="{{ section.settings.button_url }}"
            class="text-primary text-xs uppercase tracking-[0.2em] border-b border-gray-300 pb-1 hover:text-secondary hover:border-secondary transition-all"
          >
            {{ section.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>

    {% comment %} Swiper Container {% endcomment %}
    <div class="swiper featured-swiper-{{ section.id }} !overflow-visible px-4 md:px-0">
      <div class="swiper-wrapper">
        {%- if section.blocks.size > 0 -%}
          {% for block in section.blocks %}
            {%- assign product = all_products[block.settings.product] -%}
            <div class="swiper-slide" {{ block.shopify_attributes }}>
              {% comment %}
                İŞTE BURASI! Senin hazır product-card.liquid tasarımını çağırıyoruz.
                Eğer ürün seçilmemişse bile snippet'ın içindeki placeholder devreye girecek.
              {% endcomment %}
              {% render 'product-card', product: product %}
            </div>
          {% endfor %}
        {%- else -%}
          {% comment %} Hiç blok eklenmemişse 4 tane yer tutucu göster {% endcomment %}
          {%- for i in (1..4) -%}
            <div class="swiper-slide">
              {% render 'product-card', product: null %}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const initSlider = () => {
      const swiperSelector = '.featured-swiper-{{ section.id }}';
      const el = document.querySelector(swiperSelector);
      if (!el) return;

      if (el.swiper) el.swiper.destroy(true, true);

      const totalSlides = el.querySelectorAll('.swiper-slide').length;
      const desktopView = parseInt('{{ section.settings.slides_per_view | default: 4 }}');

      new Swiper(swiperSelector, {
        slidesPerView: 1.2,
        spaceBetween: 15,
        grabCursor: true,
        navigation: {
          nextEl: '.swiper-next-{{ section.id }}',
          prevEl: '.swiper-prev-{{ section.id }}',
        },
        breakpoints: {
          640: { slidesPerView: 2, spaceBetween: 20 },
          1024: { slidesPerView: desktopView, spaceBetween: 30 },
        },
        on: {
          init: function () {
            this.el.classList.add('swiper-initialized');
          },
        },
      });
    };

    document.addEventListener('DOMContentLoaded', initSlider);
    document.addEventListener('shopify:section:load', initSlider);
  })();
</script>

{% schema %}
{
  "name": "Featured Products Slider",
  "settings": [
    { "type": "text", "id": "section_title", "label": "Title", "default": "Featured Selection" },
    { "type": "text", "id": "section_subtitle", "label": "Subtitle", "default": "Handpicked for you" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "View All" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "number", "id": "slides_per_view", "label": "Slides per view (Desktop)", "default": 4 },
    { "type": "header", "content": "Spacing" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    { "type": "header", "content": "Design" },
    { "type": "checkbox", "id": "use_custom_bg", "label": "Use Custom Background Color", "default": false },
    { "type": "color", "id": "section_bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "checkbox", "id": "remove_bg", "label": "Remove Background", "default": false }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [{ "type": "product", "id": "product", "label": "Select Product" }]
    }
  ],
  "presets": [
    {
      "name": "Featured Products Slider",
      "blocks": [{ "type": "product" }, { "type": "product" }, { "type": "product" }, { "type": "product" }]
    }
  ]
}
{% endschema %}
