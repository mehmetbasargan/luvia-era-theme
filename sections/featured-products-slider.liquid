{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  /* color and background settings */
  #LuviaSection-{{ section.id }} {
    {% if section.settings.remove_bg %}
      background-color: transparent !important;
      background-image: none !important;
    {% elsif section.settings.use_custom_bg %}
      background-color: {{ section.settings.section_bg_color }} !important;
      background-image: none !important;
    {% endif %}
  }
{%- endstyle -%}

<section
  id="LuviaSection-{{ section.id }}"
  class="
    transition-colors duration-300 section-{{ section.id }}-padding
    {% unless section.settings.remove_bg or section.settings.use_custom_bg %}bg-white color-{{ section.settings.color_scheme }} gradient{% endunless %}
  "
>
  <div class="container mx-auto overflow-hidden">
    {% comment %} Header and Navigation Area {% endcomment %}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12">
      <div>
        <h2 class="text-secondary">
          {{ section.settings.section_title }}
        </h2>
        <p class="text-primary mt-2 -tracking-tight">
          {{ section.settings.section_subtitle }}
        </p>
      </div>

      <div class="flex items-center gap-6 mt-6 md:mt-0">
        {% comment %} Slider Navigation Buttons {% endcomment %}
        <div class="flex gap-4">
          <button
            class="swiper-prev-{{ section.id }} swiper-button-prev-custom cursor-pointer border border-primary p-2 hover:bg-primary hover:text-white transition"
            aria-label="Previous slide"
          >
            {% render 'icon-chevron-left' %}
          </button>
          <button
            class="swiper-next-{{ section.id }} swiper-button-next-custom cursor-pointer border border-primary p-2 hover:bg-primary hover:text-white transition"
            aria-label="Next slide"
          >
            {% render 'icon-chevron-right' %}
          </button>
        </div>

        {% if section.settings.button_url %}
          <a
            href="{{ section.settings.button_url }}"
            class="text-primary text-sm hover:text-secondary transition-all uppercase tracking-widest border-b border-line pb-1"
          >
            {{ section.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>

    {% comment %} Swiper Container {% endcomment %}
    <div class="swiper featured-swiper-{{ section.id }} !overflow-visible">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {%- assign product = all_products[block.settings.product] -%}
          {% if product != blank %}
            <div class="swiper-slide group relative flex flex-col h-full" {{ block.shopify_attributes }}>
              <div class="relative aspect-[3/4] overflow-hidden bg-white shadow-sm">
                {% if product.compare_at_price > product.price %}
                  <span class="absolute top-4 left-4 z-20 bg-primary rounded-sm text-white font-medium text-[11px] px-2 py-1 tracking-widest uppercase">
                    {{ 'products.product.on_sale' | t }}
                  </span>
                {% endif %}

                {% comment %} Wishlist Butonu {% endcomment %}
                <div class="absolute top-4 right-4 z-40">
                  <button
                    type="button"
                    class="custom-wishlist-btn w-9 h-9 flex items-center justify-center rounded-full shadow-md hover:scale-110 transition-transform cursor-pointer border-none bg-white"
                    data-product-id="{{ product.id }}"
                    onclick="if(window.LuviaWishlist) { LuviaWishlist.toggle('{{ product.id }}') }"
                  >
                    <svg
                      aria-hidden="true"
                      class="w-6 h-6 text-primary transition-all duration-300"
                      fill="none"
                      stroke="currentColor"
                      viewBox="0 0 24 24"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                    </svg>
                  </button>
                </div>

                {% comment %} Product Images (With Hover Effect) {% endcomment %}
                <a href="{{ product.url }}" class="block w-full h-full relative z-10">
                  <img
                    src="{{ product.featured_image | image_url: width: 600 }}"
                    class="w-full h-full object-cover absolute inset-0 transition-opacity duration-700 {% if product.images[1] %}group-hover:opacity-0{% endif %}"
                    height="auto"
                    width="600"
                    alt="{{ product.title }}"
                    loading="lazy"
                  >
                  {% if product.images[1] %}
                    <img
                      src="{{ product.images[1] | image_url: width: 600 }}"
                      class="w-full h-full object-cover absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700"
                      height="auto"
                      width="600"
                      alt="{{ product.title }}"
                      loading="lazy"
                    >
                  {% endif %}
                </a>

                {% comment %} Add to Cart Button {% endcomment %}
                <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 z-30">
                  <button
                    type="button"
                    onclick="handleFeaturedAddToCart(event, '{{ product.selected_or_first_available_variant.id }}')"
                    class="w-full bg-primary text-white py-4 text-[13px] uppercase tracking-[0.2em] hover:bg-secondary transition-colors cursor-pointer border-none font-medium"
                  >
                    {{ 'products.product.add_to_cart' | t }}
                  </button>
                </div>
              </div>

              {% comment %} Product Information {% endcomment %}
              <div class="mt-4 text-center">
                <a
                  href="{{ product.url }}"
                  class="text-primary uppercase tracking-wider block mb-1"
                >
                  <h6 class="">{{- product.title -}}</h6>
                </a>
                <div class="flex justify-center items-center gap-2">
                  {% if product.compare_at_price > product.price %}
                    <span class="text-gray-400 line-through text-[13px]">{{ product.compare_at_price | money }}</span>
                  {% endif %}
                  <span class="text-primary text-[14px] font-medium">{{ product.price | money }}</span>
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    new Swiper('.featured-swiper-{{ section.id }}', {
      slidesPerView: 2,
      spaceBetween: 20,
      loop: false,
      navigation: {
        nextEl: '.swiper-next-{{ section.id }}',
        prevEl: '.swiper-prev-{{ section.id }}',
      },
      breakpoints: {
        768: { slidesPerView: 3, spaceBetween: 24 },
        1024: { slidesPerView: 4, spaceBetween: 30 },
      },
    });
  });

  // Add to Cart Function (if not available globally)
  if (typeof handleFeaturedAddToCart !== 'function') {
    window.handleFeaturedAddToCart = function (e, variantId) {
      const btn = e.currentTarget;
      const originalText = btn.innerText;

      if (btn.classList.contains('loading')) return;
      btn.classList.add('loading');
      btn.innerText = '...';
      btn.disabled = true;

      fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id: variantId, quantity: 1 }),
      })
        .then((res) => res.json())
        .then((data) => {
          btn.innerText = 'ADDED';
          if (window.showToast) window.showToast('Added to cart', 'success');
          if (typeof openAndRefreshCart === 'function') openAndRefreshCart();

          setTimeout(() => {
            btn.innerText = originalText;
            btn.disabled = false;
            btn.classList.remove('loading');
          }, 2000);
        })
        .catch((err) => {
          console.error(err);
          btn.innerText = 'ERROR';
          setTimeout(() => {
            btn.innerText = originalText;
            btn.disabled = false;
            btn.classList.remove('loading');
          }, 2000);
        });
    };
  }
</script>

{% schema %}
{
  "name": "Featured Products Slider",
  "settings": [
    { "type": "text", "id": "section_title", "label": "Title", "default": "Featured Selection" },
    { "type": "text", "id": "section_subtitle", "label": "Subtitle", "default": "Handpicked for you" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "View All" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    {
      "type": "header",
      "content": "Section Spacing Settings"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    },
    {
      "type": "header",
      "content": "Background Design"
    },
    {
      "type": "checkbox",
      "id": "use_custom_bg",
      "label": "Use Custom Background Color",
      "default": false
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "remove_bg",
      "label": "Remove Background (Transparent)",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [{ "type": "product", "id": "product", "label": "Select Product" }]
    }
  ],
  "presets": [
    {
      "name": "Featured Products Slider",
      "blocks": [{ "type": "product" }, { "type": "product" }, { "type": "product" }, { "type": "product" }]
    }
  ]
}
{% endschema %}
