{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }
  #LuviaSection-{{ section.id }} {
    {% if section.settings.remove_bg %} background-color: transparent !important;
    {% elsif section.settings.use_custom_bg %} background-color: {{ section.settings.section_bg_color }} !important;
    {% endif %}
  }
  .featured-swiper-{{ section.id }} { width: 100%; opacity: 0; transition: opacity 0.3s ease; }
  .featured-swiper-{{ section.id }}.swiper-initialized { opacity: 1; }
  .swiper-button-disabled { opacity: 0.3 !important; cursor: not-allowed !important; pointer-events: none; }
{%- endstyle -%}

<section
  id="LuviaSection-{{ section.id }}"
  class="transition-colors duration-300 section-{{ section.id }}-padding {% unless section.settings.remove_bg or section.settings.use_custom_bg %}bg-white{% endunless %}"
>
  <div class="container mx-auto overflow-hidden">
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 px-4 md:px-0">
      <div>
        <h2 class="text-secondary text-2xl md:text-3xl font-bold">{{ section.settings.section_title }}</h2>
        <p class="text-primary mt-2 -tracking-tight opacity-80">{{ section.settings.section_subtitle }}</p>
      </div>
      <div class="flex items-center gap-6 mt-6 md:mt-0">
        <div class="flex gap-4">
          <button class="swiper-prev-{{ section.id }} cursor-pointer border border-primary p-2 hover:bg-primary hover:text-white transition-all duration-300">
            {% render 'icon-chevron-left' %}
          </button>
          <button class="swiper-next-{{ section.id }} cursor-pointer border border-primary p-2 hover:bg-primary hover:text-white transition-all duration-300">
            {% render 'icon-chevron-right' %}
          </button>
        </div>
        {% if section.settings.button_url -%}
          <a
            href="{{ section.settings.button_url }}"
            class="text-primary text-sm hover:text-secondary transition-all uppercase tracking-widest border-b border-line pb-1"
          >
            {{- section.settings.button_text -}}
          </a>
        {%- endif %}
      </div>
    </div>
    <div class="swiper featured-swiper-{{ section.id }} !overflow-visible px-4 md:px-0">
      <div class="swiper-wrapper">
        {% for block in section.blocks %}
          {%- assign product = all_products[block.settings.product] -%}
          <div class="swiper-slide h-auto" {{ block.shopify_attributes }}>
            {% render 'product-card', product: product %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const initSlider = () => {
      const swiperSelector = '.featured-swiper-{{ section.id }}';
      const container = document.querySelector(swiperSelector);
      if (!container) return;
      if (container.swiper) container.swiper.destroy(true, true);
      const totalSlides = container.querySelectorAll('.swiper-slide').length;
      const desktopView = parseInt('{{ section.settings.slides_per_view | default: 4 }}');
      new Swiper(swiperSelector, {
        slidesPerView: 2,
        spaceBetween: 15,
        grabCursor: true,
        watchOverflow: true,
        loop: totalSlides > 2,
        navigation: { nextEl: '.swiper-next-{{ section.id }}', prevEl: '.swiper-prev-{{ section.id }}' },
        breakpoints: {
          768: { slidesPerView: 3, spaceBetween: 20, loop: totalSlides > 3 },
          1024: { slidesPerView: desktopView, spaceBetween: 30, loop: totalSlides > desktopView },
        },
        on: {
          init: function () {
            this.el.classList.add('swiper-initialized');
          },
        },
      });
    };
    if (document.readyState === 'complete') initSlider();
    else window.addEventListener('load', initSlider);
    document.addEventListener('shopify:section:load', initSlider);
  })();

  // 🛒 SEPET VE DRAWER ÇÖZÜMÜ
  window.handleAddToCart = async function (e, variantId) {
    e.preventDefault();
    const btn = e.currentTarget;
    const originalText = btn.innerHTML;
    if (btn.classList.contains('loading')) return;

    btn.classList.add('loading');
    btn.innerText = '...';

    const sectionsToUpdate = ['cart-drawer', 'cart-icon-bubble', 'header'];

    try {
      const response = await fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: variantId,
          quantity: 1,
          sections: sectionsToUpdate.join(','),
        }),
      });

      const data = await response.json();

      // 1. Header & Bubble Güncelleme (Zorunlu)
      if (data.sections) {
        sectionsToUpdate.forEach((section) => {
          const html = data.sections[section];
          if (!html) return;
          const targetSelectors = {
            'cart-icon-bubble': '#cart-icon-bubble',
            'cart-drawer': 'cart-drawer',
            header: '#shopify-section-header',
          };
          const target = document.querySelector(targetSelectors[section]);
          if (target) {
            if (section === 'cart-drawer' && typeof target.renderContents === 'function') {
              target.renderContents(data); // Dawn Drawer tetikleyici
            } else {
              target.innerHTML = new DOMParser().parseFromString(html, 'text/html').body.innerHTML;
            }
          }
        });
      }

      // 2. Drawer'ı Aç
      const drawer = document.querySelector('cart-drawer');
      if (drawer && typeof drawer.open === 'function') {
        drawer.open();
      }

      btn.innerText = 'ADDED';
    } catch (err) {
      console.error('Cart Error:', err);
      btn.innerText = 'ERROR';
    } finally {
      setTimeout(() => {
        btn.innerHTML = originalText;
        btn.classList.remove('loading');
      }, 2000);
    }
  };

  // ❤️ WISHLIST ÇÖZÜMÜ
  document.addEventListener('click', function (e) {
    const wishlistBtn = e.target.closest('.custom-wishlist-btn');
    if (!wishlistBtn) return;

    e.preventDefault();
    const handle = wishlistBtn.getAttribute('data-product-handle');
    const productId = wishlistBtn.getAttribute('data-product-id');

    if (window.LuviaWishlist) {
      // Hem event, hem handle, hem ID göndererek tüm ihtimalleri kapsıyoruz
      window.LuviaWishlist.toggle(e, handle || productId);

      // Wishlist sayfasına gitmiyorsa, localStorage'ı manuel tetikleyelim
      const currentWishlist = JSON.parse(localStorage.getItem('luvia-wishlist') || '[]');
      if (!currentWishlist.includes(handle)) {
        currentWishlist.push(handle);
        localStorage.setItem('luvia-wishlist', JSON.stringify(currentWishlist));
      }
    }
  });
</script>

{% schema %}
{
  "name": "Featured Products Slider",
  "settings": [
    { "type": "text", "id": "section_title", "label": "Title", "default": "Featured Selection" },
    { "type": "text", "id": "section_subtitle", "label": "Subtitle", "default": "Handpicked for you" },
    { "type": "text", "id": "button_text", "label": "Button Text", "default": "View All" },
    { "type": "url", "id": "button_url", "label": "Button URL" },
    { "type": "number", "id": "slides_per_view", "label": "Slides per view (Desktop)", "default": 4 },
    { "type": "header", "content": "Section Spacing Settings" },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    },
    { "type": "header", "content": "Background Design" },
    { "type": "checkbox", "id": "use_custom_bg", "label": "Use Custom Background Color", "default": false },
    { "type": "color", "id": "section_bg_color", "label": "Background Color", "default": "#ffffff" },
    { "type": "checkbox", "id": "remove_bg", "label": "Remove Background", "default": false }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [{ "type": "product", "id": "product", "label": "Select Product" }]
    }
  ],
  "presets": [
    {
      "name": "Featured Products Slider",
      "blocks": [{ "type": "product" }, { "type": "product" }, { "type": "product" }, { "type": "product" }]
    }
  ]
}
{% endschema %}
