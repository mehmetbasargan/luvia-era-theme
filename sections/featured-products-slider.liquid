{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  #LuviaSection-{{ section.id }} {
    {% if section.settings.remove_bg %}
      background-color: transparent !important;
    {% elsif section.settings.use_custom_bg %}
      background-color: {{ section.settings.section_bg_color }} !important;
    {% endif %}
  }

  .featured-swiper-{{ section.id }} {
    width: 100%;
    opacity: 0;
    transition: opacity 0.5s ease;
  }

  .featured-swiper-{{ section.id }}.swiper-initialized {
    opacity: 1;
  }
{%- endstyle -%}

<section
  id="LuviaSection-{{ section.id }}"
  class="transition-colors duration-300 section-{{ section.id }}-padding {% unless section.settings.remove_bg or section.settings.use_custom_bg %}bg-white{% endunless %}"
>
  {% comment %} SENİN ORİJİNAL CONTAINER YAPIN {% endcomment %}
  <div class="container mx-auto overflow-hidden">
    {% comment %} Header and Navigation {% endcomment %}
    <div class="flex flex-col md:flex-row justify-between items-start md:items-end mb-12 px-4 md:px-0">
      <div>
        <h2 class="text-secondary text-2xl md:text-3xl font-bold uppercase tracking-tight">
          {{ section.settings.section_title }}
        </h2>
        <p class="text-primary mt-2 opacity-80 italic">
          {{ section.settings.section_subtitle }}
        </p>
      </div>

      <div class="flex items-center gap-6 mt-6 md:mt-0">
        <div class="flex gap-4">
          <button class="swiper-prev-{{ section.id }} border border-primary p-2 hover:bg-primary hover:text-white transition-all cursor-pointer">
            {% render 'icon-chevron-left' %}
          </button>
          <button class="swiper-next-{{ section.id }} border border-primary p-2 hover:bg-primary hover:text-white transition-all cursor-pointer">
            {% render 'icon-chevron-right' %}
          </button>
        </div>

        {% if section.settings.button_url %}
          <a
            href="{{ section.settings.button_url }}"
            class="text-primary text-sm uppercase tracking-widest border-b border-gray-200 pb-1 hover:border-primary transition-all"
          >
            {{ section.settings.button_text }}
          </a>
        {% endif %}
      </div>
    </div>

    {% comment %} Swiper Container {% endcomment %}
    <div class="swiper featured-swiper-{{ section.id }} !overflow-visible px-4 md:px-0">
      <div class="swiper-wrapper flex items-stretch">
        {%- if section.blocks.size > 0 -%}
          {% for block in section.blocks %}
            {%- assign product_handle = block.settings.product -%}
            {%- assign product = all_products[product_handle] -%}

            <div class="swiper-slide h-auto" {{ block.shopify_attributes }}>
              {% comment %}
                Product değişkeni boş olsa bile product-card.liquid
                dosyan içindeki 'else' (yer tutucu) kısmını tetikler.
              {% endcomment %}
              {% render 'product-card', product: product %}
            </div>
          {% endfor %}
        {%- else -%}
          {% comment %} Hiç blok yoksa test için 4 adet şık yer tutucu basar {% endcomment %}
          {%- for i in (1..4) -%}
            <div class="swiper-slide h-auto">
              {% render 'product-card', product: null %}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<script>
  (function () {
    const initSlider = () => {
      const swiperSelector = '.featured-swiper-{{ section.id }}';
      const container = document.querySelector(swiperSelector);
      if (!container || typeof Swiper === 'undefined') return;

      if (container.swiper) container.swiper.destroy(true, true);

      const totalSlides = container.querySelectorAll('.swiper-slide').length;
      const desktopView = parseInt('{{ section.settings.slides_per_view | default: 4 }}');

      new Swiper(swiperSelector, {
        slidesPerView: 1.2,
        spaceBetween: 15,
        grabCursor: true,
        watchOverflow: true,
        navigation: {
          nextEl: '.swiper-next-{{ section.id }}',
          prevEl: '.swiper-prev-{{ section.id }}',
        },
        breakpoints: {
          768: {
            slidesPerView: 3,
            spaceBetween: 20,
          },
          1024: {
            slidesPerView: desktopView,
            spaceBetween: 30,
          },
        },
        on: {
          init: function () {
            this.el.classList.add('swiper-initialized');
          },
        },
      });
    };

    document.addEventListener('DOMContentLoaded', initSlider);
    document.addEventListener('shopify:section:load', initSlider);
    // Editor için garantiye alalım
    window.addEventListener('load', initSlider);
  })();
</script>
