{% style %}
  .product-recommendations-container {
    padding: 4rem 0;
  }

  .recommendation-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
    margin-top: 2rem;
  }

  @media screen and (min-width: 750px) {
    .recommendation-grid {
      grid-template-columns: repeat(var(--products-to-show, 4), 1fr);
    }
  }
{% endstyle %}

<div
  class="product-recommendations-container page-width"
  data-products-to-show="{{ section.settings.products_to_show }}"
  data-product-id="{{ product.id }}"
>
  <h2 class="text-center text-2xl md:text-3xl font-normal text-primary mb-8">
    {{ section.settings.heading | escape }}
  </h2>

  <div id="product-recommendations-{{ section.id }}" class="recommendation-grid">
    <!-- Recommendations will be loaded here -->
  </div>
</div>

<script>
  const loadProductRecommendations = () => {
    const recommendationsContainer = document.getElementById('product-recommendations-{{ section.id }}');

    if (!recommendationsContainer) return;

    const container = recommendationsContainer.closest('.product-recommendations-container');
    const productsToShow = container.dataset.productsToShow || 4;
    const productId = container.dataset.productId || '{{ product.id }}';

    const requestUrl = `${Shopify.routes.root}recommendations/products.json?product_id=${productId}&limit=${productsToShow}&intent=complementary`;

    fetch(requestUrl)
      .then((response) => response.json())
      .then(({ products }) => {
        if (products.length === 0) {
          recommendationsContainer.innerHTML = '<p class="text-center text-secondary">No recommendations found.</p>';
          return;
        }

        // Set CSS variable for grid columns
        container.style.setProperty('--products-to-show', productsToShow);

        recommendationsContainer.innerHTML = products
          .map(
            (product) => `
          <div class="product-card">
            <a href="${product.url}" class="block group">
              <div class="relative aspect-[3/4] overflow-hidden bg-custombg mb-4">
                <img src="${product.featured_image}" 
                     alt="${product.title}" 
                     class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
                     loading="lazy"
                     width="400"
                     height="533">
              </div>
              <div class="text-center">
                <h3 class="text-sm uppercase tracking-wider text-primary line-clamp-1 font-normal mb-1">
                  ${product.title}
                </h3>
                <p class="text-secondary font-medium text-sm">
                  ${new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(product.price / 100)}
                </p>
              </div>
            </a>
          </div>
        `
          )
          .join('');
      })
      .catch((error) => {
        console.error('Error loading product recommendations:', error);
        recommendationsContainer.innerHTML =
          '<p class="text-center text-secondary">Unable to load recommendations.</p>';
      });
  };

  // Load recommendations when the DOM is ready
  document.addEventListener('DOMContentLoaded', loadProductRecommendations);
</script>

{% schema %}
{
  "name": "Product Recommendations",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 10,
      "step": 1,
      "label": "Maximum products to show",
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations",
      "settings": {
        "heading": "You May Also Like",
        "products_to_show": 4
      }
    }
  ]
}
{% endschema %}
