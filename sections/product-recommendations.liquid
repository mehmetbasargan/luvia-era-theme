<div
  class="product-recommendations"
  data-url="{{ routes.product_recommendations_url }}?section_id={{ section.id }}&product_id={{ product.id }}&limit={{ section.settings.products_to_show }}"
>
  {% if recommendations.performed and recommendations.products_count > 0 %}
    <div class="container mx-auto px-4 py-12">
      <h5 class="text-primary mb-8 uppercase text-center border-b border-line pb-2 font-light tracking-widest">
        {{ section.settings.heading }}
      </h5>

      <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
        {% for recommendation in recommendations.products %}
          <div class="product-card group relative flex flex-col h-full bg-white transition-all duration-500">
            <div class="relative aspect-[3/4] overflow-hidden bg-custombg">
              {% if recommendation.compare_at_price > recommendation.price %}
                <span class="absolute top-3 left-3 z-20 bg-secondary text-white text-[13px] px-2 py-1 uppercase tracking-tighter font-medium">
                  {{ 'products.product.on_sale' | t | default: 'SALE' }}
                </span>
              {% endif %}

              <div class="absolute top-3 right-3 z-20">
                <button
                  type="button"
                  class="custom-wishlist-btn w-9 h-9 flex items-center justify-center bg-white rounded-full shadow-sm hover:scale-110 transition-transform duration-300"
                  data-product-id="{{ recommendation.id }}"
                  onclick="window.LuviaWishlist.toggle('{{ recommendation.id }}')"
                >
                  <svg
                    class="w-4 h-4 transition-colors duration-300"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"></path>
                  </svg>
                </button>
              </div>

              <a href="{{ recommendation.url }}" class="block h-full w-full">
                <img
                  src="{{ recommendation.featured_image | image_url: width: 600 }}"
                  alt="{{ recommendation.title }}"
                  width=""
                  height=""
                  class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                  loading="lazy"
                >
              </a>

              <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 hidden md:block z-30">
                <button
                  type="button"
                  onclick="handleFeaturedAddToCart(event, '{{ recommendation.first_available_variant.id }}')"
                  class="w-full bg-primary text-white py-4 text-[11px] uppercase tracking-[0.2em] block text-center hover:bg-secondary transition-colors border-none cursor-pointer"
                >
                  {{ 'products.product.add_to_cart' | t }}
                </button>
              </div>
            </div>

            <div class="pt-4 pb-2 flex flex-col items-center px-3 text-center">
              <h3 class="text-primary font-light text-[13px] hover:text-secondary transition-colors uppercase line-clamp-2 min-h-[36px] tracking-wider">
                <a href="{{ recommendation.url }}">{{ recommendation.title }}</a>
              </h3>
              <div class="mt-2 flex items-center justify-center gap-2">
                {% if recommendation.compare_at_price > recommendation.price %}
                  <span class="text-gray-400 line-through text-[13px]">
                    {{- recommendation.compare_at_price | money -}}
                  </span>
                {% endif %}
                <span class="text-primary text-[13px] font-medium tracking-tight">
                  {{- recommendation.price | money -}}
                </span>
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
</div>

{% javascript %}
  const handleIntersection = (entries, observer) => {
    if (!entries[0].isIntersecting) return;
    observer.unobserve(entries[0].target);

    const url = entries[0].target.dataset.url;

    fetch(url)
      .then((response) => response.text())
      .then((html) => {
        const div = document.createElement('div');
        div.innerHTML = html;
        const recommendations = div.querySelector('.product-recommendations');

        if (recommendations && recommendations.innerHTML.trim().length > 0) {
          entries[0].target.innerHTML = recommendations.innerHTML;

          // Kartlar yüklendikten sonra Wishlist ikonlarını kontrol et (Global JS kullanıyoruz)
          if (window.LuviaWishlist && typeof window.LuviaWishlist.initIcons === 'function') {
            window.LuviaWishlist.initIcons();
          }
        }
      })
      .catch((e) => console.error(e));
  };

  const observer = new IntersectionObserver(handleIntersection, { rootMargin: '0px 0px 200px 0px' });
  const target = document.querySelector('.product-recommendations');
  if (target) observer.observe(target);
{% endjavascript %}

{% schema %}
{
  "name": "Product Recommendations",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You May Also Like"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    }
  ],
  "presets": [
    {
      "name": "Product Recommendations"
    }
  ]
}
{% endschema %}
