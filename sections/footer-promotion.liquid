{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }

  /* color and background settings */
  #LuviaSection-{{ section.id }} {
    {% if section.settings.remove_bg %}
      background-color: transparent !important;
      background-image: none !important;
    {% elsif section.settings.use_custom_bg %}
      background-color: {{ section.settings.section_bg_color }} !important;
      background-image: none !important;
    {% endif %}
  }
{%- endstyle -%}

<section
  id="LuviaSection-{{ section.id }}"
  class="
    transition-colors duration-300 section-{{ section.id }}-padding
    {% unless section.settings.remove_bg or section.settings.use_custom_bg %}bg-white color-{{ section.settings.color_scheme }} gradient{% endunless %}
  "
>
  <div class="container mx-auto">
    {% comment %} Heading {% endcomment %}
    {% if section.settings.heading != blank %}
      <div class="text-center mb-12">
        <h3 class="text-secondary uppercase tracking-[0.1em]">
          {{ section.settings.heading }}
        </h3>
        <div class="h-[1px] w-20 bg-secondary mx-auto mt-4"></div>
      </div>
    {% endif %}

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.link }}"
          class="group relative block overflow-hidden aspect-square border border-line"
          {{ block.shopify_attributes }}
        >
          {% comment %} Image {% endcomment %}
          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.title }}"
              height="auto"
              width="800"
              class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
              loading="lazy"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'w-full h-full bg-line/10' }}
          {% endif %}

          {% comment %}
            Dynamic Overlay Layer
            Opacity value directly from block settings.
          {% endcomment %}
          {%- assign overlay_opacity = block.settings.overlay_opacity | divided_by: 100.0 -%}
          <div
            class="absolute inset-0 bg-black transition-all duration-500 z-10 flex items-center justify-center group-hover:bg-opacity-60"
            style="background-color: rgba(0,0,0, {{ overlay_opacity }});"
          >
            {% comment %} Text Area {% endcomment %}
            <div class="text-center px-4 relative z-20">
              <h3 class="text-white text-[13px] uppercase tracking-[0.3em] leading-snug">
                {{ block.settings.title }}
              </h3>
              <div
                class="h-[1px] w-0 group-hover:w-full bg-white mx-auto mt-2 transition-all duration-500 ease-in-out"
              ></div>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Footer Promotion",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Curated Collections"
    },
    {
      "type": "header",
      "content": "Section Spacing Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    },
    {
      "type": "header",
      "content": "Background Design"
    },
    {
      "type": "checkbox",
      "id": "use_custom_bg",
      "label": "Use Custom Background Color",
      "default": false
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "remove_bg",
      "label": "Remove Background (Transparent)",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "promotion",
      "name": "Promotion Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Promotion Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "New Arrivals"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 80,
          "step": 10,
          "unit": "%",
          "label": "Overlay Opacity",
          "default": 30
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer Promotion",
      "blocks": [
        { "type": "promotion", "settings": { "title": "Dresses", "overlay_opacity": 30 } },
        { "type": "promotion", "settings": { "title": "Accessories", "overlay_opacity": 30 } },
        { "type": "promotion", "settings": { "title": "Best Sellers", "overlay_opacity": 30 } },
        { "type": "promotion", "settings": { "title": "Final Sale", "overlay_opacity": 30 } }
      ]
    }
  ]
}
{% endschema %}
