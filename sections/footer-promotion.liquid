<section class="bg-custombg py-16 border-t border-line">
  <div class="container mx-auto px-4">
    {% comment %} Başlık {% endcomment %}
    {% if section.settings.heading != blank %}
      <div class="text-center mb-12">
        <h2 class="text-secondary font-light uppercase tracking-[0.2em]">
          {{ section.settings.heading }}
        </h2>
        <div class="h-[1px] w-20 bg-secondary mx-auto mt-4"></div>
      </div>
    {% endif %}

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.link }}"
          class="group relative block overflow-hidden aspect-square border border-line"
          {{ block.shopify_attributes }}
        >
          {% comment %} Görsel {% endcomment %}
          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.title }}"
              height="auto"
              width="800"
              class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
              loading="lazy"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'w-full h-full bg-line/10' }}
          {% endif %}

          {% comment %}
            🛠️ Dinamik Overlay Layer
            Opacity değerini doğrudan block ayarlarından alıyoruz.
          {% endcomment %}
          {%- assign overlay_opacity = block.settings.overlay_opacity | divided_by: 100.0 -%}
          <div
            class="absolute inset-0 bg-black transition-all duration-500 z-10 flex items-center justify-center group-hover:bg-opacity-60"
            style="background-color: rgba(0,0,0, {{ overlay_opacity }});"
          >
            {% comment %} Metin Alanı {% endcomment %}
            <div class="text-center px-4 relative z-20">
              <h3 class="text-white text-[13px] uppercase tracking-[0.3em] font-light leading-snug">
                {{ block.settings.title }}
              </h3>
              <div
                class="h-[1px] w-0 group-hover:w-full bg-white mx-auto mt-2 transition-all duration-500 ease-in-out"
              ></div>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Footer Promotion",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Curated Collections"
    }
  ],
  "blocks": [
    {
      "type": "promotion",
      "name": "Promotion Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Promotion Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "New Arrivals"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        },
        {
          "type": "range",
          "id": "overlay_opacity",
          "min": 0,
          "max": 80,
          "step": 10,
          "unit": "%",
          "label": "Overlay Opacity",
          "default": 30
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer Promotion",
      "blocks": [
        { "type": "promotion", "settings": { "title": "Dresses", "overlay_opacity": 30 } },
        { "type": "promotion", "settings": { "title": "Accessories", "overlay_opacity": 30 } },
        { "type": "promotion", "settings": { "title": "Best Sellers", "overlay_opacity": 30 } },
        { "type": "promotion", "settings": { "title": "Final Sale", "overlay_opacity": 30 } }
      ]
    }
  ]
}
{% endschema %}
