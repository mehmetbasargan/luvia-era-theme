<section class="bg-custombg py-16 border-t border-line">
  <div class="container mx-auto px-4">
    {% comment %} Başlık (Luvia Tarzı Minimal) {% endcomment %}
    <div class="text-center mb-12">
      <h2 class="text-primary font-light uppercase tracking-[0.4em] text-[13px] opacity-70">
        {{ section.settings.heading | default: 'Explore the Collections' }}
      </h2>
      <div class="h-[1px] w-12 bg-secondary/50 mx-auto mt-4"></div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
      {% for block in section.blocks %}
        <a
          href="{{ block.settings.link }}"
          class="group relative block overflow-hidden aspect-square border border-line/20"
          {{ block.shopify_attributes }}
        >
          {% comment %} Görsel {% endcomment %}
          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="{{ block.settings.title }}"
              height="auto"
              width="800"
              class="w-full h-full object-cover transition-transform duration-1000 group-hover:scale-105"
              loading="lazy"
            >
          {% else %}
            {{ 'image' | placeholder_svg_tag: 'w-full h-full bg-line/10' }}
          {% endif %}

          {% comment %}
            🛠️ Dinamik Overlay Layer (Daima Okunabilirlik İçin)
            bg-black/30: Sabit karartma (Açık renk görseller için koruma)
            group-hover:bg-black/50: Üzerine gelince daha fazla karartma (Kontrast artırma)
          {% endcomment %}
          <div class="absolute inset-0 bg-black/30 group-hover:bg-black/50 transition-colors duration-500 z-10 flex items-center justify-center">
            {% comment %} Metin ve Alt Çizgi Efekti {% endcomment %}
            <div class="text-center px-4">
              <h3 class="text-white text-[12px] md:text-[13px] uppercase tracking-[0.3em] font-light leading-snug">
                {{ block.settings.title }}
              </h3>
              {% comment %} İnce, zarif hover çizgisi {% endcomment %}
              <div
                class="h-[1px] w-0 group-hover:w-full bg-white mx-auto mt-2 transition-all duration-500 ease-in-out opacity-70"
              ></div>
            </div>
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Footer Promotion",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Curated Collections"
    }
  ],
  "blocks": [
    {
      "type": "promotion",
      "name": "Promotion Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Promotion Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "New Arrivals"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer Promotion",
      "blocks": [
        { "type": "promotion", "settings": { "title": "Dresses" } },
        { "type": "promotion", "settings": { "title": "Accessories" } },
        { "type": "promotion", "settings": { "title": "Best Sellers" } },
        { "type": "promotion", "settings": { "title": "Final Sale" } }
      ]
    }
  ]
}
{% endschema %}
