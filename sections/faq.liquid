{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Akordeon Ana Kapsayıcı */
  .accordion-content {
    max-height: 0;
    overflow: hidden;
    /* Pürüzsüzlük anahtarı: Süre ve Bezier eğrisi */
    transition: max-height 0.6s cubic-bezier(0.4, 0, 0.2, 1), opacity 0.5s ease;
    opacity: 0;
  }

  /* Aktif olduğunda yazı yavaşça belirsin */
  .accordion-item.active .accordion-content {
    opacity: 1;
  }

  /* İçerik Yazısı: Padding'i buraya veriyoruz ki yükseklik hesaplanırken takılmasın */
  .accordion-inner {
    padding-top: 0.5rem;
    padding-bottom: 2rem;
  }

  /* İkon Animasyonu */
  .icon-plus { transition: transform 0.5s ease; }
  .accordion-item.active .icon-plus { transform: rotate(45deg); color: #000; } /* Artı işaretini çarpıya çevirir */
{%- endstyle -%}

<section class="section-{{ section.id }}-padding bg-white">
  <div class="container mx-auto px-4 md:px-10 lg:px-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-start">
      <div class="relative aspect-[4/5] overflow-hidden bg-custombg animate-fadeIn sticky top-32">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 1000 }}"
            loading="lazy"
            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-1000"
          >
        {% else %}
          <div class="w-full h-full opacity-30 p-20">
            {{ 'lifestyle-1' | placeholder_svg_tag: 'w-full h-full object-cover' }}
          </div>
        {% endif %}
      </div>

      <div class="flex flex-col space-y-8 animate-fadeIn">
        <h2 class="text-secondary text-2xl md:text-3xl font-light uppercase tracking-[0.2em]">
          {{ section.settings.title }}
        </h2>

        <div class="accordion-wrapper border-t border-line">
          {% for block in section.blocks %}
            <div class="accordion-item border-b border-line" {{ block.shopify_attributes }}>
              <button
                type="button"
                class="w-full flex items-center justify-between py-6 text-left group"
                onclick="toggleAccordion(this)"
              >
                <span class="text-primary text-[13px] md:text-[14px] uppercase tracking-[0.15em] font-medium transition-colors group-hover:text-secondary">
                  {{ block.settings.question }}
                </span>
                <span class="icon-plus text-secondary">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M12 6v12m6-6H6"></path>
                  </svg>
                </span>
              </button>

              <div class="accordion-content">
                <div class="accordion-inner text-primary/70 leading-relaxed text-[14px] font-light md:pr-10 italic">
                  {{ block.settings.answer }}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function toggleAccordion(button) {
    const currentItem = button.parentElement;
    const content = currentItem.querySelector('.accordion-content');
    const allItems = document.querySelectorAll('.accordion-item');

    // 1. Diğerlerini kapat (Daha profesyonel bir akış için)
    allItems.forEach((item) => {
      if (item !== currentItem && item.classList.contains('active')) {
        item.classList.remove('active');
        item.querySelector('.accordion-content').style.maxHeight = '0px';
      }
    });

    // 2. Mevcut olanı aç/kapat
    const isActive = currentItem.classList.toggle('active');

    if (isActive) {
      // scrollHeight ile gerçek yüksekliği tam hesaplayıp veriyoruz
      content.style.maxHeight = content.scrollHeight + 'px';
    } else {
      content.style.maxHeight = '0px';
    }
  }
</script>
