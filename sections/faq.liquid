{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  /* Akordeon Mantığı */
  .accordion-content {
    display: grid;
    grid-template-rows: 0fr; /* Kapalıyken 0 satır yüksekliği */
    transition: grid-template-rows 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    opacity: 0;
  }

  .accordion-item.active .accordion-content {
    grid-template-rows: 1fr; /* Açıldığında içeriğin kendi yüksekliği kadar */
    opacity: 1;
  }

  .accordion-inner {
    overflow: hidden; /* Taşmayı önler */
  }

  /* İkon Animasyonu */
  .icon-plus {
    transition: transform 0.4s ease;
  }
  .accordion-item.active .icon-plus {
    transform: rotate(45deg);
  }
{%- endstyle -%}

<section class="section-{{ section.id }}-padding bg-white">
  <div class="container mx-auto px-4 md:px-10 lg:px-20">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-24 items-start">
      <div class="relative aspect-[4/5] overflow-hidden bg-custombg animate-fadeIn">
        {% if section.settings.image != blank %}
          <img
            src="{{ section.settings.image | image_url: width: 1000 }}"
            loading="lazy"
            height="100%"
            width="100%"
            class="w-full h-full object-cover grayscale hover:grayscale-0 transition-all duration-1000"
          >
        {% else %}
          <div class="w-full h-full opacity-30 p-20">
            {{ 'lifestyle-2' | placeholder_svg_tag: 'w-full h-full object-cover' }}
          </div>
        {% endif %}
      </div>

      <div class="flex flex-col space-y-8 animate-fadeIn">
        <h2 class="text-secondary text-2xl md:text-3xl font-light uppercase tracking-[0.2em]">
          {{ section.settings.title }}
        </h2>

        <div class="accordion-wrapper border-t border-line">
          {% for block in section.blocks %}
            <div class="accordion-item border-b border-line" {{ block.shopify_attributes }}>
              <button
                type="button"
                class="w-full flex items-center justify-between py-6 text-left group"
                onclick="toggleFAQ(this)"
              >
                <span class="text-primary text-[13px] md:text-[14px] uppercase tracking-[0.15em] font-medium transition-colors group-hover:text-secondary">
                  {{ block.settings.question }}
                </span>
                <span class="icon-plus text-secondary">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.2" d="M12 6v12m6-6H6"></path>
                  </svg>
                </span>
              </button>

              <div class="accordion-content">
                <div class="accordion-inner">
                  <div class="pb-6 text-primary/70 leading-relaxed text-[14px] font-light md:pr-10 italic">
                    {{ block.settings.answer }}
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function toggleFAQ(button) {
    const currentItem = button.parentElement;
    const allItems = currentItem.closest('.accordion-wrapper').querySelectorAll('.accordion-item');
    const isActive = currentItem.classList.contains('active');

    // 1. Tüm açık olanları kapat (Süzülerek kapanırlar)
    allItems.forEach((item) => {
      item.classList.remove('active');
    });

    // 2. Eğer tıklandığında zaten aktif değilse aç (Süzülerek açılır)
    if (!isActive) {
      currentItem.classList.add('active');
    }
  }
</script>

{% schema %}
{
  "name": "FAQ Accordion",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "FAQ Image"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "question",
      "name": "Question",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "What is your shipping policy?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>We offer free express shipping on all orders over $150.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "FAQ Accordion",
      "blocks": [{ "type": "question" }, { "type": "question" }]
    }
  ]
}
{% endschema %}
