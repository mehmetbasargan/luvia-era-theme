<div class="login-wrapper py-[{{ section.settings.padding_top }}px] pb-[{{ section.settings.padding_bottom }}px]">
  <div class="container mx-auto max-w-md">
    <h1 style="color: {{ section.settings.title_color }}">{{ section.settings.title_text }}</h1>

    {% form 'customer_login' %}
      {{ form.errors | default_errors }}
      <input type="email" name="customer[email]" placeholder="E-posta">
      <input type="password" name="customer[password]" placeholder="Şifre">
      <button type="submit" class="btn">{{ section.settings.button_label }}</button>
    {% endform %}
  </div>
</div>

{% schema %}
{
  "name": "Login Sayfası Ayarları",
  "settings": [
    {
      "type": "text",
      "id": "title_text",
      "label": "Başlık Yazısı",
      "default": "Giriş Yap"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Başlık Rengi",
      "default": "#000000"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Buton Yazısı",
      "default": "Oturum Aç"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Üst Boşluk",
      "default": 40
    }
  ]
}
{% endschema %}
