<section
  id="Gallery-{{ section.id }}"
  class="w-full bg-white overflow-hidden"
  data-section-id="{{ section.id }}"
  data-section-type="gallery"
>
  {% if section.settings.title != blank %}
    <div class="text-center mb-8">
      <h2 class="text-2xl font-light tracking-[0.3em] uppercase text-primary">{{ section.settings.title }}</h2>
    </div>
  {% endif %}

  <div class="flex flex-wrap">
    {% for block in section.blocks %}
      <div
        class="w-1/2 md:w-1/4 aspect-square relative group overflow-hidden cursor-pointer luvia-gallery-item"
        {{ block.shopify_attributes }}
        onclick="openLuviaGallery({{ forloop.index0 }})"
        data-full-src="{{ block.settings.image | image_url: width: 2000 }}"
      >
        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.image.alt | default: 'Gallery' }}"
            class="w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-110"
            loading="lazy"
            width="800"
            height="800"
          >
        {% else %}
          <div class="w-full h-full bg-custombg flex items-center justify-center">
            {{ 'image' | placeholder_svg_tag: 'w-20 h-20 opacity-20' }}
          </div>
        {% endif %}

        <div
          class="absolute inset-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center z-20"
          style="background: #00000050;"
        >
          <span class="text-primary bg-white h-16 w-16 rounded-full flex items-center justify-center">
            {% render 'icon-zoom-pan' %}
          </span>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<div
  id="LuviaLightbox"
  class="fixed inset-0 z-[10000] flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300"
  style="background: #00000070 !important;"
>
  <button
    type="button"
    class="absolute top-8 right-8 text-white hover:bg-secondary bg-primary hover:text-white text-5xl z-[9999] h-[60px] w-[60px] cursor-pointer rounded-full flex items-center justify-center"
    onclick="closeLuviaGallery()"
  >
    {% render 'icon-close' %}
  </button>
  <button
    type="button"
    class="absolute left-4 top-1/2 -translate-y-1/2 text-white hover:bg-secondary bg-primary hover:text-white text-5xl z-[10001] p-4 cursor-pointer rounded-full flex items-center justify-center"
    onclick="changeImage(-1)"
  >
    {% render 'icon-chevron-left' %}
  </button>
  <img
    id="LightboxImage"
    src=""
    width=""
    height=""
    loading="eager"
    class="max-w-[85%] max-h-[80vh] object-contain shadow-2xl transition-all duration-300"
    alt="Luvia Gallery"
  >
  <button
    type="button"
    class="absolute right-4 top-1/2 -translate-y-1/2 text-white hover:bg-secondary bg-primary hover:text-white text-5xl z-[10001] p-4 cursor-pointer rounded-full flex items-center justify-center"
    onclick="changeImage(1)"
  >
    {% render 'icon-chevron-right' %}
  </button>
  <div
    id="GalleryCounter"
    class="absolute bottom-10 text-white text-[14px] tracking-widest uppercase"
  ></div>
</div>

<script>
  var currentImgIndex = 0;
  var galleryImages = [];

  function initLuviaGallery() {
    galleryImages = [];
    document.querySelectorAll('.luvia-gallery-item').forEach(function (item) {
      galleryImages.push(item.getAttribute('data-full-src'));
    });
  }

  function openLuviaGallery(index) {
    if (galleryImages.length === 0) initLuviaGallery();
    currentImgIndex = index;
    updateLightbox();
    var modal = document.getElementById('LuviaLightbox');
    modal.style.opacity = '1';
    modal.style.pointerEvents = 'auto';
    document.body.style.overflow = 'hidden';
  }

  function updateLightbox() {
    var img = document.getElementById('LightboxImage');
    var counter = document.getElementById('GalleryCounter');
    img.src = galleryImages[currentImgIndex];
    counter.innerText = currentImgIndex + 1 + ' / ' + galleryImages.length;
  }

  function changeImage(step) {
    currentImgIndex += step;
    if (currentImgIndex >= galleryImages.length) currentImgIndex = 0;
    if (currentImgIndex < 0) currentImgIndex = galleryImages.length - 1;
    updateLightbox();
  }

  function closeLuviaGallery() {
    var modal = document.getElementById('LuviaLightbox');
    modal.style.opacity = '0';
    modal.style.pointerEvents = 'none';
    document.body.style.overflow = 'auto';
  }

  document.addEventListener('shopify:section:load', initLuviaGallery);
  document.addEventListener('DOMContentLoaded', initLuviaGallery);
</script>

{% schema %}
{
  "name": "Luvia Full Gallery",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Follow Era"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luvia Full Gallery",
      "blocks": [{ "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }]
    }
  ]
}
{% endschema %}
