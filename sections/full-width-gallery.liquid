<section
  id="Gallery-{{ section.id }}"
  class="w-full bg-white overflow-hidden pt-9"
  data-section-id="{{ section.id }}"
>
  {% if section.settings.title != blank %}
    <div class="text-center mb-8">
      <h2 class="font-light tracking-[0.3em] uppercase text-secondary">{{ section.settings.title }}</h2>
      <div class="h-[1px] w-20 bg-secondary mx-auto mt-4"></div>
    </div>
  {% endif %}

  <div class="flex flex-wrap gallery-wrapper">
    {% for block in section.blocks %}
      <div
        class="w-1/2 md:w-1/4 aspect-[3/2] relative group overflow-hidden cursor-pointer luvia-gallery-item"
        {{ block.shopify_attributes }}
        onclick="openLuviaGallery(this, {{ forloop.index0 }})"
        data-full-src="{{ block.settings.image | image_url: width: 2000 }}"
      >
        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.image.alt | default: 'Gallery Image' }}"
            height="auto"
            width="800"
            class="w-full h-full object-cover object-top transition-transform duration-[1500ms] ease-out group-hover:scale-110"
            loading="lazy"
          >
        {% else %}
          <div class="w-full h-full bg-custombg flex items-center justify-center">
            {{ 'image' | placeholder_svg_tag: 'w-20 h-20 opacity-20' }}
          </div>
        {% endif %}

        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-[1500ms] ease-out flex items-center justify-center z-20 bg-black/50">
          <span class="flex text-primary bg-white md:h-16 md:w-16 h-12 w-12 rounded-full items-center justify-center transition-all duration-[1500ms] transform scale-50 group-hover:scale-100">
            {% render 'icon-zoom-pan' %}
          </span>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<script>
  // Fonksiyonları global kapsamda tanımlıyoruz (Eğer yoksa)
  if (typeof openLuviaGallery !== 'function') {
    var currentImgIndex = 0;
    var galleryImages = [];

    window.openLuviaGallery = function (element, index) {
      // Sadece tıklanan galeri grubundaki görselleri topla
      galleryImages = [];
      const parentSection = element.closest('section');
      const items = parentSection.querySelectorAll('.luvia-gallery-item');

      items.forEach(function (item) {
        galleryImages.push(item.getAttribute('data-full-src'));
      });

      currentImgIndex = index;
      updateLightbox();

      const modal = document.getElementById('LuviaLightbox');
      if (modal) {
        modal.style.opacity = '1';
        modal.style.pointerEvents = 'auto';
        document.body.style.overflow = 'hidden';
      }
    };

    window.updateLightbox = function () {
      const img = document.getElementById('LightboxImage');
      const counter = document.getElementById('GalleryCounter');
      if (img && galleryImages[currentImgIndex]) {
        img.src = galleryImages[currentImgIndex];
        counter.innerText = currentImgIndex + 1 + ' / ' + galleryImages.length;
      }
    };

    window.changeImage = function (step) {
      currentImgIndex += step;
      if (currentImgIndex >= galleryImages.length) currentImgIndex = 0;
      if (currentImgIndex < 0) currentImgIndex = galleryImages.length - 1;
      updateLightbox();
    };

    window.closeLuviaGallery = function () {
      const modal = document.getElementById('LuviaLightbox');
      if (modal) {
        modal.style.opacity = '0';
        modal.style.pointerEvents = 'none';
        document.body.style.overflow = 'auto';
      }
    };
  }
</script>

{% schema %}
{
  "name": "Luvia Full Gallery",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Follow Era"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luvia Full Gallery",
      "blocks": [{ "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }]
    }
  ]
}
{% endschema %}
