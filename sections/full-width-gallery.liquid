{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
    margin-bottom: {{ section.settings.margin_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
      margin-top: {{ section.settings.margin_top }}px;
      margin-bottom: {{ section.settings.margin_bottom }}px;
    }
  }
{%- endstyle -%}

<section
  id="Gallery-{{ section.id }}"
  class="w-full bg-white overflow-hidden section-{{ section.id }}-padding color-{{ section.settings.color_scheme }} gradient"
  data-section-id="{{ section.id }}"
>
  {% if section.settings.title != blank %}
    <div class="text-center mb-8">
      <h2 class="text-secondary">{{ section.settings.title }}</h2>
      <div class="h-[1px] w-20 bg-secondary mx-auto mt-4"></div>
    </div>
  {% endif %}

  <div class="flex flex-wrap gallery-wrapper">
    {% for block in section.blocks %}
      <div
        class="w-1/2 md:w-1/4 aspect-[3/2] relative group overflow-hidden cursor-pointer luvia-gallery-item"
        {{ block.shopify_attributes }}
        onclick="openLuviaGallery(this, {{ forloop.index0 }})"
        data-full-src="{{ block.settings.image | image_url: width: 2000 }}"
      >
        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.image.alt | default: 'Gallery Image' }}"
            height="600"
            width="800"
            class="w-full h-full object-cover object-top transition-transform duration-[1500ms] ease-out group-hover:scale-110"
            loading="lazy"
          >
        {% else %}
          {% comment %} Daha gösterişli placeholder {% endcomment %}
          <div class="w-full h-full bg-gradient-to-br from-gray-100 to-gray-200 flex items-center justify-center">
            <div class="text-center">
              {{ 'image' | placeholder_svg_tag: 'w-16 h-16 md:w-20 md:h-20 opacity-40 mx-auto' }}
              <p class="text-xs text-gray-400 mt-2">No Image</p>
            </div>
          </div>
        {% endif %}

        <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-[1500ms] ease-out flex items-center justify-center z-20 bg-black/50">
          <span class="flex text-primary bg-white md:h-16 md:w-16 h-12 w-12 rounded-full items-center justify-center transition-all duration-[1500ms] transform scale-50 group-hover:scale-100">
            {% render 'icon-zoom-pan' %}
          </span>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<script>
  // Define functions in global scope (if not exists)
  if (typeof openLuviaGallery !== 'function') {
    var currentImgIndex = 0;
    var galleryImages = [];

    window.openLuviaGallery = function (element, index) {
      // Collect images only from the clicked gallery group
      galleryImages = [];
      const parentSection = element.closest('section');
      const items = parentSection.querySelectorAll('.luvia-gallery-item');

      items.forEach(function (item) {
        galleryImages.push(item.getAttribute('data-full-src'));
      });

      currentImgIndex = index;
      updateLightbox();

      const modal = document.getElementById('LuviaLightbox');
      if (modal) {
        modal.style.opacity = '1';
        modal.style.pointerEvents = 'auto';
        document.body.style.overflow = 'hidden';
      }
    };

    window.updateLightbox = function () {
      const img = document.getElementById('LightboxImage');
      const counter = document.getElementById('GalleryCounter');
      if (img && galleryImages[currentImgIndex]) {
        img.src = galleryImages[currentImgIndex];
        counter.innerText = currentImgIndex + 1 + ' / ' + galleryImages.length;
      }
    };

    window.changeImage = function (step) {
      currentImgIndex += step;
      if (currentImgIndex >= galleryImages.length) currentImgIndex = 0;
      if (currentImgIndex < 0) currentImgIndex = galleryImages.length - 1;
      updateLightbox();
    };

    window.closeLuviaGallery = function () {
      const modal = document.getElementById('LuviaLightbox');
      if (modal) {
        modal.style.opacity = '0';
        modal.style.pointerEvents = 'none';
        document.body.style.overflow = 'auto';
      }
    };
  }
</script>

{% schema %}
{
  "name": "Luvia Full Gallery",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Follow Era"
    },
    {
      "type": "header",
      "content": "Style Settings"
    },
    {
      "type": "range",
      "id": "header_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Header Opacity Rate",
      "default": 100,
      "info": "Adjust the transparency level of the header section if applicable."
    },
    {
      "type": "header",
      "content": "Section Spacing Settings"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top Margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom Margin",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Gallery Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luvia Full Gallery",
      "blocks": [{ "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }]
    }
  ]
}
{% endschema %}
