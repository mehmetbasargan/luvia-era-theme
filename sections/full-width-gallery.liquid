<section class="w-full bg-white overflow-hidden">
  <div class="flex flex-wrap" id="LuviaGallery-{{ section.id }}">
    {% for block in section.blocks %}
      <div
        class="w-1/2 md:w-1/4 aspect-square relative group overflow-hidden cursor-pointer luvia-gallery-item"
        data-src="{{ block.settings.image | image_url: width: 2000 }}"
      >
        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.image.alt | default: 'Luvia Gallery' }}"
            class="w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-110"
            loading="lazy"
            width="800"
            height="800"
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'w-full h-full bg-gray-200' }}
        {% endif %}

        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center z-20">
          <span class="text-white text-[11px] tracking-[0.4em] uppercase border border-white/50 px-6 py-3 backdrop-blur-sm">
            {{ 'general.discover_more' | t | default: 'VIEW IMAGE' }}
          </span>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<div
  id="LuviaLightbox"
  class="fixed inset-0 z-[500] bg-black/95 flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300"
>
  <button
    type="button"
    class="absolute top-6 right-8 text-white text-5xl font-light hover:rotate-90 transition-all duration-300 z-[510] cursor-pointer"
    onclick="closeLightbox()"
  >
    &times;
  </button>
  <img
    id="LightboxImage"
    src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
    class="max-w-[90%] max-h-[85vh] object-contain shadow-2xl transition-all duration-500 scale-95"
    height=""
    width=""
    loading="eager"
    alt="Enlarged view"
  >
</div>

<script>
  function openLightbox(src) {
    const lightbox = document.getElementById('LuviaLightbox');
    const img = document.getElementById('LightboxImage');
    if (!lightbox || !img) return;

    img.src = src;
    lightbox.style.opacity = '1';
    lightbox.style.pointerEvents = 'auto';
    setTimeout(() => {
      img.style.transform = 'scale(1)';
    }, 50);
  }

  function closeLightbox() {
    const lightbox = document.getElementById('LuviaLightbox');
    const img = document.getElementById('LightboxImage');
    if (!lightbox || !img) return;

    img.style.transform = 'scale(0.95)';
    lightbox.style.opacity = '0';
    lightbox.style.pointerEvents = 'none';
    setTimeout(() => {
      img.src = '';
    }, 300); // Kapanınca resmi temizle
  }

  // Event Listeners (Tıklama yakalama)
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.luvia-gallery-item').forEach((item) => {
      item.addEventListener('click', function () {
        const fullResSrc = this.getAttribute('data-src');
        openLightbox(fullResSrc);
      });
    });
  });

  // ESC tuşu
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeLightbox();
  });
</script>

<style>
  #LuviaLightbox {
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
  }
  #LightboxImage {
    transition: transform 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
  }
</style>

{% schema %}
{
  "name": "Full Width Gallery",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Follow the Era"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image Block",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Select Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Luvia Full Gallery",
      "blocks": [{ "type": "image" }, { "type": "image" }, { "type": "image" }, { "type": "image" }]
    }
  ]
}
{% endschema %}
