<section class="w-full bg-white overflow-hidden">
  <div class="flex flex-wrap" id="LuviaGallery-{{ section.id }}">
    {% for block in section.blocks %}
      <div
        class="w-1/2 md:w-1/4 aspect-square relative group overflow-hidden cursor-pointer luvia-gallery-item"
        onclick="openLuviaGallery({{ forloop.index0 }})"
        data-full-src="{{ block.settings.image | image_url: width: 2000 }}"
      >
        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 800 }}"
            alt="{{ block.settings.title | default: 'Gallery Image' }}"
            class="w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-110"
            loading="lazy"
            height=""
            width=""
          >
        {% else %}
          {{ 'image' | placeholder_svg_tag: 'w-full h-full bg-gray-200' }}
        {% endif %}

        <div class="absolute inset-0 bg-black/40 opacity-0 group-hover:opacity-100 transition-opacity duration-500 flex items-center justify-center z-20">
          <span class="text-white text-[11px] tracking-[0.4em] uppercase border border-white/50 px-6 py-3 backdrop-blur-sm">
            {{ 'general.discover_more' | t | default: 'VIEW' }}
          </span>
        </div>
      </div>
    {% endfor %}
  </div>
</section>

<div
  id="LuviaLightbox"
  class="fixed inset-0 z-[9999] bg-black/95 flex items-center justify-center opacity-0 pointer-events-none transition-all duration-300 backdrop-blur-xl"
>
  <button
    type="button"
    class="absolute top-10 right-10 text-white/70 hover:text-white text-5xl font-thin transition-all z-[10000] cursor-pointer"
    onclick="closeLuviaGallery()"
  >
    &times;
  </button>

  <button
    type="button"
    class="absolute left-5 top-1/2 -translate-y-1/2 text-white/50 hover:text-white text-6xl font-thin z-[10000] p-4 cursor-pointer"
    onclick="changeImage(-1)"
  >
    &#8249;
  </button>

  <img
    id="LightboxImage"
    src="data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7"
    class="max-w-[90%] max-h-[85vh] object-contain shadow-2xl transition-all duration-500 scale-95"
    alt="Enlarged view"
    width=""
    height=""
    loading="eager"
  >

  <button
    type="button"
    class="absolute right-5 top-1/2 -translate-y-1/2 text-white/50 hover:text-white text-6xl font-thin z-[10000] p-4 cursor-pointer"
    onclick="changeImage(1)"
  >
    &#8250;
  </button>

  <div id="GalleryCounter" class="absolute bottom-10 text-white/40 text-xs tracking-widest uppercase"></div>
</div>

<script>
  let currentImgIndex = 0;
  const galleryImages = [];

  // Sayfa yüklendiğinde tüm resim adreslerini bir diziye (array) topla
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.luvia-gallery-item').forEach((item) => {
      galleryImages.push(item.getAttribute('data-full-src'));
    });
  });

  function openLuviaGallery(index) {
    currentImgIndex = index;
    updateLightbox();
    const modal = document.getElementById('LuviaLightbox');
    modal.style.opacity = '1';
    modal.style.pointerEvents = 'auto';
    document.body.style.overflow = 'hidden'; // Sayfa kaymasını engelle
  }

  function updateLightbox() {
    const img = document.getElementById('LightboxImage');
    const counter = document.getElementById('GalleryCounter');

    img.style.opacity = '0'; // Geçiş efekti
    setTimeout(() => {
      img.src = galleryImages[currentImgIndex];
      img.style.opacity = '1';
      img.classList.remove('scale-95');
      img.classList.add('scale-100');
      counter.innerText = currentImgIndex + 1 + ' / ' + galleryImages.length;
    }, 200);
  }

  function changeImage(step) {
    currentImgIndex += step;
    if (currentImgIndex >= galleryImages.length) currentImgIndex = 0;
    if (currentImgIndex < 0) currentImgIndex = galleryImages.length - 1;
    updateLightbox();
  }

  function closeLuviaGallery() {
    const modal = document.getElementById('LuviaLightbox');
    modal.style.opacity = '0';
    modal.style.pointerEvents = 'none';
    document.body.style.overflow = 'auto'; // Kaydırmayı geri aç
  }

  // Klavye Kontrolleri
  document.addEventListener('keydown', (e) => {
    if (document.getElementById('LuviaLightbox').style.opacity === '1') {
      if (e.key === 'Escape') closeLuviaGallery();
      if (e.key === 'ArrowRight') changeImage(1);
      if (e.key === 'ArrowLeft') changeImage(-1);
    }
  });
</script>
