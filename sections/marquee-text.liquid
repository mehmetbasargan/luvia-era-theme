{%- liquid
  assign show_marquee = false
  if section.blocks.size > 0
    assign show_marquee = true
  endif
-%}

{%- if show_marquee -%}
  <style>
    :root {
      /* Başlangıçta 0, JS ile gerçek yükseklik atanacak */
      --marquee-height: 0px;
    }
    #shopify-section-{{ section.id }} {
      /* Fixed yerine absolute yaparak scroll ile kaybolmasını sağlıyoruz */
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 1001;
    }
    .marquee-wrapper {
      background-color: {{ section.settings.bg_color }};
      border-bottom: 1px solid rgba(255,255,255,0.1);
    }
    .animate-marquee {
      display: inline-flex;
      animation: marquee-animation {{ section.settings.speed | default: 30 }}s linear infinite;
    }
    {% if section.settings.pause_on_hover %}
    .animate-marquee:hover {
      animation-play-state: paused;
    }
    {% endif %}
    @keyframes marquee-animation {
      0% { transform: translateX(0); }
      100% { transform: translateX(-25%); }
    }
  </style>

  <section
    id="Marquee-{{ section.id }}"
    class="marquee-wrapper overflow-hidden select-none"
  >
    <div class="flex whitespace-nowrap animate-marquee">
      {% for i in (1..4) %}
        <div class="flex items-center">
          {% for block in section.blocks %}
            <span
              class="marquee-item text-[10px] md:text-[11px] font-light uppercase tracking-[0.2em] mx-6 py-3 flex items-center gap-4"
              style="color: {{ section.settings.text_color }};"
              {{ block.shopify_attributes }}
            >
              {{ block.settings.text }}
              {% if section.settings.show_separator %}
                <span class="opacity-30">•</span>
              {% endif %}
            </span>
          {% endfor %}
        </div>
      {% endfor %}
    </div>
  </section>

  <script>
    function updateMarqueeHeight() {
      const marquee = document.getElementById('Marquee-{{ section.id }}');
      if (marquee) {
        // Bölümün yüksekliğini ölçüp CSS değişkenine gönderiyoruz
        document.documentElement.style.setProperty('--marquee-height', marquee.offsetHeight + 'px');
      }
    }
    // Sayfa yüklendiğinde ve boyut değiştiğinde tetikle
    window.addEventListener('resize', updateMarqueeHeight);
    window.addEventListener('load', updateMarqueeHeight);
    // Shopify editor etkileşimi için
    document.addEventListener('shopify:section:load', updateMarqueeHeight);
    document.addEventListener('shopify:section:unload', () => {
      document.documentElement.style.setProperty('--marquee-height', '0px');
    });

    /* **** */
    (function () {
      // Header'ı bulmak için yardımcı fonksiyon
      function getHeader() {
        return document.getElementById('main-header') || document.querySelector('.site-header');
      }

      function initMarqueeHeader() {
        const header = getHeader();
        if (!header) return;

        // 1. Marquee class'ını ekle
        header.classList.add('marquee-text-active');

        // 2. Scroll kontrolü
        const updateHeaderPosition = () => {
          const isScrolled = window.scrollY > 20;
          if (isScrolled) {
            header.classList.add('is-scrolled');
            header.style.setProperty('top', '0px', 'important');
          } else {
            header.classList.remove('is-scrolled');
            header.style.setProperty('top', '40px', 'important');
          }
        };

        // Event'leri bağla
        window.addEventListener('scroll', updateHeaderPosition, { passive: true });
        updateHeaderPosition(); // İlk açılışta çalıştır

        // Bekçi: Başka bir JS class'ı silerse geri ekle
        const observer = new MutationObserver(() => {
          if (!header.classList.contains('marquee-text-active')) {
            header.classList.add('marquee-text-active');
            updateHeaderPosition();
          }
        });
        observer.observe(header, { attributes: true, attributeFilter: ['class'] });
      }

      // DOM'un yüklenmesini beklemeden hemen denemeye başla (Interval yöntemi)
      let retryCount = 0;
      const checkHeader = setInterval(() => {
        const header = getHeader();
        if (header) {
          initMarqueeHeader();
          clearInterval(checkHeader);
        }
        if (retryCount > 100) clearInterval(checkHeader); // 10 saniye sonra aramayı bırak
        retryCount++;
      }, 100);
    })();
  </script>

  <style>
    /* Header'ın temel geçiş ayarları */
    #main-header {
      transition: top 0.4s cubic-bezier(0.4, 0, 0.2, 1), background-color 0.3s ease !important;
    }

    /* Sayfa en tepedeyken (Marquee aktif) */
    #main-header.marquee-text-active:not(.is-scrolled) {
      top: 40px !important;
    }

    /* Sayfa kaydırıldığında */
    #main-header.is-scrolled {
      top: 0 !important;
      /* İstersen burada gölge ekleyerek derinlik katabilirsin */
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.05);
    }
  </style>

{%- else -%}
  <style>
    :root {
      --marquee-height: 0px;
    }
  </style>
{%- endif -%}

{% schema %}
{
  "name": "Marquee Text",
  "settings": [
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "speed",
      "min": 10,
      "max": 100,
      "step": 5,
      "unit": "s",
      "label": "Speed",
      "default": 30
    },
    {
      "type": "checkbox",
      "id": "show_separator",
      "label": "Show Separator",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on Hover",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "text_block",
      "name": "Text Slide",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Marquee Text",
          "default": "FREE SHIPPING WORLDWIDE"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Marquee Text",
      "blocks": [{ "type": "text_block" }]
    }
  ]
}
{% endschema %}
