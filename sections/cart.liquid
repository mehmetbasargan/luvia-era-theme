{% comment %}
  This section is used in the cart template to render /cart page with an
  overview of the items in customer's cart.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}

<div class="container px-4 md:px-10 py-16 lg:py-24">
  <header class="text-center mb-16">
    <h2 class="text-secondary">
      {{ 'cart.shopping_bag' | t }}
    </h2>
    <div class="h-[2px] w-20 bg-secondary mx-auto mt-4"></div>
  </header>

  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post" novalidate class="flex flex-col lg:flex-row gap-16">
      <div class="w-full lg:w-2/3">
        <div class="border-t border-line">
          {% for item in cart.items %}
            <div class="flex flex-col md:flex-row gap-6 py-8 border-b border-line items-start md:items-center animate-fadeIn">
              {% comment %} Görsel Alanı Başlangıcı {% endcomment %}
              <div class="w-28 h-36 shrink-0 bg-custombg overflow-hidden flex items-center justify-center border border-line/10">
                <a
                  href="{{ item.url }}"
                  aria-label="View {{ item.product.title | escape }} product details"
                  class="w-full h-full block"
                >
                  {% if item.image != blank %}
                    <img
                      src="{{ item.image | image_url: width: 400 }}"
                      alt="{{ item.title | escape }}"
                      width="400"
                      height="400"
                      class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                      loading="eager"
                    >
                  {% else %}
                    {% comment %} Görsel yoksa burası çalışır {% endcomment %}
                    <div class="w-full h-full bg-gray-100 flex items-center justify-center opacity-60">
                      {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover' }}
                    </div>
                  {% endif %}
                </a>
              </div>
              {% comment %} Görsel Alanı Bitiş {% endcomment %}

              <div class="grow space-y-2 w-full md:w-auto">
                <div class="flex justify-between items-start">
                  <div>
                    <span class="uppercase text-sm md:text-lg">
                      <a href="{{ item.url }}" aria-label="View {{ item.product.title | escape }} product details">
                        {{- item.product.title -}}
                      </a>
                    </span>
                    {% unless item.product.has_only_default_variant %}
                      <p class="text-[12px  ] md:text-[14px] uppercase tracking-widest mt-1">
                        {{ item.variant.title }}
                      </p>
                    {% endunless %}
                  </div>
                  <p class="text-[15px] font-semibold">{{ item.final_line_price | money }}</p>
                </div>

                <div class="flex justify-between items-center pt-6 w-full">
                  <div class="flex items-center justify-between border border-line">
                    <a
                      href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}"
                      class="px-3 py-1 text-xl hover:bg-primary text-primary hover:!text-white transition-colors"
                      >-</a
                    >

                    <label class="sr-only" for="CartQuantity-{{ forloop.index }}">Adet</label>
                    <input
                      type="number"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      readOnly
                      id="CartQuantity-{{ forloop.index }}"
                      class="w-8 h-8 py-3 text-center text-[15px] text-primary border-none focus:ring-0 cursor-default flex items-center justify-center "
                      aria-label="Quantity"
                    >

                    <a
                      href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}"
                      class="px-3 py-1 text-xl hover:bg-primary text-primary hover:!text-white transition-colors"
                      >+</a
                    >
                  </div>

                  <a
                    href="{{ item.url_to_remove }}"
                    class="text-red-500 hover:text-red-600 p-1 rounded-full hover:bg-red-200 transition-colors"
                  >
                    {% render 'icon-close' %}
                  </a>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="mt-8">
          <a
            href="{{ routes.all_products_collection_url }}"
            class="text-[16px] uppercase -tracking-tight text-primary pb-1 hover:!text-secondary transition-all"
          >
            ← {{ 'cart.continue_shopping' | t }}
          </a>
        </div>
      </div>

      <div class="w-full lg:w-1/3 ">
        <div class="bg-custombg p-7 space-y-8 sticky top-40">
          <div class="border-b border-line pb-1 block">
            <span class="uppercase text-sm md:text-xl font-semibold tracking-wider">
              {{ 'cart.order_title' | t }}
            </span>
          </div>

          <div class="space-y-4">
            <div class="flex justify-between items-center">
              <span class="text-[14px] uppercase tracking-widest text-primary font-bold">
                {{ 'cart.subtotal' | t }}
              </span>
              <span class="text-[16px] tracking-tight font-bold">{{ cart.total_price | money }}</span>
            </div>
            <p class="text-[14px] text-primary">
              {{ 'cart.shipping_taxes_discounts' | t }}
            </p>
          </div>

          <div class="pt-4">
            <button
              type="submit"
              name="checkout"
              class="w-full cursor-pointer bg-primary text-white py-5 text-[14px] uppercase tracking-[0.1em] hover:bg-secondary transition-all duration-500 shadow-sm"
              aria-label="{{ 'cart.proceed_to_checkout' | t | default: 'Proceed to checkout' }}"
            >
              {{ 'cart.proceed_to_checkout' | t }}
            </button>
          </div>

          <div class="flex justify-center gap-4 pt-4">
            <small class="text-[14px] uppercase tracking-wider text-primary">
              {{ 'cart.secure_payment_guaranteed' | t }}
            </small>
          </div>
        </div>
      </div>
    </form>
  {% else %}
    <div class="text-center py-32 animate-fadeIn">
      <p class="text-[14px] text-secondary mb-10 tracking-wider">
        {{ 'cart.shopping_bg_is_empty' | t }}
      </p>
      <a
        href="{{ routes.all_products_collection_url }}"
        class="inline-block bg-primary text-white px-12 py-5 uppercase tracking-[0.3em] text-[12px] hover:bg-secondary transition-all duration-500"
      >
        {{ 'cart.discover_our_collection' | t }}
      </a>
    </div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    // Capture all cart buttons (+, -, Remove)
    const cartButtons = document.querySelectorAll('a[href*="/cart/change"], a[href*="/cart/add"]');

    cartButtons.forEach((link) => {
      link.addEventListener('click', function (e) {
        const url = new URL(this.href);
        const params = new URLSearchParams(url.search);
        const quantity = parseInt(params.get('quantity'));

        // If link has quantity parameter and it's 0, set DELETED message
        if (params.has('quantity') && quantity === 0) {
          localStorage.setItem('cart_toast_msg', 'Product removed from cart!');
          localStorage.setItem('cart_toast_type', 'error');
        }
        // If quantity is increasing or just changing, set UPDATED message
        else {
          localStorage.setItem('cart_toast_msg', 'Cart updated successfully!');
          localStorage.setItem('cart_toast_type', 'success');
        }
      });
    });

    // Check if there's a message when page loads
    const pendingMsg = localStorage.getItem('cart_toast_msg');
    const pendingType = localStorage.getItem('cart_toast_type');

    if (pendingMsg && typeof showToast === 'function') {
      showToast(pendingMsg, pendingType);
      // Clear message after showing once
      localStorage.removeItem('cart_toast_msg');
      localStorage.removeItem('cart_toast_type');
    }
  });
</script>

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
