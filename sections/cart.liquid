{% comment %}
  This section is used in the cart template to render /cart page with an
  overview of the items in customer's cart.

  https://shopify.dev/docs/storefronts/themes/architecture/templates/cart
{% endcomment %}

<div class="container px-4 md:px-10 py-16 lg:py-24">
  <header class="text-center mb-16">
    <h3 class="font-light tracking-[0.3em] uppercase text-secondary">
      {{ 'cart.shopping_bag' | t }}
    </h3>
    <div class="h-[2px] w-20 bg-secondary mx-auto mt-4"></div>
  </header>

  {% if cart.item_count > 0 %}
    <form action="{{ routes.cart_url }}" method="post" novalidate class="flex flex-col lg:flex-row gap-16">
      <div class="w-full lg:w-2/3">
        <div class="border-t border-line">
          {% for item in cart.items %}
            <div class="flex flex-col md:flex-row gap-6 py-8 border-b border-line items-start md:items-center animate-fadeIn">
              <div class="w-28 h-36 shrink-0 bg-custombg overflow-hidden">
                <a href="{{ item.url }}">
                  <img
                    src="{{ item.image | image_url: width: 400 }}"
                    alt="{{ item.title | escape }}"
                    width="400"
                    height="400"
                    class="w-full h-full object-cover hover:scale-105 transition-transform duration-700"
                    loading="eager"
                  >
                </a>
              </div>

              <div class="grow space-y-2 w-full md:w-auto">
                <div class="flex justify-between items-start">
                  <div>
                    <h6 class="uppercase tracking-[0.2em] font-medium leading-[20px]">
                      <a href="{{ item.url }}">{{ item.product.title }}</a>
                    </h6>
                    {% unless item.product.has_only_default_variant %}
                      <p class="text-[14px] uppercase tracking-widest mt-1">
                        {{ item.variant.title }}
                      </p>
                    {% endunless %}
                  </div>
                  <p class="text-[15px] font-semibold">{{ item.final_line_price | money }}</p>
                </div>

                <div class="flex justify-between items-center pt-6 w-full">
                  <div class="flex items-center justify-between border border-line">
                    <a
                      href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | minus: 1 }}"
                      class="px-3 py-1 text-xl hover:bg-primary text-primary hover:!text-white transition-colors"
                      >-</a
                    >

                    <input
                      type="number"
                      name="updates[]"
                      value="{{ item.quantity }}"
                      readOnly
                      class="w-8 h-8 py-3 text-center text-[15px] text-primary border-none focus:ring-0 cursor-default flex items-center justify-center pl-3"
                      aria-label="Quantity"
                    >

                    <a
                      href="{{ routes.cart_change_url }}?line={{ forloop.index }}&quantity={{ item.quantity | plus: 1 }}"
                      class="px-3 py-1 text-xl hover:bg-primary text-primary hover:!text-white transition-colors"
                      >+</a
                    >
                  </div>

                  <a
                    href="{{ item.url_to_remove }}"
                    class="text-red-500 hover:text-red-600 p-1 rounded-full hover:bg-red-200 transition-colors"
                  >
                    {% render 'icon-close' %}
                  </a>
                </div>
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="mt-8">
          <a
            href="{{ routes.all_products_collection_url }}"
            class="text-[15px] uppercase tracking-[0.2em] text-primary pb-1 hover:!text-secondary transition-all"
          >
            ← {{ 'cart.continue_shopping' | t }}
          </a>
        </div>
      </div>

      <div class="w-full lg:w-1/3">
        <div class="bg-custombg p-2 md:p-10 space-y-8 sticky top-40">
          <h6 class="uppercase tracking-[0.3em] font-medium border-b border-line pb-6">
            {{ 'cart.order_title' | t }}
          </h6>

          <div class="space-y-4">
            <div class="flex justify-between items-center">
              <span class="text-[14px] uppercase tracking-widest text-primary font-medium">
                {{ 'cart.subtotal' | t }}
              </span>
              <span class="text-[16px] tracking-tight font-medium">{{ cart.total_price | money }}</span>
            </div>
            <p class="text-[14px] text-primary leading-relaxed">
              {{ 'cart.shipping_taxes_discounts' | t }}
            </p>
          </div>

          <div class="pt-4">
            <button
              type="submit"
              name="checkout"
              class="w-full cursor-pointer bg-primary text-white py-5 text-[13px] uppercase tracking-[0.2em] hover:bg-secondary transition-all duration-500 shadow-sm"
            >
              {{ 'cart.proceed_to_checkout' | t }}
            </button>
          </div>

          <div class="flex justify-center gap-4 pt-4">
            <small class="text-[13px] uppercase tracking-widest text-primary">
              {{ 'cart.secure_payment_guaranteed' | t }}
            </small>
          </div>
        </div>
      </div>
    </form>
  {% else %}
    <div class="text-center py-32 animate-fadeIn">
      <p class="text-[13px] text-secondary mb-10 tracking-widest font-light">
        {{ 'cart.shopping_bg_is_empty' | t }}
      </p>
      <a
        href="{{ routes.all_products_collection_url }}"
        class="inline-block bg-primary text-white px-12 py-5 uppercase tracking-[0.3em] text-[12px] hover:bg-secondary transition-all duration-500"
      >
        {{ 'cart.discover_our_collection' | t }}
      </a>
    </div>
  {% endif %}
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const urlParams = new URLSearchParams(window.location.search);

    if (window.performance && window.performance.navigation.type === window.performance.navigation.TYPE_RELOAD) {
    }

    const removeLinks = document.querySelectorAll('a[href*="/cart/change"]');
    removeLinks.forEach((link) => {
      link.addEventListener('click', function () {
        localStorage.setItem('showRemoveToast', 'true');
      });
    });

    if (localStorage.getItem('showRemoveToast') === 'true') {
      showToast('Product removed from cart!', 'error');
      localStorage.removeItem('showRemoveToast');
    }
  });

  document.addEventListener('click', function (e) {
    if (e.target.closest('a[href*="/cart/change"]')) {
      localStorage.setItem('cart_item_removed', 'true');
    }
  });

  window.addEventListener('load', function () {
    if (localStorage.getItem('cart_item_removed') === 'true') {
      if (typeof showToast === 'function') {
        showToast('Product removed from cart!', 'error');
      } else {
        showToast('Product removed from cart!', 'error');
      }
      localStorage.removeItem('cart_item_removed');
    }
  });
</script>

{% schema %}
{
  "name": "t:general.cart",
  "settings": []
}
{% endschema %}
