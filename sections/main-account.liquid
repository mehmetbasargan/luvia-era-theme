<div class="account-section py-[{{ section.settings.padding_y }}px] bg-white">
  <div class="container mx-auto px-6">
    <div class="flex flex-col md:flex-row justify-between items-end mb-12 border-b border-gray-100 pb-8">
      <div>
        <h1 class="text-3xl font-light uppercase tracking-[0.3em] text-primary">{{ 'customer.account.title' | t }}</h1>
        <p class="text-gray-400 text-[10px] mt-2 uppercase tracking-widest">Hoş geldin, {{ customer.name }}</p>
      </div>
      <a
        href="{{ routes.account_logout_url }}"
        class="text-[10px] uppercase tracking-widest text-red-400 hover:text-red-600 transition-colors"
      >
        {{- 'customer.log_out' | t -}}
      </a>
    </div>

    <div class="flex flex-col lg:flex-row gap-16">
      {% comment %} Yan Menü {% endcomment %}
      <aside class="lg:w-1/4">
        <nav class="flex flex-col gap-6">
          <a
            href="{{ routes.account_url }}"
            class="flex items-center gap-4 text-[11px] uppercase tracking-[0.2em] font-bold text-primary"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-secondary"></span>
            {{ 'customer.orders.title' | t }}
          </a>
          <a
            href="{{ routes.account_addresses_url }}"
            class="flex items-center gap-4 text-[11px] uppercase tracking-[0.2em] text-gray-400 hover:text-primary transition-colors"
          >
            <span class="w-1.5 h-1.5 rounded-full bg-transparent"></span>
            {{ 'customer.account.view_addresses' | t }} ({{ customer.addresses_count }})
          </a>
        </nav>
      </aside>

      {% comment %} Sipariş Tablosu {% endcomment %}
      <main class="lg:w-3/4">
        {% paginate customer.orders by 10 %}
          {% if customer.orders.size > 0 %}
            <div class="overflow-x-auto">
              <table class="w-full text-left border-collapse">
                <thead>
                  <tr class="border-b border-gray-100 text-[10px] uppercase tracking-widest text-gray-400">
                    <th class="py-4 font-medium italic">Sipariş</th>
                    <th class="py-4 font-medium italic">Tarih</th>
                    <th class="py-4 font-medium italic">Ödeme</th>
                    <th class="py-4 font-medium text-right italic">Toplam</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                  {% for order in customer.orders %}
                    <tr
                      class="group hover:bg-gray-50 transition-colors cursor-pointer"
                      onclick="window.location='{{ order.customer_url }}'"
                    >
                      <td class="py-6 text-xs font-medium text-primary tracking-tighter">{{ order.name }}</td>
                      <td class="py-6 text-xs font-light text-gray-500">{{ order.created_at | date: '%d.%m.%Y' }}</td>
                      <td class="py-6">
                        <span class="text-[9px] uppercase tracking-widest px-2 py-1 bg-gray-100 text-gray-600 rounded-sm">
                          {{ order.financial_status_label }}
                        </span>
                      </td>
                      <td class="py-6 text-xs font-medium text-primary text-right">{{ order.total_price | money }}</td>
                    </tr>
                  {% endfor %}
                </tbody>
              </table>
            </div>
          {% else %}
            <p class="text-gray-400 text-xs italic uppercase tracking-widest py-10 border border-dashed border-gray-100 text-center">
              {{ 'customer.orders.none' | t }}
            </p>
          {% endif %}
          {{ paginate | default_pagination }}
        {% endpaginate %}
      </main>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Müşteri Hesabı",
  "settings": [
    {
      "type": "range",
      "id": "padding_y",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Dikey Boşluk",
      "default": 60
    }
  ]
}
{% endschema %}
