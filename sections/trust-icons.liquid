<section class="bg-custombg py-12 border-t border-line">
  <div class="container mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-4">
      {% for block in section.blocks %}
        <div class="flex flex-col items-center text-center space-y-3 group" {{ block.shopify_attributes }}>
          {% comment %} İkon Alanı {% endcomment %}
          <div class="text-primary/80 group-hover:text-secondary transition-colors duration-500">
            {% if block.settings.custom_svg != blank %}
              {{ block.settings.custom_svg }}
            {% else %}
              <svg
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="0.75"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M20 7h-9m3 3H5m12 3h-9m6 3H5"></path>
              </svg>
            {% endif %}
          </div>

          {% comment %} Metinler {% endcomment %}
          <div class="space-y-1">
            <h5 class="text-primary text-[11px] uppercase tracking-[0.2em] font-medium">
              {{ block.settings.title }}
            </h5>
            <p class="text-primary/60 text-[10px] uppercase tracking-widest leading-tight">
              {{ block.settings.subtitle }}
            </p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust Icons",
  "max_blocks": 4,
  "settings": [],
  "blocks": [
    {
      "type": "icon_block",
      "name": "Icon Block",
      "settings": [
        { "type": "html", "id": "custom_svg", "label": "Custom SVG Code" },
        { "type": "text", "id": "title", "label": "Title", "default": "Free Shipping" },
        { "type": "text", "id": "subtitle", "label": "Subtitle", "default": "On all orders over $200" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Trust Icons",
      "blocks": [
        { "type": "icon_block", "settings": { "title": "World Wide Shipping", "subtitle": "Premium delivery" } },
        { "type": "icon_block", "settings": { "title": "Secure Payment", "subtitle": "100% Protected" } },
        { "type": "icon_block", "settings": { "title": "Eco Friendly", "subtitle": "Sustainable Fashion" } },
        { "type": "icon_block", "settings": { "title": "Customer Care", "subtitle": "24/7 Support" } }
      ]
    }
  ]
}
{% endschema %}
