<div id="cart-drawer" class="fixed inset-0 z-[100] invisible overflow-hidden">
  <div
    id="cart-drawer-overlay"
    class="absolute inset-0 bg-black/30 opacity-0 transition-opacity duration-500 ease-in-out"
    onclick="closeCartDrawer()"
  ></div>

  <div
    id="cart-drawer-content"
    class="absolute right-0 t-full h-full w-full max-w-[400px] bg-white translate-x-full transition-transform duration-500 ease-out p-8 shadow-2xl flex flex-col"
  >
    <div class="flex justify-between items-center pb-6 border-b border-line">
      <h4 class="text-primary">{{ 'cart.my_cart' | t }}</h4>
      <button
        type="button"
        onclick="closeCartDrawer()"
        class="text-[13px] uppercase tracking-widest hover:opacity-50 transition-opacity"
        aria-label="Close cart"
      >
        {{ 'general.close' | t }}
      </button>
    </div>

    <div id="cart-drawer-items" class="flex-grow overflow-y-auto py-6 space-y-6"></div>

    <div class="border-t border-line pt-6 mt-auto">
      <div class="flex justify-between items-center mb-6">
        <span class="text-[13px] uppercase tracking-widest text-secondary">{{ 'general.total' | t }}</span>
        <span id="cart-total-price" class="text-sm font-light tracking-wider">{{ cart.total_price | money }}</span>
      </div>
      <a
        href="{{ routes.cart_url }}"
        class="block w-full bg-primary text-white py-4 text-center text-[11px] uppercase tracking-[0.3em] hover:bg-secondary transition-all"
      >
        {{ 'cart.checkout' | t }}
      </a>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    updateCartDrawer();
  });

  function updateCartDrawer() {
    fetch('/cart.js?t=' + Date.now())
      .then((response) => response.json())
      .then((cart) => {
        const container = document.getElementById('cart-drawer-items');
        const totalPrice = document.getElementById('cart-total-price');

        if (!container) return;

        // Sembolü her zaman başa alan format (Panel ayarını ezer)
        const moneyFormat = '{{ cart.currency.symbol }}{{amount}}';

        if (cart.items.length === 0) {
          container.innerHTML = '<p class="text-center text-gray-400 py-8">{{ "cart.empty" | t }}</p>';
        } else {
          container.innerHTML = cart.items
            .map((item) => {
              // Ürün fiyatını formatla (Sembol + Rakam)
              const itemPrice =
                window.Shopify && Shopify.formatMoney
                  ? Shopify.formatMoney(item.price, moneyFormat)
                  : '{{ cart.currency.symbol }}' + (item.price / 100).toFixed(2);

              return `
             <div class="flex gap-4 border-b border-gray-50 pb-4" data-item-key="${item.key}">
                <div class="w-20 h-24 shrink-0 bg-custombg overflow-hidden flex items-center justify-center border border-line/10">
                    ${
                      item.image
                        ? `<img src="${item.image}" alt="${item.product_title}" class="w-full h-full object-cover">`
                        : `<svg class="w-8 h-8 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path></svg>`
                    }
                </div>

                <div class="flex flex-col justify-center grow">
                    <h6 class="text-[12px] uppercase tracking-wider">${item.product_title}</h6>
                    <div class="flex items-center justify-between">
                        <p class="text-[11px] text-gray-400 mt-1">${item.variant_title || ''}</p>
                        <button type="button" onclick="removeFromCart('${
                          item.key
                        }')" class="text-red-500 hover:text-red-600 p-1 rounded-full hover:bg-red-200 transition-colors" aria-label="Remove item from cart">
                            {% render 'icon-close' %}
                        </button>
                    </div>
                    <div class="flex justify-between items-end mt-4">
                        <p class="text-[11px] tracking-widest text-gray-400">${item.quantity} QTY</p>
                        <p class="text-[13px] font-medium">${itemPrice}</p>
                    </div>
                </div>
            </div>
            `;
            })
            .join('');
        }

        // TOPLAM FİYAT (Sembolü başa alır)
        if (totalPrice) {
          totalPrice.innerHTML =
            window.Shopify && Shopify.formatMoney
              ? Shopify.formatMoney(cart.total_price, moneyFormat)
              : '{{ cart.currency.symbol }}' + (cart.total_price / 100).toFixed(2);
        }

        // Cart count update
        const cartBubbles = document.querySelectorAll('.cart-count-bubble');
        cartBubbles.forEach((bubble) => {
          const count = cart.item_count || 0;
          bubble.innerText = count;
          count > 0 ? bubble.classList.remove('hidden') : bubble.classList.add('hidden');
        });
      })
      .catch((error) => console.error('Cart update error:', error));
  }

  function updateCartCount() {
    fetch('/cart.js?t=' + Date.now())
      .then((response) => response.json())
      .then((cart) => {
        const cartBubbles = document.querySelectorAll('.cart-count-bubble');
        cartBubbles.forEach((bubble) => {
          const count = cart.item_count || 0;
          bubble.innerText = count;
          if (count > 0) {
            bubble.classList.remove('hidden');
          } else {
            bubble.classList.add('hidden');
          }
        });
      })
      .catch((error) => console.error('Cart update error:', error));
  }

  // Event-based cart updates instead of setInterval
  document.addEventListener('cart:updated', updateCartDrawer);
  document.addEventListener('wishlist:updated', updateCartDrawer);
  document.addEventListener('product:added', updateCartCount);

  // Initial cart count update
  updateCartCount();

  window.removeFromCart = function (itemKey) {
    fetch('/cart/change.js?t=' + Date.now(), {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        id: itemKey,
        quantity: 0,
      }),
    })
      .then((res) => res.json())
      .then((cartData) => {
        document.dispatchEvent(
          new CustomEvent('cart:updated', {
            detail: { cart: cartData },
            bubbles: true,
          })
        );
        const itemElement = document.querySelector(`[data-item-key="${itemKey}"]`);
        if (itemElement) {
          itemElement.style.opacity = '0';
          itemElement.style.transform = 'translateX(-100%)';
          setTimeout(() => {
            updateCartDrawer();
          }, 300);
        }
      })
      .catch((error) => {
        console.error('Cart remove error:', error);
        showToast('Product removed from cart!', 'error');
      });
  };
</script>
