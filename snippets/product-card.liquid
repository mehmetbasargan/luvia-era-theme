{% comment %}
  Luvia Era Product Card - ABSOLUTE FIXED HOVER
{% endcomment %}

<div class="group flex flex-col h-full bg-white overflow-hidden relative">
  <div class="relative aspect-[3/4] overflow-hidden bg-gray-50">
    {% comment %} Sale Badge {% endcomment %}
    {% if product.compare_at_price > product.price %}
      <span class="absolute top-3 left-3 z-30 bg-primary text-white font-light text-[10px] md:text-[11px] px-2.5 py-1 tracking-widest uppercase">
        {{ 'products.product.on_sale' | t | default: 'Sale' }}
      </span>
    {% endif %}

    {% comment %} Wishlist {% endcomment %}
    <div class="absolute top-3 right-3 z-30">
      <button
        type="button"
        class="flex items-center justify-center w-8 h-8 md:w-9 md:h-9 bg-white rounded-full shadow-sm hover:scale-110 transition-all duration-300 cursor-pointer p-1"
        onclick="LuviaWishlist.toggle('{{ product.id }}')"
      >
        <svg class="text-primary w-4 h-4 md:w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
        </svg>
      </button>
    </div>

    {% comment %} IMAGE WRAPPER {% endcomment %}
    <a href="{{ product.url | default: '#' }}" class="relative block w-full h-full z-10">
      {% if product.featured_image != blank %}
        {% comment %} Birinci Görsel (Base) {% endcomment %}
        <img
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.title | escape }}"
          loading="lazy"
          height="600"
          width="100%"
          class="
            w-full h-full object-cover transition-all duration-700 ease-in-out
            {% if product.images.size > 1 %} group-hover:opacity-0 group-hover:scale-105 {% endif %}
          "
        >

        {% comment %} İkinci Görsel (Hover) {% endcomment %}
        {% if product.images.size > 1 %}
          <img
            src="{{ product.images[1] | image_url: width: 600 }}"
            alt="{{ product.title | escape }}"
            loading="lazy"
            height="600"
            width="100%"
            class="absolute inset-0 w-full h-full object-cover opacity-0 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700 ease-in-out"
          >
        {% endif %}

      {% else %}
        {% comment %} Placeholder {% endcomment %}
        <div class="w-full h-full bg-gray-100 flex items-center justify-center opacity-30">
          {{ 'product-1' | placeholder_svg_tag: 'w-full h-full' }}
        </div>
      {% endif %}
    </a>

    {% comment %} Add to Cart {% endcomment %}
    <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-500 hidden md:block z-40">
      <button
        type="button"
        class="w-full bg-primary text-white py-4 text-[12px] uppercase tracking-[0.2em] hover:bg-secondary transition-colors cursor-pointer"
        {% if product.available %}
        {% endif %}
      >
        {{ 'products.product.add_to_cart' | t | default: 'Add to Cart' }}
      </button>
    </div>
  </div>

  {% comment %} Info {% endcomment %}
  <div class="pt-5 pb-3 flex flex-col items-center px-3">
    <a
      href="{{ product.url | default: '#' }}"
      class="text-primary text-[13px] md:text-[14px] hover:text-secondary transition-colors uppercase tracking-widest text-center"
    >
      {{ product.title | default: 'Luvia Premium Item' }}
    </a>
    <div class="mt-2 flex items-center gap-2">
      {% if product.compare_at_price > product.price %}
        <span class="text-gray-400 line-through text-[12px]">{{ product.compare_at_price | money }}</span>
      {% endif %}
      <span class="text-primary text-[14px] font-medium">{{ product.price | money | default: '$0.00' }}</span>
    </div>
  </div>
</div>
