{% comment %}
  Luvia Era Product Card Snippet
  - Fixed: Double image hover effect (Featured -> Second Image)
  - Fixed: Placeholder logic for empty images
  - Fixed: Quick add-to-cart & Wishlist layout
{% endcomment %}

<div class="group flex flex-col h-full bg-white overflow-hidden relative">
  {% comment %} Media Area {% endcomment %}
  <div class="relative aspect-[3/4] overflow-hidden bg-gray-50">
    {% comment %} Sale Badge {% endcomment %}
    {% if product.compare_at_price > product.price %}
      <span class="absolute top-3 left-3 z-30 bg-primary text-white font-light text-[10px] md:text-[11px] px-2.5 py-1 tracking-[0.15em] uppercase">
        {{ 'products.product.on_sale' | t | default: 'Sale' }}
      </span>
    {% endif %}

    {% comment %} Wishlist Button {% endcomment %}
    <div class="absolute top-3 right-3 z-30">
      <button
        type="button"
        class="flex items-center justify-center w-8 h-8 md:w-9 md:h-9 bg-white rounded-full shadow-sm hover:scale-110 transition-all duration-300 cursor-pointer p-1"
        data-product-id="{{ product.id }}"
        onclick="LuviaWishlist.toggle('{{ product.id }}')"
      >
        <svg
          class="text-primary w-4 h-4 md:w-5 h-5 transition-colors duration-300 pointer-events-none"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
        </svg>
      </button>
    </div>

    {% comment %} Images {% endcomment %}
    <a
      href="{{ product.url | default: '#' }}"
      class="block h-full w-full relative z-10"
      aria-label="View {{ product.title | escape }}"
    >
      {% if product.featured_image != blank %}
        {% comment %} First Image {% endcomment %}
        <img
          src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.title | escape }}"
          loading="lazy"
          width="400"
          height="533"
          class="
            w-full h-full object-cover transition-opacity duration-700 ease-in-out
            {% if product.images.size > 1 %} group-hover:opacity-0 {% endif %}
          "
        >

        {% comment %} Second Image (Appears on Hover) {% endcomment %}
        {% if product.images.size > 1 %}
          <img
            src="{{ product.images[1] | image_url: width: 600 }}"
            alt="{{ product.title | escape }}"
            loading="lazy"
            width="400"
            height="533"
            class="w-full h-full object-cover absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 ease-in-out"
          >
        {% endif %}

      {% else %}
        {% comment %} Placeholder if no images found {% endcomment %}
        <div class="w-full h-full bg-gray-100 flex items-center justify-center opacity-30 group-hover:scale-105 transition-transform duration-700">
          {{ 'product-1' | placeholder_svg_tag: 'w-full h-full' }}
        </div>
      {% endif %}
    </a>

    {% comment %} Quick Add to Cart (Desktop Hover Only) {% endcomment %}
    <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-500 hidden md:block z-40">
      <button
        type="button"
        {% if product.available %}
          onclick="handleAddToCart(event, '{{ product.selected_or_first_available_variant.id }}')"
        {% endif %}
        class="w-full bg-primary text-white py-4 text-[12px] uppercase tracking-[0.25em] block text-center hover:bg-secondary transition-colors cursor-pointer"
        {% unless product.available %}
          disabled
        {% endunless %}
      >
        {% if product.available %}
          {{ 'products.product.add_to_cart' | t | default: 'Add to Cart' }}
        {% else %}
          {{ 'products.product.sold_out' | t | default: 'Sold Out' }}
        {% endif %}
      </button>
    </div>
  </div>

  {% comment %} Product Information {% endcomment %}
  <div class="pt-5 pb-3 flex flex-col items-center px-3">
    {% comment %} Title {% endcomment %}
    <a
      href="{{ product.url | default: '#' }}"
      class="text-primary text-[13px] md:text-[14px] hover:text-secondary transition-colors uppercase tracking-[0.1em] text-center line-clamp-1"
    >
      {{ product.title | default: 'Luvia Premium Item' }}
    </a>

    {% comment %} Price {% endcomment %}
    <div class="mt-2.5 flex items-center gap-2.5">
      {% if product.compare_at_price > product.price %}
        <span class="text-gray-400 line-through text-[12px] italic">{{ product.compare_at_price | money }}</span>
        <span class="text-primary text-[14px] font-medium tracking-wide">{{ product.price | money }}</span>
      {% elsif product.price %}
        <span class="text-primary text-[14px] font-medium tracking-wide">{{ product.price | money }}</span>
      {% else %}
        <span class="text-primary text-[14px] font-medium tracking-wide">$99.00</span>
      {% endif %}
    </div>
  </div>
</div>
