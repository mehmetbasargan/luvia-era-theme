{% comment %}
  Luvia Era Product Card Snippet - TASARIM KORUMALI & MERKEZİ SİSTEM
{% endcomment %}

<div class="group flex flex-col h-full bg-white overflow-hidden relative" data-product-id="{{ product.id }}">
  <div class="relative aspect-[3/4] overflow-hidden bg-custombg">
    {% if product.compare_at_price > product.price %}
      <span class="absolute top-3 left-3 z-10 bg-primary text-white font-light text-[12px] px-2 py-1 tracking-widest uppercase">
        {{ 'products.product.on_sale' | t }}
      </span>
    {% endif %}

    {% comment %} WISHLIST BUTONU (İkon İçinde ve Konumu Sabit) {% endcomment %}
    <div class="absolute top-3 right-3 z-20">
      <button
        type="button"
        class="custom-wishlist-btn flex items-center justify-center w-9 h-9 bg-white rounded-full shadow-sm hover:scale-110 transition-all duration-300 cursor-pointer p-1"
        data-product-id="{{ product.id }}"
        onclick="window.LuviaWishlist.toggle('{{ product.id }}')"
        aria-label="Wishlist"
      >
        <svg
          class="wishlist-icon text-primary transition-all duration-300 pointer-events-none w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
        </svg>
      </button>
    </div>

    {% comment %} Ürün Görselleri {% endcomment %}
    <a href="{{ product.url }}" class="block h-full w-full z-10">
      {% if product.featured_image != blank %}
        <img
          src="{{ product.featured_image | image_url: width: 400 }}"
          alt="{{ product.title | escape }}"
          loading="lazy"
          width="100%"
          height="auto"
          class="w-full h-full object-cover transition-opacity duration-700 {% if product.images[1] %}group-hover:opacity-0{% endif %}"
        >
        {% if product.images[1] -%}
          <img
            src="{{ product.images[1] | image_url: width: 400 }}"
            alt="{{ product.title | escape }}"
            loading="lazy"
            width="100%"
            height="auto"
            class="w-full h-full object-cover absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700"
          >
        {%- endif %}
      {% else %}
        <div class="w-full h-full bg-gray-100 transition-opacity duration-700 group-hover:opacity-0 flex items-center justify-center">
          {{ 'product-1' | placeholder_svg_tag: 'w-full h-full object-cover opacity-20' }}
        </div>
        <div class="w-full h-full absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-700 bg-gray-200 flex items-center justify-center">
          {{ 'product-2' | placeholder_svg_tag: 'w-full h-full object-cover opacity-20' }}
        </div>
      {% endif %}
    </a>

    {% comment %} SEPETE EKLE BUTONU (Global Fonksiyon Bağlı) {% endcomment %}
    <div class="absolute inset-x-0 bottom-0 translate-y-full group-hover:translate-y-0 transition-transform duration-300 hidden md:block z-30">
      <button
        type="button"
        onclick="window.handleGlobalAddToCart(event, '{{ product.selected_or_first_available_variant.id }}')"
        class="w-full bg-primary text-white py-4 text-[14px] uppercase tracking-[0.1em] font-bold block text-center hover:bg-secondary transition-colors cursor-pointer border-none"
        {% unless product.available %}
          disabled
        {% endunless %}
      >
        {% if product.available %}
          {{ 'products.product.add_to_cart' | t }}
        {% else %}
          {{ 'products.product.sold_out' | t }}
        {% endif %}
      </button>
    </div>
  </div>

  {% comment %} Ürün Bilgileri {% endcomment %}
  <div class="pt-4 pb-2 flex flex-col items-center px-3">
    <a
      href="{{ product.url }}"
      class="text-primary text-[14px] hover:text-secondary transition-colors uppercase text-center"
    >
      {{ product.title }}
    </a>
    <div class="mt-2 flex items-center gap-2">
      {% if product.compare_at_price > product.price -%}
        <span class="text-gray-400 line-through text-[12px]">{{ product.compare_at_price | money }}</span>
      {%- endif %}
      <span class="text-primary text-[14px] font-medium">{{ product.price | money }}</span>
    </div>
  </div>
</div>

<style>
  /* Global JS 'active' veya 'wishlist-active' eklediğinde kalbi doldur */
  .custom-wishlist-btn.active svg,
  .custom-wishlist-btn.wishlist-active svg,
  .custom-wishlist-btn.is-active svg {
    fill: currentColor !important;
  }
</style>
