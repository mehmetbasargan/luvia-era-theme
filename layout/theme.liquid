<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="ltr">
  <head>
    <meta charset="utf-8">
    <meta
      name="viewport"
      content="width=device-width,initial-scale=1,shrink-to-fit=no,viewport-fit=cover,user-scalable=no"
    >

    {% # Meta tags, social, favicon %}
    {% render 'meta-tags' %}

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
      <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180 }}">
    {%- endif -%}

    {%- assign heading_font = settings.heading_font -%}
    {%- assign body_font = settings.body_font -%}

    <style>
      {{ heading_font | font_face: font_display: 'swap' }}
      {{ body_font | font_face: font_display: 'swap' }}

      :root {
        /* Renk Değişkenleri */
        --color-primary: {{ settings.primary_color | strip }};
        --color-secondary: {{ settings.secondary_color | strip }};
        --color-custombg: {{ settings.custom_bg_color | strip }};
        --color-line: {{ settings.line_color | strip }};
        --color-bgtransparent: {{ settings.bgtransparent_color | strip }};
        --color-white: #ffffff;
        --color-black: #000000;

        /* Font Değişkenlericcc - BURASI EKSİKTİ */
        --font-heading: {{ heading_font.family }}, {{ heading_font.fallback_families }};
        --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};
      }

      body {
        background-color: var(--color-white);
        color: var(--color-primary);
        font-family: var(--font-body); /* Artık yukarıdaki değişkeni okuyabilir */
        margin: 0;
        -webkit-font-smoothing: antialiased;
        display: block !important;
        opacity: 1 !important;
      }

      h1, h2, h3, h4, h5, h6, .font-heading {
        font-family: var(--font-heading); /* Artık yukarıdaki değişkeni okuyabilir */
      }
    </style>

    {{ content_for_header }}

    {% # Asset CSS %}
    {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'tailwind.output.css' | asset_url | stylesheet_tag: preload: true }}
  </head>

  <body itemscope itemtype="https://schema.org/WebPage">
    <div
      id="toast-container"
      class="fixed bottom-10 left-1/2 -translate-x-1/2 z-[200] space-y-2 pointer-events-none"
      role="status"
      aria-live="polite"
    ></div>

    <header role="banner" itemscope itemtype="https://schema.org/WPHeader">
      {% sections 'header-group' %}
    </header>

    {% render 'cart-drawer' %}

    <script>
      window.customer = {% if customer %}{{ customer | json }}{% else %}false{% endif %};
  
      // Global showToast function
      window.showToast = function(message, type = 'info') {
        const toast = document.createElement('div');
        toast.className = `fixed top-4 right-4 z-[9999] px-6 py-3 rounded-lg shadow-lg transition-all duration-300 transform translate-x-full ${
          type === 'success' ? 'bg-green-500 text-white' :
          type === 'error' ? 'bg-red-500 text-white' :
          type === 'warning' ? 'bg-yellow-500 text-white' :
          'bg-blue-500 text-white'
        }`;
        toast.textContent = message;
        document.body.appendChild(toast);
        
        setTimeout(() => {
          toast.classList.remove('translate-x-full');
        }, 100);
        
        setTimeout(() => {
          toast.classList.add('translate-x-full');
          setTimeout(() => {
            document.body.removeChild(toast);
          }, 300);
        }, 3000);
      };
  
      // Global closeCartDrawer function
      window.closeCartDrawer = function() {
        const drawer = document.getElementById('cart-drawer');
        const overlay = document.getElementById('cart-drawer-overlay');
        const content = document.getElementById('cart-drawer-content');
        
        if (overlay && content) {
          overlay.classList.replace('opacity-100', 'opacity-0');
          content.classList.replace('translate-x-0', 'translate-x-full');
          setTimeout(() => {
            if (drawer) {
              drawer.classList.add('invisible');
            }
          }, 500);
        }
      };
  
      // Global openCartDrawer function
      window.openCartDrawer = function() {
        const drawer = document.getElementById('cart-drawer');
        const overlay = document.getElementById('cart-drawer-overlay');
        const content = document.getElementById('cart-drawer-content');
        
        if (drawer && overlay && content) {
          drawer.classList.remove('invisible');
          setTimeout(() => {
            overlay.classList.replace('opacity-0', 'opacity-100');
            content.classList.replace('translate-x-full', 'translate-x-0');
          }, 10);
        }
      };
  
      // Global Wishlist Functions
      window.LuviaWishlist = {
        toggle: function(productId) {
          let wishlist = JSON.parse(localStorage.getItem('luvia-wishlist') || '[]');
          
          if (wishlist.includes(productId.toString())) {
            // Remove from wishlist
            wishlist = wishlist.filter(id => id !== productId.toString());
            showToast('Product removed from wishlist!', 'info');
          } else {
            // Add to wishlist
            wishlist.push(productId.toString());
            showToast('Product added to wishlist!', 'success');
          }
          
          localStorage.setItem('luvia-wishlist', JSON.stringify(wishlist));
          
          // Update all wishlist buttons
          const updateAllWishlistButtons = function() {
            document.querySelectorAll('.wishlist-trigger-btn, .custom-wishlist-btn, [id*="wishlist-btn"]').forEach(btn => {
              const btnProductId = btn.dataset.productId || btn.dataset.id || btn.id.replace('wishlist-btn-', '');
              console.log('Updating button:', btnProductId, 'in wishlist:', wishlist.includes(btnProductId.toString()));
              
              if (wishlist.includes(btnProductId.toString())) {
                btn.classList.add('active', 'bg-primary', 'text-white');
                btn.classList.remove('border', 'text-primary');
                const btnText = btn.querySelector('[id*="wishlist-text"]');
                if (btnText) btnText.textContent = 'Remove from Wishlist';
                // Update SVG fill for active state
                const svg = btn.querySelector('svg');
                if (svg) {
                  svg.style.fill = 'currentColor';
                  svg.classList.add('text-white');
                }
              } else {
                btn.classList.remove('active', 'bg-primary', 'text-white');
                btn.classList.add('border', 'text-primary');
                const btnText = btn.querySelector('[id*="wishlist-text"]');
                if (btnText) btnText.textContent = 'Add to Wishlist';
                // Update SVG fill for inactive state
                const svg = btn.querySelector('svg');
                if (svg) {
                  svg.style.fill = 'none';
                  svg.classList.remove('text-white');
                }
              }
            });
          };
          
          updateAllWishlistButtons();
          
          // Dispatch event for other components
          window.dispatchEvent(new CustomEvent('wishlist:updated', {
            detail: { productId, wishlist }
          }));
        },
        
        remove: function(productId) {
          let wishlist = JSON.parse(localStorage.getItem('luvia-wishlist') || '[]');
          wishlist = wishlist.filter(id => id !== productId.toString());
          localStorage.setItem('luvia-wishlist', JSON.stringify(wishlist));
          
          // Remove element from DOM
          const itemElement = document.getElementById(`wish-item-${productId}`);
          if (itemElement) {
            itemElement.remove();
          }
          
          // Dispatch event
          window.dispatchEvent(new CustomEvent('wishlist:updated', {
            detail: { productId, wishlist }
          }));
          
          showToast('Product removed from wishlist!', 'info');
        }
      };
      
      // Global toggleWishlist function (alias for LuviaWishlist.toggle)
      window.toggleWishlist = function(productId, button) {
        window.LuviaWishlist.toggle(productId);
      };
  
      // Listen for wishlist updates from other components
      document.addEventListener('wishlist:updated', function() {
        setTimeout(() => {
          updateAllWishlistButtons();
        }, 100);
      });


      /*  */
        window.LuviaWishlist = {
  // Hafızadaki listeyi getir
  get: function() {
    return JSON.parse(localStorage.getItem('luvia-wishlist') || '[]');
  },
  
  // Şık bir uyarı mesajı (Toast) göster
  showToast: function(message) {
    const oldToast = document.querySelector('.luvia-toast');
    if (oldToast) oldToast.remove();

    const toast = document.createElement('div');
    toast.className = 'luvia-toast fixed bottom-8 left-1/2 -translate-x-1/2 bg-primary text-white px-8 py-3 rounded-full shadow-2xl z-[9999] text-[12px] uppercase tracking-[0.2em] transition-all duration-500 opacity-0 translate-y-4';
    toast.innerText = message;
    document.body.appendChild(toast);

    setTimeout(() => toast.classList.remove('opacity-0', 'translate-y-4'), 10);

    setTimeout(() => {
      toast.classList.add('opacity-0', 'translate-y-4');
      setTimeout(() => toast.remove(), 500);
    }, 3000);
  },

  toggle: function(productId) {
    let wishlist = this.get();
    const index = wishlist.indexOf(productId.toString());
    const isAdding = index === -1;

    if (isAdding) {
      wishlist.push(productId.toString());
      this.showToast("ADDED TO WISHLIST");
    } else {
      wishlist.splice(index, 1);
      this.showToast("REMOVED FROM WISHLIST");
    }

    localStorage.setItem('luvia-wishlist', JSON.stringify(wishlist));
    
    // UI Güncelleme
    this.updateUI(productId, isAdding);

    // Wishlist sayfasındaysak satırı kaldır
    const wishItem = document.getElementById(`wish-item-${productId}`);
    if (!isAdding && wishItem) {
      wishItem.style.opacity = '0';
      wishItem.style.transform = 'scale(0.9)';
      setTimeout(() => {
        wishItem.remove();
        if (typeof this.checkEmpty === 'function') this.checkEmpty();
      }, 300);
    }

    window.dispatchEvent(new CustomEvent('wishlist:updated', { detail: { productId, wishlist, isAdding } }));
  },

  updateUI: function(productId, isActive) {
    const buttons = document.querySelectorAll(`.custom-wishlist-btn[data-product-id="${productId}"], .wishlist-trigger-btn[data-product-id="${productId}"]`);
    buttons.forEach(btn => {
      const svg = btn.querySelector('svg');
      if (isActive) {
        btn.classList.add('wishlist-active');
        if(svg) svg.setAttribute('fill', 'currentColor'); 
      } else {
        btn.classList.remove('wishlist-active');
        if(svg) svg.setAttribute('fill', 'none');
      }
    });
  },

  initIcons: function() {
    const wishlist = this.get();
    wishlist.forEach(id => this.updateUI(id, true));
  }
};

// Başlat
document.addEventListener('DOMContentLoaded', () => {
  window.LuviaWishlist.initIcons();
});


      /* ***** */
    </script>

    <main role="main" itemprop="mainContentOfPage">
      {{ content_for_layout }}
    </main>

    <footer role="contentinfo" itemscope itemtype="https://schema.org/WPFooter">
      {% sections 'footer-group' %}
    </footer>

    <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>
    <script src="{{ 'theme.js' | asset_url }}" defer></script>

    {% # Senin tüm Wishlist, Toast ve Cart Drawer JS scriptlerin burada devam edebilir %}
    <script>
      // Buraya daha önce yazdığın scriptleri ekleyebilirsin.
    </script>
  </body>
</html>
