<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="ltr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no, viewport-fit=cover">
    <title>{{ page_title | default: shop.name | escape }}</title>
    {% render 'meta-tags' %}
    <link rel="canonical" href="{{ canonical_url }}">

    {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}

    <style>
      {{ settings.heading_font | font_face: font_display: 'swap' }}
      {{ settings.body_font | font_face: font_display: 'swap' }}

      :root {
        --font-heading: {{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families | default: 'sans-serif' }};
        --font-body: {{ settings.body_font.family }}, {{ settings.body_font.fallback_families | default: 'sans-serif' }};
        --color-primary: {{ settings.primary_color | default: '#3b443c' }};
        --color-secondary: {{ settings.secondary_color | default: '#5a5432' }};
        --header-opacity: {{ settings.header_opacity | default: 100 | divided_by: 100.0 }};
      }

      /* !IMPORTANT'LARI TEMİZLEDİK: Tailwind artık bunları ezebilir */
      html, body {
        font-family: var(--font-body);
        background-color: {{ settings.background_color | default: '#ffffff' }};
        color: var(--color-primary);
        margin: 0;
      }

      h1, h2, h3, h4, h5, h6, .h1, .h2, .h3, .h4, .h5, .h6 {
        font-family: var(--font-heading) !important; /* Font ailesi sabit kalsın */
        color: var(--color-secondary);
        text-transform: uppercase;
        font-weight: {{ settings.heading_font.weight | default: 400 }};
      }

      /* Varsayılan boyutlar (Clamp kalsın ama !important sildik) */
      h1, .h1 { font-size: clamp(1.75rem, 4vw, 2.5rem); }
      h2, .h2 { font-size: clamp(1.5rem, 3.5vw, 2rem); }
      h3, .h3 { font-size: clamp(1.25rem, 3vw, 1.625rem); }
      h4, .h4 { font-size: clamp(1.1rem, 2.5vw, 1.375rem); }
      h5, .h5 { font-size: clamp(1rem, 2vw, 1.125rem); }
      h6, .h6 { font-size: clamp(0.85rem, 1.5vw, 0.95rem); }

      /* Diğer dekoratifler */
      svg { stroke: currentColor; fill: none; transition: all 0.3s ease; }
      #main-header {
        background-color: rgba(255, 255, 255, var(--header-opacity));
        transition: background-color 0.3s ease;
      }
    </style>

    {{ 'style.output.css' | asset_url | stylesheet_tag }}

    {{ content_for_header }}
  </head>

  <body itemscope itemtype="https://schema.org/WebPage">
    <div
      id="toast-container"
      class="fixed bottom-10 left-1/2 -translate-x-1/2 z-[200] space-y-2 pointer-events-none"
      role="status"
      aria-live="polite"
    ></div>

    <header role="banner" itemscope itemtype="https://schema.org/WPHeader">
      {% sections 'header-group' %}
    </header>

    {% render 'cart-drawer' %}

    <main role="main" itemprop="mainContentOfPage">
      {{ content_for_layout }}
    </main>

    <footer role="contentinfo" itemscope itemtype="https://schema.org/WPFooter">
      {% sections 'footer-group' %}
    </footer>

    <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
    <script src="{{ 'luvia-global.js' | asset_url }}" defer></script>

    <script>
      window.customer = {% if customer %}{{ customer | json }}{% else %}false{% endif %};
      window.LuviaStrings = {
        wishlistAdded: {{ 'wishlist.added' | t | json }},
        wishlistRemoved: {{ 'wishlist.removed' | t | json }},
        cartAdded: {{ 'products.product.add_to_cart' | t | json }}
      };
    </script>

    {% render 'luvia-lightbox' %}
  </body>
</html>
