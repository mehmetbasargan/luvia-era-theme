<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="ltr">
  <head>
    <meta charset="utf-8">
    <meta
      name="viewport"
      content="width=device-width,initial-scale=1,shrink-to-fit=no,viewport-fit=cover,user-scalable=no"
    >

    <!-- SEO Meta Tags -->
    <title>
      {%- if template == 'product' -%}
        {{ product.title }} - {{ shop.name }}
      {%- elsif template == 'collection' -%}
        {{ collection.title }} - {{ shop.name }}
      {%- elsif template == 'blog' -%}
        {{ blog.title }} - {{ shop.name }}
      {%- elsif template == 'article' -%}
        {{ article.title }} - {{ blog.title }} - {{ shop.name }}
      {%- else -%}
        {{ page_title }} - {{ shop.name }}
      {%- endif -%}
    </title>

    <meta name="description" content="{{ page_description | default: shop.description | truncate: 160 | escape }}">

    <!-- Open Graph Meta Tags -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="{{ page_title | default: shop.name | escape }}">
    <meta
      property="og:description"
      content="{{ page_description | default: shop.description | truncate: 160 | escape }}"
    >
    {% if settings.logo %}
      <meta property="og:image" content="{{ settings.logo | image_url: width: 1200, height: 630 }}">
    {% endif %}
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:site_name" content="{{ shop.name | escape }}">

    <!-- Twitter Card Meta Tags -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ page_title | default: shop.name | escape }}">
    <meta
      name="twitter:description"
      content="{{ page_description | default: shop.description | truncate: 160 | escape }}"
    >
    {% if settings.logo %}
      <meta name="twitter:image" content="{{ settings.logo | image_url: width: 1200, height: 630 }}">
    {% endif %}

    <!-- Additional SEO Meta Tags -->
    <meta name="robots" content="index, follow">
    <meta name="googlebot" content="index, follow">
    <meta name="language" content="{{ shop.locale }}">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <!-- Canonical URL -->
    <link rel="canonical" href="{{ canonical_url }}">

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Organization",
        "name": "{{ shop.name | escape }}",
        "url": "{{ shop.url }}",
        {% if settings.logo %}
        "logo": "{{ settings.logo | image_url: width: 400, height: 400 }}",
        {% endif %}
        "description": "{{ shop.description | escape }}"
      }
    </script>

    {% render 'meta-tags' %}

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
      <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180 }}">
    {%- endif -%}

    {%- assign heading_font = settings.heading_font -%}
    {%- assign body_font = settings.body_font -%}

    <style>
      {{ heading_font | font_face: font_display: 'swap' }}
      {{ body_font | font_face: font_display: 'swap' }}

      :root {
        --font-heading: {{ heading_font.family }}, {{ heading_font.fallback_families }};
        --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};

        /* Global Değişkenler */
        --color-primary: {{ settings.primary_color | default: '#3b443c' }};
        --color-secondary: {{ settings.secondary_color | default: '#b2ac88' }};
        --color-custombg: {{ settings.custom_bg_color | default: '#f9f9f9' }};
        --color-line: {{ settings.line_color | default: '#e5e7eb' }};
      }

      /* 1. TAILWIND İLE ÇAKIŞMAYAN ÖZEL SINIFLAR */
      /* Sadece bizim özel sınıflarımıza !important veriyoruz */
      .bg-custombg { background-color: var(--color-custombg) !important; }
      .text-primary { color: var(--color-primary) !important; }
      .text-secondary { color: var(--color-secondary) !important; }
      .border-line { border-color: var(--color-line) !important; }
      .bg-secondary { background-color: var(--color-secondary) !important; }

      /* 2. GENEL ELEMENTLER */
      body {
        background-color: var(--color-custombg);
        color: var(--color-primary);
        font-family: var(--font-body);
        margin: 0;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
        color: var(--color-primary);
      }

      /* 3. İKONLAR (Sadece varsayılanı belirle, !important kullanma ki değişebilsin) */
      svg {
        stroke: currentColor;
        fill: none;
        transition: all 0.3s ease;
      }

      /* 4. WISHLIST AKTİF DURUMU */
      /* Sınıf isimlerini tam eşleyelim: hem 'active' hem 'wishlist-active' */
      .custom-wishlist-btn.active svg,
      .custom-wishlist-btn.wishlist-active svg {
        fill: var(--color-primary) !important;
        stroke: var(--color-primary) !important;
      }

      /* 5. HOVER & ACTIVE LINK */
      /* Tailwind sınıflarını ezmemesi için daha spesifik seçici kullanalım */
      #main-header .active-link,
      #main-header a:hover {
        color: var(--color-secondary) !important;
      }

      /* Tailwind text-white sınıfının çalışması için koruma */
      .text-white { color: #ffffff !important; }
    </style>

    {{ content_for_header }}

    <!-- Asset CSS -->
    {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'tailwind.output.css' | asset_url | stylesheet_tag: preload: true }}

    <!-- Preload Critical Resources -->
    {% if settings.favicon %}
      {{ settings.favicon | image_url: width: 32 | image_tag: preload: true, alt: '', style: 'display:none;' }}
    {% endif %}
  </head>

  <body itemscope itemtype="https://schema.org/WebPage">
    <div
      id="toast-container"
      class="fixed bottom-10 left-1/2 -translate-x-1/2 z-[200] space-y-2 pointer-events-none"
      role="status"
      aria-live="polite"
    ></div>

    <header role="banner" itemscope itemtype="https://schema.org/WPHeader">
      {% sections 'header-group' %}
    </header>

    {% render 'cart-drawer' %}

    <main role="main" itemprop="mainContentOfPage">
      {{ content_for_layout }}
    </main>

    <footer role="contentinfo" itemscope itemtype="https://schema.org/WPFooter">
      {% sections 'footer-group' %}
    </footer>

    <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>
    <script src="{{ 'theme.js' | asset_url }}" defer></script>

    <script>
      window.customer = {% if customer %}{{ customer | json }}{% else %}false{% endif %};
      window.LuviaStrings = {
        wishlistAdded: {{ 'wishlist.added' | t | json }},
        wishlistRemoved: {{ 'wishlist.removed' | t | json }},
        cartAdded: {{ 'products.product.add_to_cart' | t | json }}
      };
    </script>
    <script src="{{ 'luvia-global.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
