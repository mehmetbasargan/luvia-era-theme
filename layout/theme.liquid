<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="ltr">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no, viewport-fit=cover">

    <title>{{ page_title | default: shop.name | escape }}</title>
    <meta name="description" content="{{ page_description | default: shop.description | truncate: 160 | escape }}">

    {% render 'meta-tags' %}
    <link rel="canonical" href="{{ canonical_url }}">

    <meta property="og:title" content="{{ page_title | default: shop.name | escape }}">
    <meta
      property="og:description"
      content="{{ page_description | default: shop.description | truncate: 160 | escape }}"
    >
    <meta property="og:url" content="{{ canonical_url }}">
    <meta property="og:type" content="website">

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
      <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180 }}">
    {%- endif -%}

    {{ 'style.output.css' | asset_url | stylesheet_tag }}
    {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag }}

    <style>
      /* 1. Dinamik Font Yükleme (RemoteAsset Hatasını Giderir) */
      {{ settings.heading_font | font_face: font_display: 'swap' }}
      {{ settings.body_font | font_face: font_display: 'swap' }}

      /* Kalın versiyonlar için opsiyonel yükleme */
      {{ settings.heading_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
      {{ settings.body_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}

      :root {
        /* Font ailelerini tam isimleriyle ve fallback (yedek) fontlarıyla tanımlıyoruz */
        --font-heading: {{ settings.heading_font.family }}, {{ settings.heading_font.fallback_families | default: 'sans-serif' }};
        --font-body: {{ settings.body_font.family }}, {{ settings.body_font.fallback_families | default: 'sans-serif' }};

        --color-primary: {{ settings.primary_color | default: '#3b443c' }};
        --color-secondary: {{ settings.secondary_color | default: '#867f57' }};
        --color-custombg: {{ settings.custom_bg_color | default: '#f9f9f9' }};
        --color-line: {{ settings.line_color | default: '#e5e7eb' }};
        --color-main-bg: {{ settings.background_color | default: '#ffffff' }};

        /* Header Opacity Değişkeni */
        --header-opacity: {{ settings.header_opacity | default: 100 | divided_by: 100.0 }};
      }

      /* 2. Global Font Uygulaması: Tarayıcıyı zorlamak için html ve body'e ekliyoruz */
      html, body {
        font-family: var(--font-body) !important;
        background-color: var(--color-main-bg);
        color: var(--color-primary);
        margin: 0;
        -webkit-font-smoothing: antialiased;
      }

      /* BAŞLIKLAR: Panelden Seçilen Fontu Kullanır */
      h1, h2, h3, h4, h5, h6, .h1, .h2, .h3, .h4, .h5, .h6 {
        font-family: var(--font-heading) !important;
        color: var(--color-secondary) !important;
        text-transform: uppercase !important;
        letter-spacing: 1px !important;
        font-weight: {{ settings.heading_font.weight | default: 400 }} !important;
        line-height: 1.2;
      }

      /* Rafine Font Boyutları */
      h1, .h1 { font-size: clamp(1.75rem, 4vw, 2.5rem) !important; }
      h2, .h2 { font-size: clamp(1.5rem, 3.5vw, 2rem) !important; }
      h3, .h3 { font-size: clamp(1.25rem, 3vw, 1.625rem) !important; }
      h4, .h4 { font-size: clamp(1.1rem, 2.5vw, 1.375rem) !important; }
      h5, .h5 { font-size: clamp(1rem, 2vw, 1.125rem) !important; }
      h6, .h6 { font-size: clamp(0.85rem, 1.5vw, 0.95rem) !important; }

      /* Diğer Yardımcı Sınıflar */
      .bg-custombg { background-color: var(--color-custombg) !important; }
      .text-primary { color: var(--color-primary) !important; }
      .text-secondary { color: var(--color-secondary) !important; }
      .text-white { color: #ffffff !important; }

      svg { stroke: currentColor; fill: none; transition: all 0.3s ease; }

      #main-header .active-link, #main-header a:hover {
        color: var(--color-secondary) !important;
      }

      /* Header Şeffaflık Uygulaması: Arka plan rengini CSS değişkeninden çeker */
      #main-header {
        background-color: rgba(255, 255, 255, var(--header-opacity)) !important;
        transition: background-color 0.3s ease;
      }

      .custom-wishlist-btn.active svg, .custom-wishlist-btn.wishlist-active svg {
        fill: var(--color-primary) !important;
        stroke: var(--color-primary) !important;
      }
    </style>

    {{ content_for_header }}
  </head>

  <body itemscope itemtype="https://schema.org/WebPage">
    <div
      id="toast-container"
      class="fixed bottom-10 left-1/2 -translate-x-1/2 z-[200] space-y-2 pointer-events-none"
      role="status"
      aria-live="polite"
    ></div>

    <header role="banner" itemscope itemtype="https://schema.org/WPHeader">
      {% sections 'header-group' %}
    </header>

    {% render 'cart-drawer' %}

    <main role="main" itemprop="mainContentOfPage">
      {{ content_for_layout }}
    </main>

    <footer role="contentinfo" itemscope itemtype="https://schema.org/WPFooter">
      {% sections 'footer-group' %}
    </footer>

    <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>
    <script src="{{ 'theme.js' | asset_url }}" defer></script>
    <script src="{{ 'luvia-global.js' | asset_url }}" defer></script>

    <script>
      window.customer = {% if customer %}{{ customer | json }}{% else %}false{% endif %};
      window.LuviaStrings = {
        wishlistAdded: {{ 'wishlist.added' | t | json }},
        wishlistRemoved: {{ 'wishlist.removed' | t | json }},
        cartAdded: {{ 'products.product.add_to_cart' | t | json }}
      };
    </script>

    {% render 'luvia-lightbox' %}
  </body>
</html>
