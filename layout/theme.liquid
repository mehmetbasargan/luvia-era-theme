<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="ltr">
  <head>
    <meta charset="utf-8">
    <meta
      name="viewport"
      content="width=device-width,initial-scale=1,shrink-to-fit=no,viewport-fit=cover,user-scalable=no"
    >

    <!-- SEO Meta Tags -->
    <title>
      {{ page_title }}
      -
      {{ shop.name }}
    </title>
    <meta name="description" content="{{ page_description | default: shop.description | escape }}">

    {% render 'meta-tags' %}

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
      <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180 }}">
    {%- endif -%}

    {%- assign heading_font = settings.heading_font -%}
    {%- assign body_font = settings.body_font -%}

    <style>
      {{ heading_font | font_face: font_display: 'swap' }}
      {{ body_font | font_face: font_display: 'swap' }}

      :root {
        /* 1. Global Yazı Tipleri */
        --font-heading: {{ heading_font.family }}, {{ heading_font.fallback_families }};
        --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};

        /* 2. ANA RENK DEĞİŞKENLERİ (Settings'ten gelenler) */
        --color-primary: {{ settings.primary_color | default: '#3b443c' }};
        --color-secondary: {{ settings.secondary_color | default: '#b2ac88' }};
        --color-custombg: {{ settings.custom_bg_color | default: '#f9f9f9' }};
        --color-line: {{ settings.line_color | default: '#e5e7eb' }};
        --color-white: #ffffff;
        --color-black: #000000;
      }

      /* 3. TAILWIND SINIFLARINI HAYATA DÖNDÜRME */
      /* Şemaları sildiğimiz için bu sınıfları manuel eşliyoruz */
      .bg-custombg { background-color: var(--color-custombg) !important; }
      .text-primary { color: var(--color-primary) !important; }
      .text-secondary { color: var(--color-secondary) !important; }
      .border-line { border-color: var(--color-line) !important; }
      .bg-secondary { background-color: var(--color-secondary) !important; }

      /* 4. Genel Element Stilleri */
      body {
        background-color: var(--color-custombg);
        color: var(--color-primary);
        font-family: var(--font-body);
        margin: 0;
        display: block !important;
        opacity: 1 !important;
      }

      h1, h2, h3, h4, h5, h6 {
        font-family: var(--font-heading);
        color: var(--color-primary); /* Başlıklar varsayılan ana renk */
      }

      /* İkonlar için Evrensel Kural */
      svg {
        stroke: currentColor;
        fill: none;
        transition: all 0.3s ease;
      }

      /* Aktif Link ve Hover Global Kural */
      .active-link, a:hover, button:hover {
        color: var(--color-secondary) !important;
      }

      /* Wishlist Aktifleşince Kalbin İçini Doldur */
      .custom-wishlist-btn.wishlist-active svg,
      .custom-wishlist-btn.active svg {
        fill: var(--color-primary) !important;
        stroke: var(--color-primary) !important;
        color: var(--color-primary) !important;
      }

      /* Wishlist Aktif Değilse Kalp Boş */
      .custom-wishlist-btn:not(.wishlist-active):not(.active) svg {
        fill: none !important;
        stroke: var(--color-primary) !important;
        color: var(--color-primary) !important;
      }

      /* Hover yapınca hafif bir tepki */
      .custom-wishlist-btn:hover svg {
        transform: scale(1.1);
      }

      /* Accessibility Focus States */
      button:focus-visible,
      a:focus-visible,
      input:focus-visible,
      select:focus-visible,
      textarea:focus-visible {
        outline: 2px solid var(--color-primary);
        outline-offset: 2px;
      }

      /* Better Contrast for Interactive Elements */
      .btn, button, a {
        color: var(--color-primary) !important;
        min-height: 44px;
        min-width: 44px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
    </style>

    {{ content_for_header }}

    <!-- Asset CSS -->
    {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'tailwind.output.css' | asset_url | stylesheet_tag: preload: true }}

    <!-- Preload Critical Resources -->
    {% if settings.favicon %}
      {{ settings.favicon | image_url: width: 32 | image_tag: preload: true, alt: '', style: 'display:none;' }}
    {% endif %}
  </head>

  <body itemscope itemtype="https://schema.org/WebPage">
    <div
      id="toast-container"
      class="fixed bottom-10 left-1/2 -translate-x-1/2 z-[200] space-y-2 pointer-events-none"
      role="status"
      aria-live="polite"
    ></div>

    <header role="banner" itemscope itemtype="https://schema.org/WPHeader">
      {% sections 'header-group' %}
    </header>

    {% render 'cart-drawer' %}

    <main role="main" itemprop="mainContentOfPage">
      {{ content_for_layout }}
    </main>

    <footer role="contentinfo" itemscope itemtype="https://schema.org/WPFooter">
      {% sections 'footer-group' %}
    </footer>

    <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>
    <script src="{{ 'theme.js' | asset_url }}" defer></script>

    <script>
      window.customer = {% if customer %}{{ customer | json }}{% else %}false{% endif %};
      window.LuviaStrings = {
        wishlistAdded: {{ 'wishlist.added' | t | json }},
        wishlistRemoved: {{ 'wishlist.removed' | t | json }},
        cartAdded: {{ 'products.product.add_to_cart' | t | json }}
      };
    </script>
    <script src="{{ 'luvia-global.js' | asset_url }}" defer="defer"></script>
  </body>
</html>
