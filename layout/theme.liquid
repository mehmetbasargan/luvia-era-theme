<!doctype html>
<html lang="{{ request.locale.iso_code }}" dir="ltr">
  <head>
    <meta
      name="viewport"
      content="width=device-width,initial-scale=1,shrink-to-fit=no,viewport-fit=cover,user-scalable=no"
    >
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {%- if settings.favicon != blank -%}
      <link rel="icon" type="image/png" href="{{ settings.favicon | image_url: width: 32, height: 32 }}">
      <link rel="apple-touch-icon" href="{{ settings.favicon | image_url: width: 180, height: 180 }}">
    {%- endif -%}

    {%- assign heading_font = settings.heading_font -%}
    {%- assign body_font = settings.body_font -%}

    <style>
      {{ heading_font | font_face: font_display: 'swap' }}
      {{ body_font | font_face: font_display: 'swap' }}

      :root {
        --color-primary: {{ settings.primary_color }};
        --color-secondary: {{ settings.secondary_color }};
        --color-custombg: {{ settings.custom_bg_color }};
        --color-line: {{ settings.line_color }};
        --color-white: #ffffff;
        --color-black: #000000;

        --font-heading: {{ heading_font.family }}, {{ heading_font.fallback_families }};
        --font-body: {{ body_font.family }}, {{ body_font.fallback_families }};
      }

      body {
        background-color: var(--color-white);
        color: var(--color-primary);
        font-family: var(--font-body);
        margin: 0;
        -webkit-font-smoothing: antialiased;
        display: block !important;
        opacity: 1 !important;
      }

      h1, h2, h3, h4, h5, h6, .font-heading {
        font-family: var(--font-heading);
      }

      /* Mobile Performance */
      img {
        image-rendering: -webkit-optimize-contrast;
        image-rendering: crisp-edges;
      }
    </style>

    {{ content_for_header }}

    {% # Critical CSS with preload %}
    {{ 'swiper-bundle.min.css' | asset_url | stylesheet_tag: preload: true }}
    {{ 'tailwind.output.css' | asset_url | stylesheet_tag: preload: true }}
  </head>

  <body itemscope itemtype="https://schema.org/WebPage">
    <div
      id="toast-container"
      class="fixed bottom-10 left-1/2 -translate-x-1/2 z-[200] space-y-2 pointer-events-none"
      role="status"
      aria-live="polite"
    ></div>

    <header role="banner" itemscope itemtype="https://schema.org/WPHeader">
      {% sections 'header-group' %}
    </header>
    {% render 'cart-drawer' %}

    <script>
      window.customer = {% if customer %}{{ customer | json }}{% else %}false{% endif %};
    </script>

    <main role="main" itemprop="mainContentOfPage">
      {{ content_for_layout }}
    </main>

    <footer role="contentinfo" itemscope itemtype="https://schema.org/WPFooter">
      {% sections 'footer-group' %}
    </footer>

    <script src="{{ 'swiper-bundle.min.js' | asset_url }}" defer></script>
    <script src="{{ 'theme.js' | asset_url }}" defer></script>

    <script>
      // Global Toast Function
      window.showToast = function (message, type = 'success') {
        const toast = document.createElement('div');
        toast.className = `fixed top-4 right-4 z-[9999] px-4 py-2 rounded-lg text-white text-sm font-medium transition-all duration-300 transform translate-x-full ${
          type === 'success' ? 'bg-green-500' : 'bg-primary'
        }`;
        toast.textContent = message;

        document.body.appendChild(toast);

        setTimeout(() => {
          toast.classList.remove('translate-x-full');
        }, 100);

        setTimeout(() => {
          toast.classList.add('translate-x-full', 'opacity-0');
          setTimeout(() => toast.remove(), 300);
        }, 3000);
      };

      // Global Cart Drawer Functions
      window.openCartDrawer = function () {
        const drawer = document.getElementById('cart-drawer');
        const overlay = document.getElementById('cart-drawer-overlay');
        const content = document.getElementById('cart-drawer-content');

        if (!drawer) return;

        drawer.classList.remove('invisible');

        setTimeout(() => {
          overlay?.classList.replace('opacity-0', 'opacity-100');
          content?.classList.replace('translate-x-full', 'translate-x-0');
        }, 10);
      };

      window.closeCartDrawer = function () {
        const drawer = document.getElementById('cart-drawer');
        const overlay = document.getElementById('cart-drawer-overlay');
        const content = document.getElementById('cart-drawer-content');

        if (!drawer) return;

        overlay?.classList.replace('opacity-100', 'opacity-0');
        content?.classList.replace('translate-x-0', 'translate-x-full');

        setTimeout(() => {
          drawer.classList.add('invisible');
        }, 500);
      };
    </script>

    <script>
      const LuviaWishlist = {
        storageKey: 'luvia_wishlist_data',

        init() {
          this.bindEvents();
          this.renderUI();
          setInterval(() => this.renderUI(), 1000);
        },

        get() {
          return JSON.parse(localStorage.getItem(this.storageKey)) || [];
        },

        toggle(id, title = 'Product') {
          let list = this.get();
          const index = list.indexOf(id.toString());
          let added = false;

          if (index > -1) {
            list.splice(index, 1);
            this.showToast(`${title} removed from favorites.`);
          } else {
            list.push(id.toString());
            this.showToast(`${title} added to favorites!`);
            added = true;
          }

          localStorage.setItem(this.storageKey, JSON.stringify(list));
          this.renderUI();
          return added;
        },

        // Show small notification to user
        showToast(message) {
          const toast = document.createElement('div');
          toast.className =
            'fixed bottom-5 right-5 bg-primary text-white px-6 py-3 rounded-full shadow-2xl z-[9999] animate-bounce text-[13px] uppercase tracking-widest';
          toast.innerText = message;
          document.body.appendChild(toast);
          setTimeout(() => toast.remove(), 3000);
        },

        renderUI() {
          const list = this.get();
          document.querySelectorAll('.custom-wishlist-btn').forEach((btn) => {
            const id = btn.getAttribute('data-id');
            const svg = btn.querySelector('svg');
            if (list.includes(id.toString())) {
              svg.setAttribute('fill', 'currentColor');
              svg.classList.add('text-red-500');
            } else {
              svg.setAttribute('fill', 'none');
              svg.classList.remove('text-red-500');
            }
          });
        },

        bindEvents() {
          document.addEventListener(
            'click',
            (e) => {
              const btn = e.target.closest('.custom-wishlist-btn');
              if (btn) {
                e.preventDefault();
                e.stopPropagation();
                const id = btn.getAttribute('data-id');
                // Ürün başlığını karttan çekmeye çalışalım (opsiyonel)
                const title = btn.closest('.group')?.querySelector('a.text-primary')?.innerText || 'Ürün';
                this.toggle(id, title);
              }
            },
            true
          );
        },
      };

      LuviaWishlist.init();
    </script>
  </body>
</html>
